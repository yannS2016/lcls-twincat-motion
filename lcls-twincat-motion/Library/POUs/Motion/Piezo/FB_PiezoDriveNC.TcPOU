    <Method Name="MotionParams" Id="{0a8584fe-3c80-4a7e-938d-fcc07474a976}">
      <Declaration><![CDATA[METHOD MotionParams
VAR_INPUT
	tRefreshDelay	: TIME;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[tonReadParamsTimer(
    IN:= NOT bReadParamsExec,
    PT:=tRefreshDelay);
bReadParamsExec S= tonReadParamsTimer.Q;
mcReadParams(
    Parameter:=SUPER^.stPiezoStage.stAxisParameters,
    Axis:=SUPER^.stPiezoStage.Axis,
    Execute:=bReadParamsExec,
    Error=>bError);

// Copy axis parameters that we want to expose to the EPICS layer.
SUPER^.stPiezoStage.stAxisParametersExposed.bCtrlEnablePosDiffControl     := SUPER^.stPiezoStage.stAxisParameters.bCtrlEnablePosDiffControl;
SUPER^.stPiezoStage.stAxisParametersExposed.bEncEnableSoftEndMaxControl   := SUPER^.stPiezoStage.stAxisParameters.bEncEnableSoftEndMaxControl;
SUPER^.stPiezoStage.stAxisParametersExposed.bEncEnableSoftEndMinControl   := SUPER^.stPiezoStage.stAxisParameters.bEncEnableSoftEndMinControl;
SUPER^.stPiezoStage.stAxisParametersExposed.fAccelerationMax              := SUPER^.stPiezoStage.stAxisParameters.fAccelerationMax;
SUPER^.stPiezoStage.stAxisParametersExposed.fCtrlPosDiffMax               := SUPER^.stPiezoStage.stAxisParameters.fCtrlPosDiffMax;
SUPER^.stPiezoStage.stAxisParametersExposed.fCtrlPosDiffMaxTime           := SUPER^.stPiezoStage.stAxisParameters.fCtrlPosDiffMaxTime;
SUPER^.stPiezoStage.stAxisParametersExposed.fDecelerationMax              := SUPER^.stPiezoStage.stAxisParameters.fDecelerationMax;
SUPER^.stPiezoStage.stAxisParametersExposed.fEncSoftEndMax                := SUPER^.stPiezoStage.stAxisParameters.fEncSoftEndMax;
SUPER^.stPiezoStage.stAxisParametersExposed.fEncSoftEndMin                := SUPER^.stPiezoStage.stAxisParameters.fEncSoftEndMin;
SUPER^.stPiezoStage.stAxisParametersExposed.fVeloMaximum                  := SUPER^.stPiezoStage.stAxisParameters.fVeloMaximum;
SUPER^.stPiezoStage.stAxisParametersExposed.fEncOffset               		:= SUPER^.stPiezoStage.stAxisParameters.fEncOffset;
SUPER^.stPiezoStage.stAxisParametersExposed.fEncScaleFactorInternal       := SUPER^.stPiezoStage.stAxisParameters.fEncScaleFactorInternal;

IF mcReadParams.ErrorID <> 0 THEN
    nLatchErrId := 0;
END_IF
bReadParamsExec R= mcReadParams.Done OR mcReadParams.Error;
SUPER^.stPiezoStage.bAxisParamsInit S= mcReadParams.Done;]]></ST>
      </Implementation>
    </Method>
