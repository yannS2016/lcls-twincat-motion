<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_PiezoDriveNC" Id="{a5ab4d86-81e0-47bf-8391-7049ec373d4c}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK PUBLIC FB_PiezoDriveNC EXTENDS FB_PiezoDrive
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    fbSetPos: MC_SetPosition;
    tonReadParamsTimer: TON;

    tRetryDelay: TIME := T#1s;
    nMaxRetries: UINT := 10;
    nCurrTries: UINT := 0;
    bWaitRetry: BOOL;
	bSaveDone	: BOOL;
    tonRetry: TON;
    mcReadParams: MC_ReadParameterSet;
    bReadParamsExec: BOOL := TRUE;
    nLatchErrId: UDINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Brake" Id="{a23dd471-fc06-4b84-bbce-dca5a779d151}">
      <Declaration><![CDATA[METHOD Brake
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="EncSaveRestore" Id="{a24d666c-ec71-4afe-9509-4f94738da469}">
      <Declaration><![CDATA[METHOD EncSaveRestore
VAR_INPUT
	bEnable	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bEnable THEN
    // Trigger a load if anything was saved at all
    IF NOT bInit THEN
        bInit := TRUE;
        bLoad S= bSaved;
        fbSetPos.Options.ClearPositionLag := TRUE;
    END_IF

    // Set our position if bLoad is true
    fbSetPos(
        Axis:=SUPER^.stPiezoStage.Axis,
        Execute:=bLoad,
        Position:=fPosition);

    // Only load once, at startup
    bLoad R= fbSetPos.Done OR fbSetPos.Error;

    IF fbSetPos.Error THEN
        // Keep the error latched, it can disappear if Execute is set to FALSE
        nLatchError := fbSetPos.ErrorID;
        nCurrTries := nCurrTries + 1;
        IF nCurrTries >= nMaxRetries THEN
            // Alert the user that something has gone wrong
            SUPER^.stPiezoStage.bError := TRUE;
            SUPER^.stPiezoStage.nErrorId := nLatchError;
            SUPER^.stPiezoStage.sCustomErrorMessage := 'Error loading previously saved position.';
        ELSE
            // Reset the FB for the next retry
            fbSetPos(
                Axis:=SUPER^.stPiezoStage.Axis,
                Execute:=FALSE,
                Position:=fPosition);
            // Try again
            bWaitRetry := TRUE;
        END_IF
    END_IF

    tonRetry(
        IN := bWaitRetry,
        PT := tRetryDelay);

    bLoad S= tonRetry.Q;
    bWaitRetry R= tonRetry.Q;

    // Check ST_MotionStage for an encoder error (range 0x44nn)
    bEncError := SUPER^.stPiezoStage.bError AND SUPER^.stPiezoStage.nErrorId >= 16#4400 AND SUPER^.stPiezoStage.nErrorId <= 16#44FF;

    // Do not save if we're currently loading or if there is an encoder error
    IF NOT bLoad AND NOT bEncError AND NOT bWaitRetry THEN
        fPosition := SUPER^.stPiezoStage.stAxisStatus.fActPosition;
        // This persistent variable lets us check if anything was saved
        // It will be TRUE at startup if we have saved values
        bSaved := TRUE;
    END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
