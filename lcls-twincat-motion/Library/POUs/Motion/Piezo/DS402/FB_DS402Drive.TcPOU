<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_DS402Drive" Id="{062edea9-cfc5-43cf-98da-5ad9b4d99528}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'call_after_init'}
FUNCTION_BLOCK PUBLIC ABSTRACT FB_DS402Drive IMPLEMENTS I_DS402PiezoDrive
VAR_INPUT

END_VAR
VAR_OUTPUT

END_VAR
VAR
	{attribute 'no_copy'}
    stPiezoStage		:	REFERENCE TO ST_PiezoStage;
	eDriveState			:	E_DS402DriveState;
	fbLogError			:   FB_LogMotionError;
    eHomingState		: 	E_DS402Homing;
	// reuse to absolute/relative moves for DS402
    eAxisState			:  MC_AxisStates;
    // create a property for some of these
    bExecMove			: BOOL;
    bExecHome			: BOOL;
    bPosGoal			: BOOL;
    bNegGoal			: BOOL;
    bNewMoveReq			: BOOL;
    bHomingBusy			: BOOL;
    bHomingDone			: BOOL;
    bPrepareDisable		: BOOL;
    bMoveDone			: BOOL;
    bMoveBusy			: BOOL;
	bHalted				: BOOL;
    bError				: BOOL:=FALSE;
    // use this for motion time axis states
    bExecute			: BOOL;
	// This prevent unexpected logical 1 on stMotionStage.bExecute 
    nErrorId			: UDINT:=0;
    sLocalErrorMessage	: STRING;
	nPiezoErrorCode		: UDINT;
	// Save abd restore encoder value
    bInit				: BOOL;
    bLoad				: BOOL;
    bEncError			: BOOL;

    // axis status -- emulating some NC axis
    bOperational		:	BOOL;
    bPositiveDirection	:  	BOOL;
    bNegativeDirection 	:  	BOOL;
    bInTargetPosition 	:  	BOOL;
	bReadDone			: 	BOOL;
	bLogReady			: 	BOOL;
	bFault				: 	BOOL;
    bDiscreteMotion 	:  	BOOL;
    bContinuousMotion 	:  	BOOL;
    bSlowParamReadTimer	: 	BOOL := TRUE;
    // Drive calibrated motion params
    nCalibratedVelocity			: DINT;
    nCalibratedAcceleration		: DINT;
    nCalibratedTargetPosition 	: DINT;
    nCalibratedMaxVelocity 		: DINT;
    nCalibratedMaxAcceleration	: DINT;
    nCalibratedHomeVelocity 	: DINT;
    nCalibratedHomeAcceleration	: DINT;
    // Calibrated motion params : nanometer operation by default.
    fCalibratedStandStillPos	: REAL;
    fOverride					: REAL;
	fDefaultScalingFactor 		: REAL:=0.000001;
    fCalibratedActPos			: REAL;



	rtFault			: R_TRIG;
    rtHomed			: R_TRIG;
    ftExec			: F_TRIG;
    rtTarget		: R_TRIG;
	ftAmsNetId 		: F_TRIG;
    rtEnableDrive	: R_TRIG;
	ftErrorSdoRead	: F_TRIG;
    ftDisbaleDrive	: F_TRIG;
	
    rtMoveCmdShortcut	: R_TRIG;
    rtHomeCmdShortcut	: R_TRIG;
    rtEnableMode		: R_TRIG;
    rtUserExec			: R_TRIG;

	rtNewMoveReq		: R_TRIG;
	ftForwardEnabled	: F_TRIG;
	ftBackwardEnabled	: F_TRIG;
	rtMotionErrorEvent	: R_TRIG;
	rtNotOperational 	: R_TRIG;

    tonSyncHoming 		: TON;
	tonHoldTime			: TON;
    tonSlowParamReadTimer: TON;
	// fast changing paramter timer -- wwe could have used PDO for this params
	// but the Piezo ESC have fixed PDO list.
	tonFastParamReadTimer: TON;
	//bInitiated	: BOOL;
    // Diagnotics data from the drive, mainly Error codes
	tRefreshDelay   : TIME := T#1S;

    fbErrorSdoRead			: FB_EcCoESdoRead;
    fbFollowWinSdoRead		: FB_EcCoESdoRead;
    fbSoftLimMaxSdoRead		: FB_EcCoESdoRead;
    fbSoftLimMinSdoRead 	: FB_EcCoESdoRead;
    fbMotorloadSdoRead		: FB_EcCoESdoRead;
    fbGetAmsNetId			: FB_GetLocalAmsNetId;

    sAmsNetId 				: T_AmsNetId;
    nSubIndex  				: BYTE := 0;

  	nChanFollowErrorWinIndex	: WORD;
  	nChanSoftwareLimIndex 		: WORD;
  	nChanMotorLoadIndex			: WORD;
	nChanErrorCodeIndex			: WORD;
END_VAR


VAR CONSTANT
    nScaleOffsetIndex	: WORD := 16#2007;
    nScaleInvIndex		: WORD := 16#2008;
	nMotorLoadIndex		: WORD := 16#200d;
    nSoftLimIndex		: WORD := 16#200e;
	nHomeOffsetIndex	: WORD := 16#607c;
	nHomingSpeedIndex	: WORD := 16#6099;
	nhomingAccIndex		: WORD := 16#609a;
	nErrorCodeIndex		: WORD := 16#603f;
	nFollowErrorWinIdex	: WORD := 16#6065;
	nModuleOffsetIndex	: WORD := 16#800;
END_VAR

VAR PERSISTENT
    bSaved: BOOL;
    fPosition: LREAL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="AmsNetIdToString" Id="{7c03e2af-a3ad-4f9f-ae86-d47bb3a86f54}">
      <Declaration><![CDATA[METHOD AmsNetIdToString : BOOL
VAR_INPUT

END_VAR

VAR
	nCounter: UINT;
	nAmsNetIdLen : UINT;
	sTmp	: STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[sAmsNetId := '';
nAmsNetIdLen := (SIZEOF(stPiezoStage.arNetId)-1);
FOR nCounter := 0 TO nAmsNetIdLen BY 1 DO
	IF nCounter <= (nAmsNetIdLen -1) THEN
			sTmp := CONCAT(BYTE_TO_STRING(stPiezoStage.arNetId[nCounter]),'.');
	ELSE
			sTmp := BYTE_TO_STRING(stPiezoStage.arNetId[nCounter]);
	END_IF
	sAmsNetId := CONCAT(sAmsNetId, sTmp);
END_FOR

AmsNetIdToString := (sAmsNetId <> '');]]></ST>
      </Implementation>
    </Method>
