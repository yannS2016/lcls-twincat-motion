    <Property Name="PiezoErrorCode" Id="{6909d919-bde9-446f-9642-d6b8f1850cfe}">
      <Declaration><![CDATA[{attribute 'monitoring':= 'variable'}
PROPERTY PiezoErrorCode : UDINT]]></Declaration>
      <Get Name="Get" Id="{2ea8d926-6bc6-4780-b02a-0d0e439964a4}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[PiezoErrorCode := nPiezoErrorCode;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{dec4dd39-3493-44de-bc51-b50700783e93}">
        <Declaration><![CDATA[VAR
END_VAR
