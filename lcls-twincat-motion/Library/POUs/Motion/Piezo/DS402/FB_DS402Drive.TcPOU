    <Method Name="PostInterlocks" Id="{0f2de4be-a2d5-40b5-bf2e-f13c48bf1447}">
      <Declaration><![CDATA[METHOD PostInterlocks : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// user override aka stop from EPICS ?
// Check done moving via user stop, fbDriveVirtual and Target Position Monitoring, or from homing.
// set/reset stPiezoStage.bDone after move absolute/Relative
ftExec(CLK:=stPiezoStage.bExecute);
rtTarget(CLK:=(InTargetPosition AND MoveDone AND bExecMove));
rtHomed(CLK:=HomeDone AND bExecHome);

IF ftExec.Q OR rtTarget.Q OR rtHomed.Q THEN
    IF NOT stPiezoStage.bDone THEN
		MoveBusy:=FALSE;
		tonHoldTime.IN:=FALSE;
		stPiezoStage.bDone := MoveDone OR HomeDone;
		stPiezoStage.bHomed := HomeDone;
        IF NOT Error THEN
            bExecute:=FALSE;
            stPiezoStage.bExecute:=FALSE;
        END_IF
    END_IF
END_IF

IF bExecute AND NOT Error THEN
    // Reset local warnings if things are going well
    stPiezoStage.sErrorMessage:='';
END_IF

// Handle auto-disable timing
bPrepareDisable S= stPiezoStage.nEnableMode = E_StageEnableMode.DURING_MOTION AND ftExec.Q;
// Delay the disable until we reach standstill, else brake issues or other race conditions
IF bPrepareDisable AND eAxisState = MC_AXISSTATE_STANDSTILL THEN
    bPrepareDisable:=FALSE;
    stPiezoStage.bEnable:=FALSE;
END_IF

//---------- brakes code here ---------------

// Always reset, even if not rising edge, so command can be issued again
// but do so only after the move was done or was cancel due to error or an interlock condition
IF ftExec.Q AND (stPiezoStage.bMoveCmd OR stPiezoStage.bHomeCmd) THEN
    stPiezoStage.bMoveCmd:=FALSE;
    stPiezoStage.bHomeCmd:=FALSE;

END_IF

// Force everything off in case of error
IF stPiezoStage.bError THEN
    stPiezoStage.bBusy := FALSE;
    stPiezoStage.bDone := FALSE;
    stPiezoStage.bEnable := FALSE;
END_IF

stPiezoStage.bBusy:=HomingBusy OR MoveBusy;

// Log errors
// Set the error message if we have one

// Hook if other code wants to inject a non-NC error
IF stPiezoStage.sCustomErrorMessage <> '' THEN
	bLogReady := FALSE;
	stPiezoStage.sErrorMessage := stPiezoStage.sCustomErrorMessage;

ELSE
	stPiezoStage.sErrorMessage := F_MotionErrorCodeLookup(nErrorId := stPiezoStage.nErrorId);
END_IF

fbLogError( stMotionStage:=stPiezoStage, bEnable:=bLogReady);

]]></ST>
      </Implementation>
    </Method>
    <Method Name="Power" Id="{634342db-4980-4103-96da-256cbacd69e1}">
      <Declaration><![CDATA[METHOD Power : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[rtEnableDrive(CLK:=stPiezoStage.bAllEnable);
ftDisbaleDrive(CLK:=stPiezoStage.bAllEnable);
// Enabled the drive: the client code must wait for state transition.
IF rtEnableDrive.Q THEN
    // Voltage on, close loop operations
    stPiezoStage.nPiezoDriveControl:=16#0F;
    fOverride:=100.0;
END_IF

IF ftDisbaleDrive.Q THEN
	//  inhibit motion functions! keep amplifier enable
	stPiezoStage.nPiezoDriveControl:=16#07;
    fOverride:=0.0;
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReadDriveErrors" Id="{b0585027-4ae7-4117-8a3d-d9e1621fba78}">
      <Declaration><![CDATA[METHOD ReadDriveErrors : BOOL
VAR_INPUT

END_VAR

VAR

END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[AmsNetIdToString();

ftErrorSdoRead(CLK:=fbErrorSdoRead.bBusy);

fbErrorSdoRead( sNetId:= sAmsNetId, 
				nSlaveAddr:=stPiezoStage.nSlaveAddr, 
				nIndex:=nChanErrorCodeIndex, 
				nSubIndex :=nSubIndex, 
				pDstBuf:= ADR(nPiezoErrorCode), 
				cbBufLen:=SIZEOF(nPiezoErrorCode),
				bExecute:= Error );
				
IF ftErrorSdoRead.Q THEN
	IF 	fbErrorSdoRead.bError THEN
		Error:=fbErrorSdoRead.bError;
		ErrorCode:=fbErrorSdoRead.nErrId;
	ELSE
		// Update Motion Error code;
		ErrorCode := PiezoErrorCode;

		// Error is general error status from the output of each motion fucntion called
		stPiezoStage.bError := Error;
		stPiezoStage.nErrorId := ErrorCode;	
		bLogReady := TRUE;
	END_IF
	bReadDone := TRUE;
ELSE
	bReadDone := FALSE;
END_IF

ReadDriveErrors := bReadDone;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReadDriveParams" Id="{91ee2260-ec1c-4238-9b91-9438ac703127}">
      <Declaration><![CDATA[(*Read Piezo drive Motion parameters*)
METHOD ReadDriveParams : BOOL
VAR_INPUT

END_VAR

VAR
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[tonSlowParamReadTimer( IN:=bSlowParamReadTimer, PT:=tRefreshDelay );
// Get the Master Ams Net Into into correct format
AmsNetIdToString();
// Get the following Error
fbFollowWinSdoRead(	sNetId:= sAmsNetId, 
				nSlaveAddr:=stPiezoStage.nSlaveAddr, 
				nIndex:=nChanFollowErrorWinIndex, 
				nSubIndex:=0, 
				pDstBuf:= ADR(stPiezoStage.nfollowErrorWin), 
				cbBufLen:=SIZEOF(stPiezoStage.nfollowErrorWin),
				bExecute:=tonSlowParamReadTimer.Q
			  );
// Read the Upper software limit
fbSoftLimMaxSdoRead( sNetId:= sAmsNetId, 
				nSlaveAddr:=stPiezoStage.nSlaveAddr, 
				nIndex:=nChanSoftwareLimIndex, 
				nSubIndex:=1, 
				pDstBuf:= ADR(stPiezoStage.nSoftwareLimMax), 
				cbBufLen:=SIZEOF(stPiezoStage.nSoftwareLimMax),
				bExecute:=tonSlowParamReadTimer.Q
			  );
		  
// Read the Lower software limit		  
fbSoftLimMinSdoRead( sNetId:= sAmsNetId, 
				nSlaveAddr:=stPiezoStage.nSlaveAddr, 
				nIndex:=nChanSoftwareLimIndex, 
				nSubIndex:=2, 
				pDstBuf:= ADR(stPiezoStage.nSoftwareLimMin), 
				cbBufLen:=SIZEOF(stPiezoStage.nSoftwareLimMin),
				bExecute:=tonSlowParamReadTimer.Q
			  );

IF fbSoftLimMinSdoRead.bBusy AND fbSoftLimMaxSdoRead.bBusy AND fbFollowWinSdoRead.bBusy THEN
	bSlowParamReadTimer:=FALSE;
END_IF

IF NOT fbSoftLimMinSdoRead.bBusy AND NOT fbSoftLimMaxSdoRead.bBusy AND NOT fbFollowWinSdoRead.bBusy THEN
	IF NOT bSlowParamReadTimer THEN
		bSlowParamReadTimer:=TRUE;
	END_IF
	IF 	fbFollowWinSdoRead.bError THEN
		// this will be logged as a warning
		Error := FALSE;
		PiezoErrorCode := fbFollowWinSdoRead.nErrId;
		//fbMotionErrorLogger.AddMsg(PiezoErrorCode, '');
	ELSIF 	fbSoftLimMaxSdoRead.bError THEN
		// this will be logged as a warning
		Error := FALSE;
		PiezoErrorCode := fbSoftLimMaxSdoRead.nErrId;
		//fbMotionErrorLogger.AddMsg(PiezoErrorCode, '');
	ELSIF 	fbSoftLimMinSdoRead.bError THEN
		// this will be logged as a warning
		Error := FALSE;
		PiezoErrorCode := fbSoftLimMinSdoRead.nErrId;
		//fbMotionErrorLogger.AddMsg(PiezoErrorCode, '');
	END_IF
	stPiezoStage.bError := Error;
	stPiezoStage.nErrorId := PiezoErrorCode;
END_IF

stPiezoStage.stAxisParameters.sAxisName := stPiezoStage.sName;
stPiezoStage.stAxisParameters.AxisId := stPiezoStage.nMotionAxisID;
stPiezoStage.stAxisParameters.bCtrlEnablePosDiffControl   := BOOL_TO_WORD(stPiezoStage.nfollowErrorWin > 0);
stPiezoStage.stAxisParameters.bEncEnableSoftEndMaxControl := BOOL_TO_WORD(stPiezoStage.nSoftwareLimMax > stPiezoStage.nSoftwareLimMin);
stPiezoStage.stAxisParameters.bEncEnableSoftEndMinControl := BOOL_TO_WORD(stPiezoStage.nSoftwareLimMin < stPiezoStage.nSoftwareLimMax);
stPiezoStage.stAxisParameters.fAccelerationMax := stPiezoStage.fMaxAcceleration;
stPiezoStage.stAxisParameters.fCtrlPosDiffMax := stPiezoStage.nfollowErrorWin;
// this info is not provided by the drive we keep it 0
stPiezoStage.stAxisParameters.fCtrlPosDiffMaxTime := 0.0;
stPiezoStage.stAxisParameters.fDecelerationMax := stPiezoStage.fMaxAcceleration;
stPiezoStage.stAxisParameters.fEncSoftEndMax := LINT_TO_LREAL(stPiezoStage.nSoftwareLimMax);
stPiezoStage.stAxisParameters.fEncSoftEndMin := LINT_TO_LREAL(stPiezoStage.nSoftwareLimMin);
stPiezoStage.stAxisParameters.fVeloMaximum := stPiezoStage.fMaxVelocity;
stPiezoStage.stAxisParameters.fEncOffset := 0.0;
// this info is not provided by the driver we keep it 0
stPiezoStage.stAxisParameters.fEncScaleFactorInternal := 0.0;
stPiezoStage.bAxisParamsInit S= TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{ca77c887-2b90-4375-866f-a9f6ff5b335c}">
      <Declaration><![CDATA[METHOD Reset : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Try to clear any faults if they are present by setting bit 7 of the Control Word.
IF stPiezoStage.bReset THEN
    stPiezoStage.nPiezoDriveControl:=16#80;
    // Reset everything when bReset is flagged
    stPiezoStage.bEnable:=FALSE;
    stPiezoStage.bReset:=FALSE;
    stPiezoStage.bExecute:=FALSE;
	Error := FALSE;
	ErrorCode := 0;
	PiezoErrorCode := 0;
	stPiezoStage.bError := 0;
	stPiezoStage.nErrorId := 0;	
    stPiezoStage.sErrorMessage:='';
    stPiezoStage.sCustomErrorMessage:='';
    bExecute:=FALSE;
	bLogReady := FALSE;
	HomeDone := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetEnables" Id="{8bb4d6f6-cdad-41b7-afa8-a970de274d07}">
      <Declaration><![CDATA[METHOD SetEnables
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[stPiezoStage.bAllForwardEnable:=stPiezoStage.bLimitForwardEnable AND (stPiezoStage.bGantryForwardEnable OR NOT stPiezoStage.bGantryAxis) AND stPiezoStage.stEPSForwardEnable.bEPS_OK;
stPiezoStage.bAllBackwardEnable:=stPiezoStage.bLimitBackwardEnable AND (stPiezoStage.bGantryBackwardEnable OR NOT stPiezoStage.bGantryAxis) AND stPiezoStage.stEPSBackwardEnable.bEPS_OK;

stPiezoStage.bAllEnable:=stPiezoStage.bEnable AND stPiezoStage.bHardwareEnable AND stPiezoStage.stEPSPowerEnable.bEPS_OK;
stPiezoStage.bAllEnable R= NOT stPiezoStage.bUserEnable;]]></ST>
      </Implementation>
    </Method>
    <Method Name="StateMachine" Id="{d963b9d7-d9e1-4a33-bb79-0f8a7e20b1de}">
      <Declaration><![CDATA[METHOD StateMachine
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*switch on disable*)
IF NOT stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoDriveStatus.Fault
    AND  stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eDriveState :=E_DS402DriveState.SWITCH_ON_DISABLED;
END_IF

(*Ready to switch*)
IF  stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoDriveStatus.Fault
    AND stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN
	bFault := FALSE;
    eDriveState :=E_DS402DriveState.SWITCH_ON_READY;
END_IF

(*Switch on*)
IF  stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoDriveStatus.Fault
    AND stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eDriveState :=E_DS402DriveState.SWITCH_ON;
END_IF

(*Operation enbaled*)
IF    stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoDriveStatus.Fault
    AND stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eDriveState :=E_DS402DriveState.OPERATION_ENABLED;
END_IF

(*Fault*)
IF  NOT  stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND stPiezoStage.stPiezoDriveStatus.Fault
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN
	bFault := TRUE;
    eDriveState :=E_DS402DriveState.FAULT;
END_IF

(*Fault reaction active*)
IF    stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND stPiezoStage.stPiezoDriveStatus.Fault
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN
    eDriveState :=E_DS402DriveState.FAULT_ACTIVE;
END_IF

(*Quick Stop*)
IF    stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoDriveStatus.Fault
    AND stPiezoStage.stPiezoDriveStatus.VoltageEnabled
    AND NOT stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eDriveState :=E_DS402DriveState.QUICK_STOP_ACTIVE;
END_IF


rtFault(CLK:=bFault	);
rtMotionErrorEvent(CLK:=Error);

CASE eDriveState  OF

    E_DS402DriveState.SWITCH_ON_DISABLED:;

    E_DS402DriveState.SWITCH_ON_READY:;

    E_DS402DriveState.SWITCH_ON:;

    E_DS402DriveState.OPERATION_ENABLED:;
		IF NOT bOperational THEN
			bOperational := TRUE;
			McAxisState:=MC_AxisStates.MC_AXISSTATE_STANDSTILL;
		END_IF
    E_DS402DriveState.FAULT:;
        (* This is not a motion fault but rather a hardware, lost of enabled, wc or loss of calibration issue
			The condition will set bit 3 'fault' but not bit 13 'error' so waiting in the error state would won't  clear this condition *)
		IF rtFault.Q THEN
			Error := TRUE;
		END_IF
		// Catch the drive errors code
		ReadDriveErrors();
		McAxisState:=MC_AxisStates.MC_AXISSTATE_UNDEFINED;
		
    E_DS402DriveState.QUICK_STOP_ACTIVE:;


END_CASE

rtNotOperational(CLK:= eDriveState <> E_DS402DriveState.OPERATION_ENABLED);
IF rtNotOperational.Q THEN
	bOperational := FALSE;
	McAxisState:=MC_AxisStates.MC_AXISSTATE_DISABLED;
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Property Name="stPzStage" Id="{9f92815a-2a54-4642-bace-23982d7df851}">
      <Declaration><![CDATA[PROPERTY PUBLIC stPzStage : REFERENCE TO ST_PiezoStage]]></Declaration>
      <Set Name="Set" Id="{c8f7e1d0-f544-4543-a5ce-d8889c56fbb7}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[THIS^.stPiezoStage REF= stPzStage;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="SyncEpicsStatus" Id="{0ec1ab11-3e34-4193-8590-6aaa07110b4c}">
      <Declaration><![CDATA[METHOD SyncEpicsStatus
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Status struct for EPICS communication
stPiezoStage.stAxisStatus.bEnable:=stPiezoStage.bAllEnable;
stPiezoStage.stAxisStatus.bEnabled:=stPiezoStage.bEnableDone; // account for PowerEnable from power block
stPiezoStage.stAxisStatus.bError:=stPiezoStage.bError;
stPiezoStage.stAxisStatus.bHomeSensor:=stPiezoStage.bHome;
stPiezoStage.stAxisStatus.bLimitBwd:=stPiezoStage.bAllBackwardEnable;
stPiezoStage.stAxisStatus.bLimitFwd:=stPiezoStage.bAllForwardEnable;
stPiezoStage.stAxisStatus.bReset:=stPiezoStage.bReset;
stPiezoStage.stAxisStatus.fAcceleration:=stPiezoStage.fAcceleration;
stPiezoStage.stAxisStatus.fActDiff:=stPiezoStage.fPosDiff;
stPiezoStage.stAxisStatus.fActPosition:=THIS^.CalibratedActPos;
stPiezoStage.stAxisStatus.fActVelocity:=stPiezoStage.fVelocity;
stPiezoStage.stAxisStatus.fDeceleration:=stPiezoStage.fAcceleration;
stPiezoStage.stAxisStatus.fOverride:=THIS^.fOverride;
stPiezoStage.stAxisStatus.fPosition:=stPiezoStage.fPosition;
stPiezoStage.stAxisStatus.fVelocity:=stPiezoStage.fVelocity;
stPiezoStage.stAxisStatus.nCmdData:=stPiezoStage.nCmdData;  //Or nCmdDataLocal
stPiezoStage.stAxisStatus.nCommand:=stPiezoStage.nCommand;  //Or nCommandLocal
stPiezoStage.stAxisStatus.nErrorId:=stPiezoStage.nErrorId;
stPiezoStage.stAxisStatus.bBusy:=stPiezoStage.bBusy;
stPiezoStage.stAxisStatus.bHomed:=stPiezoStage.bHomed;
stPiezoStage.stAxisStatus.bExecute:=bExecute;
stPiezoStage.stAxisStatus.nCommand:=3; // If this is not 3, the IOC stops updating positions during homing]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>