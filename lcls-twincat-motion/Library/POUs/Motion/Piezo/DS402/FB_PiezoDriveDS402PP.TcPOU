    </Method>
    <Method Name="HandleMoveRequest" Id="{6f021476-362f-4001-9f7a-3364b0ed4a04}">
      <Declaration><![CDATA[METHOD HandleMoveRequest : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE eAxisState OF
	
MC_AxisStates.MC_AXISSTATE_UNDEFINED:; 
   
MC_AxisStates.MC_AXISSTATE_DISABLED:;
	 // Drive back to Operation Enabled state?
	IF SUPER^.bOperational THEN
		// wait for move requests
		eAxisState :=  MC_AxisStates.MC_AXISSTATE_STANDSTILL;	 
	END_IF
	
    THIS^.bMoveBusy := FALSE;
    THIS^.bMoveDone := FALSE;
	InTargetPosition := FALSE;
	
MC_AxisStates.MC_AXISSTATE_STANDSTILL: 
	IF SUPER^.bExecHome THEN
		eAxisState :=  MC_AxisStates.MC_AXISSTATE_HOMING; 
	END_IF
	  
	IF SUPER^.bExecMove THEN
		// we supporting only discrete motion for now
		SUPER^.stPiezoStage.nPiezoDriveControl.5 := FALSE;
		eAxisState :=  MC_AxisStates.MC_AXISSTATE_DISCRETEMOTION;
		// enter move discrete or continous here:
		eMotionState := E_MotionState.PREPARE_MOTION_PARAMS;
	END_IF

	// stopping
	IF SUPER^.stPiezoStage.nPiezoDriveControl.8 THEN
		eAxisState :=  MC_AxisStates.MC_AXISSTATE_STOPPING;
	END_IF

MC_AxisStates.MC_AXISSTATE_ERRORSTOP:;
	THIS^.Reset();
	// Error Cleared?
	IF NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
		eAxisState :=  MC_AxisStates.MC_AXISSTATE_UNDEFINED;
	END_IF 

    THIS^.bMoveBusy := FALSE;
    THIS^.bMoveDone := FALSE;
	THIS^.InTargetPosition := FALSE;
    SUPER^.stPiezoStage.bEnable := FALSE;
	//SUPER^.bExecute := FALSE;
MC_AxisStates.MC_AXISSTATE_STOPPING:; 
	eAxisState 	:= MC_AxisStates.MC_AXISSTATE_STANDSTILL;
	
MC_AxisStates.MC_AXISSTATE_HOMING:
	THIS^.Home();
	
MC_AxisStates.MC_AXISSTATE_DISCRETEMOTION:
	// bit 5: change set immediately set
	//SUPER^.stPiezoStage.nPiezoDriveControl.5 := 0;
	ContinuousMotion := FALSE;
	DiscreteMotion	:= TRUE;
	THIS^.DiscreteMove();
	
END_CASE

// error bit set ?
IF SUPER^.stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
	eAxisState :=  MC_AxisStates.MC_AXISSTATE_ERRORSTOP;
END_IF

// if the drive transition away from operational state then put the motion state mchine is disabled mode
IF NOT SUPER^.bOperational THEN
	eAxisState :=  MC_AxisStates.MC_AXISSTATE_DISABLED;
END_IF

// Check the limits and cancel execution if appropriate. Without this block we have infinite error spam
// it seems this limit are software limits.. need to be checked
IF THIS^.bMoveBusy THEN
	// Positive or Negative direction
	IF  fCalibratedStoppedPos > CalibratedActPos THEN
		THIS^.PositiveDirection := TRUE;
		THIS^.NegativeDirection := FALSE;
	ELSE
		THIS^.PositiveDirection := FALSE;
		THIS^.NegativeDirection := TRUE;	
	END_IF
ELSE
	// store idle Position
	fCalibratedStoppedPos := CalibratedActPos;
END_IF

bFwdHit := THIS^.PositiveDirection AND NOT SUPER^.stPiezoStage.bAllForwardEnable;
bBwdHit := THIS^.NegativeDirection AND NOT SUPER^.stPiezoStage.bAllBackwardEnable;

IF (bFwdHit OR bBwdHit) AND NOT bHomingBusy THEN
    SUPER^.stPiezoStage.bExecute := FALSE;
END_IF

// Check done moving via user stop, fbDriveVirtual and Target Position Monitoring, or from homing.
// set/reset SUPER^.stPiezoStage.bDone after move absolute/Relative
SUPER^.ftExec(CLK:=SUPER^.stPiezoStage.bExecute);
SUPER^.rtTarget(CLK:=(THIS^.InTargetPosition AND THIS^.bMoveDone AND SUPER^.bExecMove));
SUPER^.rtHomed(CLK:=SUPER^.HomeDone AND SUPER^.bExecHome);

// user can override execute from EPICS, since we using R_TRIG on bMoveCMD this possible
IF SUPER^.ftExec.Q OR SUPER^.rtTarget.Q OR SUPER^.rtHomed.Q THEN
    IF NOT SUPER^.stPiezoStage.bDone THEN
        SUPER^.stPiezoStage.bDone := TRUE;
        SUPER^.stPiezoStage.bBusy := FALSE;
        IF NOT SUPER^.stPiezoStage.bError THEN
            SUPER^.bExecute := FALSE;
            SUPER^.stPiezoStage.bExecute := FALSE;
        END_IF
    END_IF
ELSE
	//
	SUPER^.stPiezoStage.bBusy := SUPER^.HomingBusy OR THIS^.MoveBusy;
END_IF








IF SUPER^.bExecute AND NOT stPiezoStage.bError THEN
    // Reset local warnings if things are going well
    SUPER^.stPiezoStage.sErrorMessage := '';
END_IF


]]></ST>
      </Implementation>
    </Method>
