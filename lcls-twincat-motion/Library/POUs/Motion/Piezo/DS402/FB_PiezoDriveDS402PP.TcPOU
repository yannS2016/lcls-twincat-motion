    <Method Name="ReadyToMove" Id="{41029c05-8543-45cb-bee9-9ade575fa8aa}">
      <Declaration><![CDATA[METHOD ReadyToMove : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[SUPER^.ReadyToMove();

IF SUPER^.MoveReady THEN
	eInternalDriveCmdState :=  E_DS402_CMD_STATE.PREPARE_MOTION_PARAMS;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="StateMachine" Id="{6f021476-362f-4001-9f7a-3364b0ed4a04}">
      <Declaration><![CDATA[METHOD StateMachine : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
rtMoveCmd(CLK:=SUPER^.stPiezoStage.bMoveCmd);

CASE eInternalDriveCmdState OF
	E_DS402_CMD_STATE.PREPARE_MOTION_PARAMS:
		// Activate soft limit to avoid bumping hard on the end stops
		SUPER^.CalibrateMotionParams();
		SUPER^.stPiezoStage.nTargetPosition := SUPER^.CalibratedTargetPosition;
		SUPER^.stPiezoStage.nProfilVelocity := SUPER^.CalibratedVelocity;
		SUPER^.stPiezoStage.nProfilAcceleration := SUPER^.CalibratedAcceleration;
		SUPER^.stPiezoStage.nProfilDecceleration := SUPER^.CalibratedAcceleration;
		// bit_6 : absolute or relative move ? user supplied paramter
		CASE SUPER^.stPiezoStage.ePPMode OF
			// bit_11: Operation Mode : trapezoidal or s-curve: Using Trapezoidal for now
			// bit_5: Change set immediately : finish current move or interupt it to start the next move? 
			// bit_6 : absolute or relative move ? user supplied paramter
			E_DS402_PP_MODE.DISCRETE:;
				SUPER^.stPiezoStage.nPiezoStageControl.5 := FALSE;
			E_DS402_PP_MODE.CONTINUOUS:;
				SUPER^.stPiezoStage.nPiezoStageControl.5 := TRUE;
		END_CASE
		// this need to be handle in the power method and interlock to comfirm the move cmd
		// stPiezoStage.stAxisStatus.bExecute := stPiezoStage.bExecute;
		// stPiezoStage.stAxisStatus.nCommand := 10;
		SUPER^.stPiezoStage.nModeOfOperation := E_DS402_OPERATION_MODE.PROFILE_POSITION;
		eInternalDriveCmdState := E_DS402_CMD_STATE.INITIATE_MOTION;

	E_DS402_CMD_STATE.INITIATE_MOTION:;
		IF SUPER^.stPiezoStage.nModeOfOperationDisplay = E_DS402_OPERATION_MODE.PROFILE_POSITION THEN
			IF rtMoveCmd.Q THEN
				IF SUPER^.stPiezoStage.eMoveMode = E_MOVE_MODE.ABSOLUTE THEN
					// Absolute move
					THIS^.MoveAbsolute();
				ELSE
					// Relative move
					//THIS^.MoveRelative();
				END_IF
				eInternalDriveCmdState := E_DS402_CMD_STATE.DRIVE_IN_MOTION;
			END_IF
		END_IF

	E_DS402_CMD_STATE.DRIVE_IN_MOTION:;
			IF SUPER^.stPiezoStage.stPiezoStageStatus.Bit12_OpModeSpecific THEN
				// prepare for next setpoint
				SUPER^.stPiezoStage.nPiezoStageControl.4 := FALSE;
				eInternalDriveCmdState := E_DS402_CMD_STATE.TARGET_REACHED;	
			END_IF

	E_DS402_CMD_STATE.TARGET_REACHED:
		    IF SUPER^.stPiezoStage.stPiezoStageStatus.TargetReached 
			// Halt? 
			AND NOT stPiezoStage.nPiezoStageControl.8 THEN
				SUPER^.stPiezoStage.bError := FALSE;
				SUPER^.stPiezoStage.nErrorId := 0;
				eInternalDriveCmdState := E_DS402_CMD_STATE.DONE;
			END_IF
            // Prepare next move
            SUPER^.MoveReady := FALSE;
			
	E_DS402_CMD_STATE.ERROR:
			SUPER^.stPiezoStage.bError := TRUE;
			SUPER^.stPiezoStage.nErrorId := SUPER^.stPiezoStage.nPiezoErrorCode;
			// goto main state machine error state.
			DriveStateTransition := E_DS402_DRIVE_STATE.MODE_ERROR;
	E_DS402_CMD_STATE.DONE:;
END_CASE

// Track errors 
IF SUPER^.stPiezoStage.nPiezoErrorCode <> 0 THEN
	eInternalDriveCmdState := E_DS402_CMD_STATE.ERROR;
END_IF



]]></ST>
      </Implementation>
    </Method>
