  <POU Name="FB_PiezoDriveDS402PP" Id="{6e47a4a9-16e3-49c8-8786-19fbbc700413}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_PiezoDriveDS402PP EXTENDS FB_PiezoDriveDS402
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    eMotionState		:  E_DS402MotionState;
    DiscreteMotion 		:  BOOL;
    ContinuousMotion 	:  BOOL;
    // for test
	bReady  : BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[THIS^.Interlock();
THIS^.Power();
THIS^.Halt();
THIS^.Reset();
THIS^.StateMachine();





]]></ST>
    </Implementation>
    <Method Name="Brake" Id="{22a77937-1757-472e-8a24-02f41806a6fb}">
