    <Method Name="DS402StateMachine" Id="{adad349e-6f22-41f6-bf4b-2c2ba773c644}">
      <Declaration><![CDATA[METHOD DS402StateMachine
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[SUPER^.DS402StateMachine();

CASE DriveStateTransition OF

    E_DS402_DRIVE_STATE.SWITCH_ON_DISABLED:;
		// 16#06 : shutdown - > ready to switch on
		SUPER^.stPiezoStage.nPiezoStageControl := 16#06;
	
    E_DS402_DRIVE_STATE.SWITCH_ON_READY:;
		// 16#07
		SUPER^.stPiezoStage.nPiezoStageControl := 16#07;

    E_DS402_DRIVE_STATE.SWITCH_ON:
		// 16#0F
		SUPER^.stPiezoStage.nPiezoStageControl := 16#0F;
		
    E_DS402_DRIVE_STATE.QUICK_STOP_ACTIVE:;

    E_DS402_DRIVE_STATE.OPERATION_ENABLED:;
    // Homing -- common
    IF SUPER^.stPiezoStage.bHomeCmd THEN
        THIS^.Home();
        IF SUPER^.Error THEN
            DriveStateTransition := E_DS402_DRIVE_STATE.FAULT;
        END_IF
	ELSE
		// we want a rising edge here.
		THIS^.StateMachine();
    END_IF

    E_DS402_DRIVE_STATE.FAULT:;
		// this bit needs a rising edge
		SUPER^.Reset();

END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{ea3b8a11-1b80-40a7-b145-7a2a5e25ca70}">
      <Declaration><![CDATA[(*FB_Init is always available implicitly and it is used primarily for initialization.
The return value is not evaluated. For a specific influence, you can also declare the
methods explicitly and provide additional code there with the standard initialization
code. You can evaluate the return value.*)
METHOD FB_Init : BOOL
VAR_INPUT
    (* TRUE: the retain variables are initialized (reset warm / reset cold)*)
    bInitRetains	: BOOL;
    (* TRUE: the instance will be copied to the copy code afterward (online change)   *)
    bInCopyCode	: BOOL;
    stStage : REFERENCE TO ST_PiezoStage;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
