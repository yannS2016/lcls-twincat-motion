    <Method Name="PostMoveInterlocks" Id="{fdfad17f-f4c5-4acf-ad7c-c467a5ef1afc}">
      <Declaration><![CDATA[METHOD PostMoveInterlocks
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Check the limits and cancel execution if appropriate. Without this block we have infinite error spam
// it seems this limit are software limits.. need to be checked
IF THIS^.MoveBusy THEN
    // Positive or Negative direction
    IF  fCalibratedStandStillPos > CalibratedActPos THEN
        THIS^.PositiveDirection:=TRUE;
        THIS^.NegativeDirection:=FALSE;
    ELSE
        THIS^.PositiveDirection:=FALSE;
        THIS^.NegativeDirection:=TRUE;
    END_IF
ELSE
    // store idle Position
    fCalibratedStandStillPos:=CalibratedActPos;
END_IF

bFwdHit:=THIS^.PositiveDirection AND NOT SUPER^.stPiezoStage.bAllForwardEnable;
bBwdHit:=THIS^.NegativeDirection AND NOT SUPER^.stPiezoStage.bAllBackwardEnable;

IF (bFwdHit OR bBwdHit) AND NOT bHomingBusy THEN
    SUPER^.stPiezoStage.bExecute:=FALSE;
END_IF

// Check done moving via user stop, fbDriveVirtual and Target Position Monitoring, or from homing.
// set/reset SUPER^.stPiezoStage.bDone after move absolute/Relative
SUPER^.ftExec(CLK:=SUPER^.stPiezoStage.bExecute);
SUPER^.rtTarget(CLK:=(THIS^.InTargetPosition AND THIS^.MoveDone AND SUPER^.bExecMove));
SUPER^.rtHomed(CLK:=SUPER^.HomeDone AND SUPER^.bExecHome);

// user can override execute from EPICS, since we using R_TRIG on bMoveCMD this possible
IF SUPER^.ftExec.Q OR SUPER^.rtTarget.Q OR SUPER^.rtHomed.Q THEN
    IF NOT SUPER^.stPiezoStage.bDone THEN
        SUPER^.stPiezoStage.bDone:=TRUE;
        SUPER^.stPiezoStage.bBusy:=FALSE;
        IF NOT SUPER^.Error THEN
            SUPER^.bExecute:=FALSE;
            SUPER^.stPiezoStage.bExecute:=FALSE;
        END_IF
    END_IF
END_IF


IF SUPER^.bExecute AND NOT stPiezoStage.bError THEN
    // Reset local warnings if things are going well
    SUPER^.stPiezoStage.sErrorMessage:='';
END_IF
]]></ST>
      </Implementation>
    </Method>
