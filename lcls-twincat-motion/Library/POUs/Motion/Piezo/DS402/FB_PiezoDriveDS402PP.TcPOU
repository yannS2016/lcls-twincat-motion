    <Method Name="MoveAbsolute" Id="{1452777d-f00c-4295-b378-678683e81128}">
      <Declaration><![CDATA[METHOD MoveAbsolute

VAR

END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Intiate the move
SUPER^.stPiezoStage.nPiezoDriveControl.6 := FALSE;
SUPER^.stPiezoStage.nPiezoDriveControl.4 := TRUE;]]></ST>
      </Implementation>
    </Method>
