    <Method Name="DiscreteMove" Id="{0bdd1a5e-3305-4fed-8d61-3502d5d595e0}">
      <Declaration><![CDATA[METHOD  DiscreteMove
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE eMotionState OF
    E_DS402MotionState.PREPARE_MOTION_PARAMS:
        // Activate soft limit to avoid bumping hard on the end stops
        THIS^.CalibratedMotionParams();
		SUPER^.stPiezoStage.nTargetPosition:=THIS^.CalibratedTargetPosition;
        SUPER^.stPiezoStage.nProfilVelocity:=THIS^.CalibratedVelocity;
        SUPER^.stPiezoStage.nProfilAcceleration:=THIS^.CalibratedAcceleration;
        SUPER^.stPiezoStage.nProfilDecceleration:=THIS^.CalibratedAcceleration;
        SUPER^.bMoveDone:=FALSE;
        SUPER^.MoveBusy:=FALSE;
        SUPER^.InTargetPosition:=FALSE;
		THIS^.ContinuousMotion:=FALSE;
		THIS^.DiscreteMotion:=TRUE;
		// bit 5: change set immediately set
    	SUPER^.stPiezoStage.nPiezoDriveControl.5:=0;
        SUPER^.stPiezoStage.nModeOfOperation:=E_DS402OperationMode.PROFILE_POSITION;
        eMotionState:=E_DS402MotionState.INITIATE_MOTION;

    E_DS402MotionState.INITIATE_MOTION:;
        IF SUPER^.stPiezoStage.nModeOfOperationDisplay = E_DS402OperationMode.PROFILE_POSITION THEN

            // No running Job : only true for discrete motion
            IF NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Bit12_OpModeSpecific THEN
                // drive dependent, it seems PI drive only support absolute motion.
                IF SUPER^.stPiezoStage.eMoveMode = E_EpicsMotorCmd.MOVE_ABSOLUTE THEN
                    // Absolute move
					SUPER^.stPiezoStage.nCommand:=3;
                    THIS^.MoveAbsolute();
                ELSE
                    // Relative move: Not implemented
					SUPER^.stPiezoStage.nCommand:=2;
                    THIS^.MoveRelative();
                END_IF
            ELSE
                //Now: we have the set point acknowledgement from the drive
                eMotionState:=E_DS402MotionState.DRIVE_IN_MOTION;
            END_IF
        ELSE
            // Exit this state machine gracefully.
            eMotionState:=E_DS402MotionState.DONE;
        END_IF

    E_DS402MotionState.DRIVE_IN_MOTION:;
        IF SUPER^.stPiezoStage.stPiezoDriveStatus.Bit12_OpModeSpecific THEN
			SUPER^.MoveBusy:=TRUE;
			eMotionState:=E_DS402MotionState.TARGET_REACHED;

        END_IF

    E_DS402MotionState.TARGET_REACHED:
        IF SUPER^.stPiezoStage.stPiezoDriveStatus.TargetReached 
           AND SUPER^.stPiezoStage.stPiezoDriveStatus.Bit12_OpModeSpecific THEN
            // Halted?
            IF NOT stPiezoStage.nPiezoDriveControl.8 THEN
                THIS^.InTargetPosition:=TRUE;
            ELSE
                THIS^.InTargetPosition:=FALSE;
            END_IF
            // exit this state machine gracefully
            eMotionState:=E_DS402MotionState.DONE;
        END_IF

    E_DS402MotionState.DONE:;
        SUPER^.bMoveDone:=TRUE;
        SUPER^.MoveBusy:=FALSE;
		// the axis will reset bit 12 after a fallign edge on this bit to signal readiness for new set point
		SUPER^.stPiezoStage.nPiezoDriveControl.4:=FALSE;
        eAxisState:= MC_AxisStates.MC_AXISSTATE_STANDSTILL;
END_CASE



]]></ST>
      </Implementation>
    </Method>
