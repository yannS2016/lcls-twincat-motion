    <Method Name="MoveAbsolute" Id="{1452777d-f00c-4295-b378-678683e81128}">
      <Declaration><![CDATA[METHOD MoveAbsolute

VAR

END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[	IF NOT SUPER^.stPiezoStage.bHalt THEN
		// Intiate the move
		SUPER^.stPiezoStage.nPiezoStageControl.4 := TRUE;
	END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="MoveRelative" Id="{056a11cf-0783-4411-964f-fac399b96655}">
      <Declaration><![CDATA[METHOD MoveRelative
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[	SUPER^.stPiezoStage.stPiezoStageControl.Bit11_OpModeSpecific  := TRUE;
	SUPER^.stPiezoStage.stPiezoStageControl.Bit6_OpModeSpecific := TRUE;
	
	IF NOT SUPER^.stPiezoStage.bHalt THEN
		// Intiate the move
		SUPER^.stPiezoStage.stPiezoStageControl.Bit4_OpModeSpecific := TRUE;
	END_IF]]></ST>
      </Implementation>
    </Method>
