    <Method Name="PostInit" Id="{d833fbe7-e9ac-4353-bb5f-2247f06bb205}">
      <Declaration><![CDATA[{attribute 'call_after_init'}
METHOD PostInit
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE stPiezoStage.eModule OF
	E_Module.CHAN1:
		nChanFErrWinIdx 	:= nFErrWinBase;
		nChanSoftwareLimIdx	:= nSoftLimBase;
		nChanMotorLoadIdx	:= nMotorLoadbase;
		nChanErrorCodeIdx	:= nErrorCodeBase;
    	nChanOlStepIdx		:= 	nOlStepBase;
    	nChanOlStepFreqIdx	:= 	nOlStepFreqBase;
    	nChanOlStepAmpIdx	:= 	nOlStepAmpBase;
		
	E_Module.CHAN2:
		nChanFErrWinIdx 	:= nFErrWinBase + nChanOfsBase;
		nChanSoftwareLimIdx	:= nSoftLimBase + nChanOfsBase;
		nChanMotorLoadIdx	:= nMotorLoadbase + nChanOfsBase;
		nChanErrorCodeIdx	:= nErrorCodeBase + nChanOfsBase;
		nChanOlStepIdx		:= 	nOlStepBase + nChanOfsBase;
		nChanOlStepFreqIdx	:= 	nOlStepFreqBase + nChanOfsBase;
		nChanOlStepAmpIdx	:= 	nOlStepAmpBase + nChanOfsBase;
		
	E_Module.CHAN3:
		nChanFErrWinIdx		:= nFErrWinBase + (2 * nChanOfsBase);
		nChanSoftwareLimIdx	:= nSoftLimBase + (2 * nChanOfsBase);;
		nChanMotorLoadIdx	:= nMotorLoadbase + (2 * nChanOfsBase);
		nChanErrorCodeIdx	:= nErrorCodeBase + (2 * nChanOfsBase);
		nChanOlStepIdx		:= 	nOlStepBase + (2 * nChanOfsBase);
		nChanOlStepFreqIdx	:= 	nOlStepFreqBase + (2 * nChanOfsBase);
		nChanOlStepAmpIdx	:= 	nOlStepAmpBase + (2 * nChanOfsBase);
END_CASE

]]></ST>
      </Implementation>
    </Method>
