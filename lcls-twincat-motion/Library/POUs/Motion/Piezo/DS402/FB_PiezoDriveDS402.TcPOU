          <ST><![CDATA[CalibratedVelocity := nCalibratedVelocity;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="DS402StateMachine" Id="{d963b9d7-d9e1-4a33-bb79-0f8a7e20b1de}">
      <Declaration><![CDATA[METHOD DS402StateMachine
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Drive State Events and Operations
IF NOT __ISVALIDREF(SUPER^.stPiezoStage) THEN
    // we will return gracefully in the FAULT state
    ErrorMessage := 'FAULT: Drive interface not initialized';
    RETURN;
END_IF

(*switch on disable*)
IF NOT SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND  SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eInternalDriveState  := E_DS402DriveState.SWITCH_ON_DISABLED;
END_IF

(*Ready to switch*)
IF  SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eInternalDriveState  := E_DS402DriveState.SWITCH_ON_READY;
END_IF

(*Switch on*)
IF  SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eInternalDriveState  := E_DS402DriveState.SWITCH_ON;
END_IF

(*Operation enbaled*)
IF    SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eInternalDriveState  := E_DS402DriveState.OPERATION_ENABLED;
END_IF

(*Fault*)
IF  NOT  SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eInternalDriveState  := E_DS402DriveState.FAULT;
END_IF

(*Fault reaction active*)
IF    SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eInternalDriveState  := E_DS402DriveState.FAULT_ACTIVE;
END_IF

(*Quick Stop*)
IF    SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.VoltageEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eInternalDriveState  := E_DS402DriveState.QUICK_STOP_ACTIVE;
END_IF

CASE eInternalDriveState  OF

    E_DS402DriveState.SWITCH_ON_DISABLED:;
        // catch fault recovery here if needed

    E_DS402DriveState.SWITCH_ON_READY:;

    E_DS402DriveState.SWITCH_ON:;

    E_DS402DriveState.OPERATION_ENABLED:;
        bOperational := TRUE;

    E_DS402DriveState.FAULT:;
        // Theis is not a motion fault but rather hardware, lost of enabled wc or loss of calibration issue.
        // the same method we use to clear motion error too has the DS402 profil does not provide...
        THIS^.Reset();

    E_DS402DriveState.QUICK_STOP_ACTIVE:
        // return back to operation enabled: transition 16
        SUPER^.stPiezoStage.nPiezoDriveControl := 16#0F;

END_CASE

// Homing and absolute/relative moves only valid in this state
IF eInternalDriveState  <>  E_DS402DriveState.OPERATION_ENABLED THEN
        bOperational := FALSE;
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{8fccdb5f-b457-4637-ae44-ff5efe2142a7}">
      <Declaration><![CDATA[(*FB_Init is always available implicitly and it is used primarily for initialization.
The return value is not evaluated. For a specific influence, you can also declare the
methods explicitly and provide additional code there with the standard initialization
code. You can evaluate the return value.*)
METHOD FB_Init : BOOL
VAR_INPUT
    (* TRUE: the retain variables are initialized (reset warm / reset cold)*)
    bInitRetains	: BOOL;
    (* TRUE: the instance will be copied to the copy code afterward (online change)   *)
    bInCopyCode	: BOOL;
    stStage : REFERENCE TO  ST_PiezoStage;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//DS402Axis.stPiezoStageRef := stStage;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Halt" Id="{7f626c89-4c25-446a-aadf-2d7158be6cb2}">
      <Declaration><![CDATA[METHOD Halt : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Halt the move by setting bit 8 of the Control Word.
SUPER^.stPiezoStage.nPiezoDriveControl.8 := SUPER^.stPiezoStage.bHalt;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Home" Id="{d33ee575-f547-404d-bc45-25b73c38be5a}">
      <Declaration><![CDATA[METHOD Home : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[SUPER^.Home();]]></ST>
      </Implementation>
    </Method>
    <Method Name="Interlock" Id="{36207be0-7a17-466d-9c72-e0f495170f07}">
      <Declaration><![CDATA[METHOD Interlock : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[stPiezoStage.bLimitForwardEnable := (NOT SUPER^.stPiezoStage.stPiezoDriveStatus.InternalLimitActive);
stPiezoStage.bLimitBackwardEnable := (NOT SUPER^.stPiezoStage.stPiezoDriveStatus.InternalLimitActive);
// call common interlocks checker
SUPER^.Interlock();

// Handle auto-disable timing
bPrepareDisable S= stPiezoStage.nEnableMode = E_StageEnableMode.DURING_MOTION AND ftExec.Q;
// Delay the disable until we reach standstill, else brake issues or other race conditions
IF bPrepareDisable AND THIS^.eAxisState = MC_AXISSTATE_STANDSTILL THEN
    bPrepareDisable := FALSE;
    stPiezoStage.bEnable := FALSE;
END_IF

// Get a definitive bEnabled reading
CASE THIS^.eAxisState OF
    // We are not enabled if there is an issue
    MC_AXISSTATE_UNDEFINED, MC_AXISSTATE_DISABLED, MC_AXISSTATE_ERRORSTOP:
        SUPER^.stPiezoStage.bEnableDone := FALSE;
    ELSE
        SUPER^.stPiezoStage.bEnableDone := TRUE;
END_CASE

// IF doing profil positioning we should be able to do continous motion
// add an override here to account for it
IF stPiezoStage.stAxisStatus.bBusy AND NOT bExecute THEN
    // Wait for the previous move to end
    bExecute := FALSE;

ELSIF bMoveCmd THEN
    // Do not start the move until we have power and the safety system says it is OK
    bExecute := stPiezoStage.bExecute AND stPiezoStage.bAllEnable AND stPiezoStage.bEnableDone AND stPiezoStage.bSafetyReady;
ELSE
    bExecute := stPiezoStage.bExecute;
END_IF

// When we start, set the busy/done appropriately
rtExec(CLK:=bExecute);
IF rtExec.Q THEN
    SUPER^.stPiezoStage.bDone := FALSE;
END_IF

// definitive move cmds
bExecHome := bExecute AND stPiezoStage.nCommand = 10;
bExecMove := bExecute AND NOT bExecHome;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Logger" Id="{c74ad8cb-1745-4df8-b83c-c7761caffd8e}">
