<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_PiezoDriveDS402" Id="{767dade8-900b-419e-8640-c738938dffde}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK PUBLIC ABSTRACT FB_PiezoDriveDS402 EXTENDS FB_PiezoDrive
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    eInternalDriveState 		: 	E_DS402_DRIVE_STATE;
    eInternalDriveCmdState		: 	E_DS402_CMD_STATE;
    bProfilPostion				:	BOOL;
    bCyclicSynchronousPostion	: 	BOOL;
    bMoveConfirmed				: 	BOOL;
	bHalted						:	BOOL;
	// subindex for SDO parameters update: should we just add these to the PDO list?
    nHomingSpeedSubIndex		: 	WORD := 16#6099;
    nHomingAccSubIndex			: 	WORD := 16#609A;
    nHomingOffsetSubIndex		: 	WORD := 16#607C;
	
	// Calibrated motion params : nanometer operation by default.
	// user parameter are entered in mm
	fdefaultScalingFactor		: REAL := 0.000001; //nm
	
	fCalibratedMaxVelocity 		: DINT;
	fCalibratedMaxAcceleration 	: DINT;
	fCalibratedVelocity 		: DINT;
	fCalibratedAcceleration 	: DINT;
	fCalibratedTargetPosition 	: DINT;
	fIntermediate 				: REAL;
	rtReset						: R_TRIG;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
