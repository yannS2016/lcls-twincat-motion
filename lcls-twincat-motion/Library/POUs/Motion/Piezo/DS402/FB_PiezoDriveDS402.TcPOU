    <Method Name="ConfigureDriveParams" Id="{a28d7e11-f485-4a60-bdef-9b0d673cfb42}">
      <Declaration><![CDATA[METHOD ConfigureDriveParams : BOOL
VAR_INPUT
    bExecute	:	BOOL:=FALSE;
    nIndex     	: 	WORD ; 		   (* CoE Object Index *)
    nSubIndex  	: 	BYTE ; 			   (* Subindex of CoE Object *)
    nValue		: 	DINT;
    fbSdoWrite	: 	FB_EcCoESdoWrite;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT fbSdoWrite.bBusy THEN
    bExecute:=FALSE;
    IF NOT fbSdoWrite.bError THEN
        (* write successful *)
        Error:=FALSE;
        ErrorCode:=0;
    ELSE
        (* write failed *)
        Error:=fbSdoWrite.bError;
        ErrorCode:=fbSdoWrite.nErrId;

    END_IF

    fbSdoWrite(bExecute:=FALSE);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="EncSaveRestore" Id="{62326dfa-915c-4ff5-a6ba-aedff0abd839}">
      <Declaration><![CDATA[METHOD PUBLIC ABSTRACT EncSaveRestore
VAR_INPUT
	bEnable	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="EncValue" Id="{f460e6f3-54f0-4341-b7f0-33fb3e421551}">
      <Declaration><![CDATA[METHOD EncValue
VAR_INPUT
  //  bEnable: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* SmartACT: The encoder count from the Piezo drive is not a raw count from the embeded actuator device
   we get a calibrated nm value. thus the use of abs() since this value is signed. 
   PI: to be discovered *)
IF stPiezoStage.nRawEncoderDINT <> 0 THEN
    stPiezoStage.nEncoderCount:=DINT_TO_UDINT(ABS(stPiezoStage.nRawEncoderDINT));
ELSE
    stPiezoStage.nEncoderCount:=0;
END_IF

// calibrated encoder readback
fCalibratedActPos:=UDINT_TO_REAL(stPiezoStage.nEncoderCount) *  MAX(stPiezoStage.fscalingFactor, fDefaultScalingFactor);
stPiezoStage.fPosDiff:=stPiezoStage.fPosition - fCalibratedActPos;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{8fccdb5f-b457-4637-ae44-ff5efe2142a7}">
      <Declaration><![CDATA[(*FB_Init is always available implicitly and it is used primarily for initialization.
The return value is not evaluated. For a specific influence, you can also declare the
methods explicitly and provide additional code there with the standard initialization
code. You can evaluate the return value.*)
METHOD FB_Init : BOOL
VAR_INPUT
    (* TRUE: the retain variables are initialized (reset warm / reset cold)*)
    bInitRetains	: BOOL;
    (* TRUE: the instance will be copied to the copy code afterward (online change)   *)
    bInCopyCode	: BOOL;
    stStage : REFERENCE TO  ST_PiezoStage;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Drive State Events and Operations
IF NOT __ISVALIDREF(SUPER^.stPiezoStage) THEN
    // we will return gracefully in the FAULT state
    ErrorMessage:='FAULT: Drive interface not initialized';
    RETURN;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetAmsNetId" Id="{599152ff-bf5a-4de5-82dd-edaef94bc45d}">
      <Declaration><![CDATA[METHOD GetAmsNetId : BOOL
VAR_INPUT
	isNotSet : BOOL;
END_VAR

VAR
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ftAmsNetId(CLK:=fbGetAmsNetId.bBusy);

fbGetAmsNetId(bExecute := isNotSet, tTimeOut := T#2S);

IF ftAmsNetId.Q  THEN
	IF NOT fbGetAmsNetId.bError THEN
		sAmsNetId := fbGetAmsNetId.AddrString;
	ELSE
		SUPER^.Error := fbGetAmsNetId.bError;
		SUPER^.ErrorCode := fbGetAmsNetId.nErrId;
	END_IF
	fbGetAmsNetId.bExecute := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Halt" Id="{7f626c89-4c25-446a-aadf-2d7158be6cb2}">
      <Declaration><![CDATA[METHOD Halt : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* Stop condition: User stopped and either Absolute/Relative move or Homing busy? 
  Halt the move by setting bit 8 of the Control Word *)
//SUPER^.stPiezoStage.nPiezoDriveControl.8 := NOT THIS^.bExecute AND ((THIS^.MoveBusy  AND (SUPER^.stPiezoStage.nCommand=2 OR SUPER^.stPiezoStage.nCommand=3)) OR (SUPER^.HomingBusy AND SUPER^.stPiezoStage.nCommand=10));]]></ST>
      </Implementation>
    </Method>
    <Method Name="Home" Id="{d33ee575-f547-404d-bc45-25b73c38be5a}">
