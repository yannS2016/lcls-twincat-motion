<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_PiezoDriveDS402" Id="{767dade8-900b-419e-8640-c738938dffde}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK PUBLIC ABSTRACT FB_PiezoDriveDS402 EXTENDS FB_PiezoDrive
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    eInternalDriveState		: 	E_DS402DriveState;
    // reuse to absolute/relative moves
    eAxisState 				:  MC_AxisStates;
    rtReset					: R_TRIG;
    rtEnableDrive			: R_TRIG;
    rtDisbaleDrive			: F_TRIG;
    // Drive calibrated motion params
    nCalibratedVelocity			: DINT;
    nCalibratedAcceleration		: DINT;
    nCalibratedTargetPosition 	: DINT;

    fCalibratedActPos			: REAL;
    fCalibratedStoppedPos		: REAL;
    fOverride					: REAL;

    // axis status -- emulating some NC axis
    bPowerEnabled		:  BOOL;
      bOperational 		:  BOOL;
    PositiveDirection 	:  BOOL;
    NegativeDirection 	:  BOOL;
    NotMoving 			:  BOOL;
    NewTargetPosition 	:  BOOL;
    InPositionArea 		:  BOOL;
    InTargetPosition 	:  BOOL;
    StandStill 			:  BOOL;
    DiscreteMotion 		:  BOOL;
    ContinuousMotion 	:  BOOL;
    SynchronizedMotion 	:  BOOL;
     ErrorStop 			:  BOOL;
     Disabled 			:  BOOL;
     Stopping 			:  BOOL;
    bHasJob 			:  BOOL;
    bMoveDone			:  BOOL;
    bMoveBusy			: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
]]></ST>
    </Implementation>
