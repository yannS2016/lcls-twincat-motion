<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_PiezoDriveDS402" Id="{767dade8-900b-419e-8640-c738938dffde}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK PUBLIC ABSTRACT FB_PiezoDriveDS402 EXTENDS FB_PiezoDrive
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    eInternalDriveState 		: 	E_DriveStates;
    bProfilPostion				:	BOOL;
    bCyclicSynchronousPostion	: 	BOOL;
    bMoveConfirmed				: 	BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Property Name="AbsMoveEnabled" Id="{a9e7c5e3-f201-4794-87c4-3a4b3de6d4de}">
      <Declaration><![CDATA[PROPERTY AbsMoveEnabled : BOOL]]></Declaration>
      <Get Name="Get" Id="{996e612a-6e5b-45c3-8a4f-8b38d6125f34}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[AbsMoveEnabled := bMoveConfirmed;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{42ad921f-9ab5-4504-a2c5-c5f8fa88f968}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[bMoveConfirmed := AbsMoveEnabled;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="Brake" Id="{e5829bdb-4f85-41d9-84ca-59543bab5ffb}">
      <Declaration><![CDATA[METHOD Brake : BOOL
]]></Declaration>
      <Implementation>
