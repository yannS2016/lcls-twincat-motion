    <Method Name="CompleteInit" Id="{df8f5b8e-85a8-4747-b91c-da75fa4ea9a9}">
      <Declaration><![CDATA[{attribute 'call_after_init'}
METHOD CompleteInit
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE SUPER^.stPiezoStage.eModule OF
	E_Module.CHAN1:
		  nChanFollowErrorWinIndex 	:= nFollowErrorWinIdex;
		  nChanSoftwareLimIndex 	:= nSoftLimIndex;
		  nChanMotorLoadIndex		:= nMotorLoadIndex;
		  nChanErrorCodeIndex		:= nErrorCodeIndex;
		
	E_Module.CHAN2:
		  nChanFollowErrorWinIndex 	:= nFollowErrorWinIdex + nModuleOffsetIndex;
		  nChanSoftwareLimIndex 	:= nSoftLimIndex + nModuleOffsetIndex;
		  nChanMotorLoadIndex		:= nMotorLoadIndex + nModuleOffsetIndex;
		  nChanErrorCodeIndex		:= nErrorCodeIndex + nModuleOffsetIndex;
		  
	E_Module.CHAN3:
		  nChanFollowErrorWinIndex 	:= nFollowErrorWinIdex + (2 * nModuleOffsetIndex);
		  nChanSoftwareLimIndex 	:= nSoftLimIndex + (2 * nModuleOffsetIndex);;
		  nChanMotorLoadIndex		:= nMotorLoadIndex + (2 * nModuleOffsetIndex);
		  nChanErrorCodeIndex		:= nErrorCodeIndex + (2 * nModuleOffsetIndex);
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="ConfigureDriveParams" Id="{a28d7e11-f485-4a60-bdef-9b0d673cfb42}">
      <Declaration><![CDATA[METHOD ConfigureDriveParams : BOOL
VAR_INPUT
    bExecute	:	BOOL:=FALSE;
    nIndex     	: 	WORD ; 		   (* CoE Object Index *)
    nSubIndex  	: 	BYTE ; 			   (* Subindex of CoE Object *)
    nValue		: 	DINT;
    fbSdoWrite	: 	FB_EcCoESdoWrite;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT fbSdoWrite.bBusy THEN
    bExecute:=FALSE;
    IF NOT fbSdoWrite.bError THEN
        (* write successful *)
        Error:=FALSE;
        ErrorCode:=0;
    ELSE
        (* write failed *)
        Error:=fbSdoWrite.bError;
        ErrorCode:=fbSdoWrite.nErrId;

    END_IF

    fbSdoWrite(bExecute:=FALSE);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="EncSaveRestore" Id="{62326dfa-915c-4ff5-a6ba-aedff0abd839}">
      <Declaration><![CDATA[METHOD PUBLIC ABSTRACT EncSaveRestore
VAR_INPUT
	bEnable	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="EncValue" Id="{f460e6f3-54f0-4341-b7f0-33fb3e421551}">
      <Declaration><![CDATA[METHOD EncValue
VAR_INPUT
  //  bEnable: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* SmartACT: The encoder count from the Piezo drive is not a raw count from the embeded actuator device
   we get a calibrated nm value. thus the use of abs() since this value is signed. 
   PI: to be discovered *)
IF stPiezoStage.nRawEncoderDINT <> 0 THEN
    stPiezoStage.nEncoderCount:=DINT_TO_UDINT(ABS(stPiezoStage.nRawEncoderDINT));
ELSE
    stPiezoStage.nEncoderCount:=0;
END_IF

// calibrated encoder readback
fCalibratedActPos:=DINT_TO_REAL(stPiezoStage.nRawEncoderDINT) *  MAX(stPiezoStage.fscalingFactor, fDefaultScalingFactor);
stPiezoStage.fPosDiff:=ABS(stPiezoStage.fPosition) - ABS(fCalibratedActPos);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetAmsNetId" Id="{599152ff-bf5a-4de5-82dd-edaef94bc45d}">
      <Declaration><![CDATA[METHOD GetAmsNetId : BOOL
VAR_INPUT
	isNotSet : BOOL;
END_VAR

VAR
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ftAmsNetId(CLK:=fbGetAmsNetId.bBusy);

fbGetAmsNetId(bExecute := isNotSet, tTimeOut := T#2S);

IF ftAmsNetId.Q  THEN
	IF NOT fbGetAmsNetId.bError THEN
		sAmsNetId := fbGetAmsNetId.AddrString;
	ELSE
		SUPER^.Error := fbGetAmsNetId.bError;
		SUPER^.ErrorCode := fbGetAmsNetId.nErrId;
	END_IF
	fbGetAmsNetId.bExecute := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Halt" Id="{7f626c89-4c25-446a-aadf-2d7158be6cb2}">
      <Declaration><![CDATA[METHOD Halt : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* Stop condition: User stopped and either Absolute/Relative move or Homing busy? 
  Halt the move by setting bit 8 of the Control Word *)
 SUPER^.stPiezoStage.nPiezoDriveControl.8 := NOT SUPER^.stPiezoStage.bExecute;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Home" Id="{d33ee575-f547-404d-bc45-25b73c38be5a}">
      <Declaration><![CDATA[METHOD Home : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[SUPER^.Home();]]></ST>
      </Implementation>
    </Method>
    <Method Name="Interlock" Id="{36207be0-7a17-466d-9c72-e0f495170f07}">
      <Declaration><![CDATA[METHOD Interlock
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// For SmartAct MCS2 these limit are range and enstop limits. however a single bit in the status 
// notifies on the condition. it maybe more effcieint to use he position following error sign instead
IF THIS^.bMoveBusy THEN
    // Positive or Negative direction
    IF  THIS^.CalibratedActPos > fCalibratedStandStillPos THEN
        THIS^.PositiveDirection:=TRUE;
        THIS^.NegativeDirection:=FALSE;
    ELSE
        THIS^.PositiveDirection:=FALSE;
        THIS^.NegativeDirection:=TRUE;
    END_IF
ELSE
    // store idle Position
    THIS^.fCalibratedStandStillPos:=THIS^.CalibratedActPos;
END_IF
// rtMotionDir	(CLK:=SUPER^.MoveBusy);
// IF rtMotionDir.Q THEN
//         SUPER^.PositiveDirection:=(SUPER^.stPiezoStage.nFollowingError >= 0);
//         SUPER^.NegativeDirection:=(SUPER^.stPiezoStage.nFollowingError < 0);
// END_IF

stPiezoStage.bLimitForwardEnable :=  NOT(THIS^.PositiveDirection AND SUPER^.stPiezoStage.stPiezoDriveStatus.InternalLimitActive);
stPiezoStage.bLimitBackwardEnable := NOT (THIS^.NegativeDirection AND SUPER^.stPiezoStage.stPiezoDriveStatus.InternalLimitActive);
// call common interlocks checker
SUPER^.Interlock();





]]></ST>
      </Implementation>
    </Method>
    <Method Name="Logger" Id="{c74ad8cb-1745-4df8-b83c-c7761caffd8e}">
      <Declaration><![CDATA[METHOD Logger
]]></Declaration>
      <Implementation>
        <ST><![CDATA[SUPER^.Logger();]]></ST>
      </Implementation>
    </Method>
    <Method Name="MotionParams" Id="{f9010265-bfde-4e4a-8b05-a4f8748f71cd}">
      <Declaration><![CDATA[METHOD PUBLIC MotionParams
VAR_INPUT
    tRefreshDelay: TIME;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// get periodique update on Motion params
ReadDriveParams();
// 
// Copy axis parameters that we want to expose to the EPICS layer.
stPiezoStage.stAxisParametersExposed.bCtrlEnablePosDiffControl     := stPiezoStage.stAxisParameters.bCtrlEnablePosDiffControl;
stPiezoStage.stAxisParametersExposed.bEncEnableSoftEndMaxControl   := stPiezoStage.stAxisParameters.bEncEnableSoftEndMaxControl ;
stPiezoStage.stAxisParametersExposed.bEncEnableSoftEndMinControl   := stPiezoStage.stAxisParameters.bEncEnableSoftEndMinControl;
stPiezoStage.stAxisParametersExposed.fAccelerationMax              := stPiezoStage.stAxisParameters.fAccelerationMax;
stPiezoStage.stAxisParametersExposed.fCtrlPosDiffMax               := stPiezoStage.stAxisParameters.fCtrlPosDiffMax;
stPiezoStage.stAxisParametersExposed.fCtrlPosDiffMaxTime           := stPiezoStage.stAxisParameters.fCtrlPosDiffMaxTime;
stPiezoStage.stAxisParametersExposed.fDecelerationMax              := stPiezoStage.stAxisParameters.fDecelerationMax;
stPiezoStage.stAxisParametersExposed.fEncSoftEndMax                := stPiezoStage.stAxisParameters.fEncSoftEndMax;
stPiezoStage.stAxisParametersExposed.fEncSoftEndMin                := stPiezoStage.stAxisParameters.fEncSoftEndMin;
stPiezoStage.stAxisParametersExposed.fVeloMaximum                  := stPiezoStage.stAxisParameters.fVeloMaximum;
stPiezoStage.stAxisParametersExposed.fEncOffset               	  := stPiezoStage.stAxisParameters.fEncOffset;
stPiezoStage.stAxisParametersExposed.fEncScaleFactorInternal       := stPiezoStage.stAxisParameters.fEncScaleFactorInternal;

]]></ST>
      </Implementation>
    </Method>
