    <Property Name="CalibratedTargetPosition" Id="{81813abc-be79-4b01-bd0b-013ad1ba8c86}">
      <Declaration><![CDATA[PROPERTY CalibratedTargetPosition : DINT]]></Declaration>
      <Get Name="Get" Id="{b29f2fdd-a221-4a00-b566-55ff2dd3354a}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[CalibratedTargetPosition:= fCalibratedTargetPosition;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="CalibratedVelocity" Id="{54e27d08-db1c-4a56-8d6f-ee25264ddf78}">
      <Declaration><![CDATA[PROPERTY CalibratedVelocity : DINT]]></Declaration>
      <Get Name="Get" Id="{55f6b951-9e85-4976-9d4e-affbfb1a904d}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[CalibratedVelocity := fCalibratedVelocity;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="CalibrateMotionParams" Id="{ac17b7c4-a540-4db8-be71-88c2b2fc9fb9}">
      <Declaration><![CDATA[METHOD CalibrateMotionParams
VAR_INPUT
END_VAR
VAR

END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[	// All drive paramters must be express in mm, mm/s, mm/s2
	fCalibratedMaxVelocity :=  REAL_TO_DINT((SUPER^.stPiezoStage.fMaxVelocity / MAX(SUPER^.stPiezoStage.fscalingFactor, fdefaultScalingFactor)));
 	fCalibratedMaxAcceleration :=  LREAL_TO_DINT(SUPER^.stPiezoStage.fMaxAcceleration /  MAX(SUPER^.stPiezoStage.fscalingFactor, fdefaultScalingFactor));
 	// set soft limit on drive params to avoid bumping hard on the end stops
 	fCalibratedTargetPosition := LREAL_TO_DINT (SUPER^.stPiezoStage.fPosition / MAX(SUPER^.stPiezoStage.fscalingFactor, fdefaultScalingFactor));
 	fCalibratedVelocity := LIMIT(0, LREAL_TO_DINT (SUPER^.stPiezoStage.fVelocity / MAX(SUPER^.stPiezoStage.fscalingFactor, fdefaultScalingFactor)), fCalibratedMaxVelocity);
	fCalibratedAcceleration := LIMIT(0, LREAL_TO_DINT (SUPER^.stPiezoStage.fAcceleration / MAX(SUPER^.stPiezoStage.fscalingFactor, fdefaultScalingFactor)), fCalibratedMaxAcceleration) ;

	
]]></ST>
      </Implementation>
    </Method>
    <Property Name="DriveStateTransition" Id="{d49512e2-8ed7-49a9-b597-af522d2c9beb}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'variable'}
PROPERTY DriveStateTransition : E_DS402_DRIVE_STATE]]></Declaration>
      <Get Name="Get" Id="{cbe48f03-a943-49e9-9a9b-d28b456dc170}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[DriveStateTransition := eInternalDriveState;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{3f90ff1d-67cd-4286-a280-25468d6b9853}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[eInternalDriveState := DriveStateTransition;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="DS402StateMachine" Id="{d963b9d7-d9e1-4a33-bb79-0f8a7e20b1de}">
      <Declaration><![CDATA[METHOD DS402StateMachine
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Drive State Events and Operations
IF NOT __ISVALIDREF(stPiezoStage) THEN
    // we will return gracefully in the FAULT state
    ErrorMessage := 'FAULT: Drive interface not initialized';
    Error := TRUE;
    ErrorID := 9999; // find an appropriate code
    RETURN;
END_IF


(*switch on disable*)
IF NOT stPiezoStage.stPiezoStageStatus.ReadyToSwitchOn
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchedOn
    AND NOT stPiezoStage.stPiezoStageStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoStageStatus.Fault
    AND  stPiezoStage.stPiezoStageStatus.SwitchOnDisabled THEN

    DriveStateTransition := E_DS402_DRIVE_STATE.SWITCH_ON_DISABLED;
END_IF

(*Ready to switch*)
IF  stPiezoStage.stPiezoStageStatus.ReadyToSwitchOn
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchedOn
    AND NOT stPiezoStage.stPiezoStageStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoStageStatus.Fault
    AND stPiezoStage.stPiezoStageStatus.QuickStopActive
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchOnDisabled THEN

    DriveStateTransition := E_DS402_DRIVE_STATE.SWITCH_ON_READY;
END_IF

(*Switch on*)
IF  stPiezoStage.stPiezoStageStatus.ReadyToSwitchOn
    AND stPiezoStage.stPiezoStageStatus.SwitchedOn
    AND NOT stPiezoStage.stPiezoStageStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoStageStatus.Fault
    AND stPiezoStage.stPiezoStageStatus.QuickStopActive
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchOnDisabled THEN

    DriveStateTransition := E_DS402_DRIVE_STATE.SWITCH_ON;
END_IF

(*Operation enbaled*)
IF    stPiezoStage.stPiezoStageStatus.ReadyToSwitchOn
    AND stPiezoStage.stPiezoStageStatus.SwitchedOn
    AND stPiezoStage.stPiezoStageStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoStageStatus.Fault
    AND stPiezoStage.stPiezoStageStatus.QuickStopActive
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchOnDisabled THEN

    DriveStateTransition := E_DS402_DRIVE_STATE.OPERATION_ENABLED;
END_IF

(*Fault*)
IF  NOT  stPiezoStage.stPiezoStageStatus.ReadyToSwitchOn
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchedOn
    AND NOT stPiezoStage.stPiezoStageStatus.OperationEnabled
    AND stPiezoStage.stPiezoStageStatus.Fault
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchOnDisabled THEN

    DriveStateTransition := E_DS402_DRIVE_STATE.FAULT;
END_IF

(*Fault reaction active*)
IF    stPiezoStage.stPiezoStageStatus.ReadyToSwitchOn
    AND stPiezoStage.stPiezoStageStatus.SwitchedOn
    AND stPiezoStage.stPiezoStageStatus.OperationEnabled
    AND stPiezoStage.stPiezoStageStatus.Fault
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchOnDisabled THEN

    DriveStateTransition := E_DS402_DRIVE_STATE.FAULT_ACTIVE;
END_IF

(*Quick Stop*)
IF    stPiezoStage.stPiezoStageStatus.ReadyToSwitchOn
    AND stPiezoStage.stPiezoStageStatus.SwitchedOn
    AND stPiezoStage.stPiezoStageStatus.OperationEnabled
    AND NOT stPiezoStage.stPiezoStageStatus.Fault
    AND stPiezoStage.stPiezoStageStatus.VoltageEnabled
    AND NOT stPiezoStage.stPiezoStageStatus.QuickStopActive
    AND NOT stPiezoStage.stPiezoStageStatus.SwitchOnDisabled THEN

    DriveStateTransition := E_DS402_DRIVE_STATE.QUICK_STOP_ACTIVE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{8fccdb5f-b457-4637-ae44-ff5efe2142a7}">
      <Declaration><![CDATA[(*FB_Init is always available implicitly and it is used primarily for initialization.
The return value is not evaluated. For a specific influence, you can also declare the
methods explicitly and provide additional code there with the standard initialization
code. You can evaluate the return value.*)
METHOD FB_Init : BOOL
VAR_INPUT
    (* TRUE: the retain variables are initialized (reset warm / reset cold)*)
    bInitRetains	: BOOL;
    (* TRUE: the instance will be copied to the copy code afterward (online change)   *)
    bInCopyCode	: BOOL;
    stStage : REFERENCE TO  ST_PiezoStage;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.Reset();]]></ST>
      </Implementation>
    </Method>
    <Method Name="Halt" Id="{7f626c89-4c25-446a-aadf-2d7158be6cb2}">
      <Declaration><![CDATA[METHOD Halt : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Halt the move by setting bit 8 of the Control Word.
SUPER^.stPiezoStage.nPiezoStageControl.8 := SUPER^.stPiezoStage.bHalt;


]]></ST>
      </Implementation>
    </Method>
