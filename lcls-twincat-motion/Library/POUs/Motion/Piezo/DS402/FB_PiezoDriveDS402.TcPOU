    </Method>
    <Method Name="Interlock" Id="{36207be0-7a17-466d-9c72-e0f495170f07}">
      <Declaration><![CDATA[METHOD Interlock
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// For SmartAct MCS2 these limit are range and enstop limits. however a single bit in the status 
// notifies on the condition. it maybe more effcieint to use he position following error sign instead
IF THIS^.bMoveBusy THEN
    // Positive or Negative direction
    IF  THIS^.CalibratedActPos > fCalibratedStandStillPos THEN
        THIS^.PositiveDirection:=TRUE;
        THIS^.NegativeDirection:=FALSE;
    ELSE
        THIS^.PositiveDirection:=FALSE;
        THIS^.NegativeDirection:=TRUE;
    END_IF
ELSE
    // store idle Position
    THIS^.fCalibratedStandStillPos:=SUPER^.CalibratedActPos;
END_IF
// rtMotionDir	(CLK:=SUPER^.MoveBusy);
// IF rtMotionDir.Q THEN
//         SUPER^.PositiveDirection:=(SUPER^.stPiezoStage.nFollowingError >= 0);
//         SUPER^.NegativeDirection:=(SUPER^.stPiezoStage.nFollowingError < 0);
// END_IF

stPiezoStage.bLimitForwardEnable :=  NOT(THIS^.PositiveDirection AND SUPER^.stPiezoStage.stPiezoDriveStatus.InternalLimitActive);
stPiezoStage.bLimitBackwardEnable := NOT (THIS^.NegativeDirection AND SUPER^.stPiezoStage.stPiezoDriveStatus.InternalLimitActive);
// call common interlocks checker
SUPER^.Interlock();





]]></ST>
      </Implementation>
    </Method>
