    <Method Name="ReadyToMove" Id="{e8ac081b-f2ab-4fce-bd8c-66cc66e75529}">
      <Declaration><![CDATA[METHOD ReadyToMove : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF SUPER^.stPiezoStage.bMoveCmd THEN
        // attempting to move an axis without homing first?
	IF SUPER^.stPiezoStage.nHomingMode <> E_EpicsHomeCmd.NONE AND NOT SUPER^.stPiezoStage.bHomed THEN
            // one can just set bHome here even though no homing was done?
            ErrorMessage := 'Axis homing mode set, but homing routine pending';
	END_IF
	MoveReady := TRUE;
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{ca77c887-2b90-4375-866f-a9f6ff5b335c}">
      <Declaration><![CDATA[METHOD Reset : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Try to clear any faults if they are present by setting bit 7 of the Control Word.
rtReset(CLK:=SUPER^.stPiezoStage.bReset);
IF rtReset.Q THEN
		SUPER^.stPiezoStage.nPiezoStageControl := 16#80;
END_IF
]]></ST>
      </Implementation>
    </Method>
