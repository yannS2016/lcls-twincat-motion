    <Method Name="PostInterlocks" Id="{0f2de4be-a2d5-40b5-bf2e-f13c48bf1447}">
      <Declaration><![CDATA[METHOD PostInterlocks : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// user override aka stop from EPICS ?
// Check done moving via user stop, fbDriveVirtual and Target Position Monitoring, or from homing.
// set/reset SUPER^.stPiezoStage.bDone after move absolute/Relative
THIS^.ftExec(CLK:=SUPER^.stPiezoStage.bExecute);
THIS^.rtTarget(CLK:=(THIS^.InTargetPosition AND THIS^.bMoveDone AND SUPER^.bExecMove));
THIS^.rtHomed(CLK:=SUPER^.HomeDone AND SUPER^.bExecHome);

IF THIS^.ftExec.Q OR THIS^.rtTarget.Q OR THIS^.rtHomed.Q THEN
    IF NOT SUPER^.stPiezoStage.bDone THEN
		SUPER^.MoveBusy:=FALSE;
		SUPER^.stPiezoStage.bDone := THIS^.bMoveDone OR SUPER^.HomeDone;
		SUPER^.stPiezoStage.bHomed := SUPER^.HomeDone;
        IF NOT SUPER^.Error THEN
            THIS^.bExecute:=FALSE;
            SUPER^.stPiezoStage.bExecute:=FALSE;
        END_IF
    END_IF
END_IF

IF THIS^.bExecute AND NOT SUPER^.Error THEN
    // Reset local warnings if things are going well
    SUPER^.stPiezoStage.sErrorMessage:='';
END_IF

// Handle auto-disable timing
SUPER^.bPrepareDisable S= SUPER^.stPiezoStage.nEnableMode = E_StageEnableMode.DURING_MOTION AND ftExec.Q;
// Delay the disable until we reach standstill, else brake issues or other race conditions
IF SUPER^.bPrepareDisable AND THIS^.eAxisState = MC_AXISSTATE_STANDSTILL THEN
    SUPER^.bPrepareDisable:=FALSE;
    SUPER^.stPiezoStage.bEnable:=FALSE;
END_IF

//---------- brakes code here ---------------

// Always reset, even if not rising edge, so command can be issued again
// but do so only after the move was done or was cancel due to error or an interlock condition
IF NOT SUPER^.bExecute AND (SUPER^.stPiezoStage.bMoveCmd OR SUPER^.stPiezoStage.bHomeCmd) THEN
    SUPER^.stPiezoStage.bMoveCmd:=FALSE;
    SUPER^.stPiezoStage.bHomeCmd:=FALSE;
	SUPER^.bOverrideExternalExec := FALSE;
END_IF

// Force everything off in case of error
IF SUPER^.stPiezoStage.bError THEN
    SUPER^.stPiezoStage.bBusy := FALSE;
    SUPER^.stPiezoStage.bDone := FALSE;
    SUPER^.stPiezoStage.bEnable := FALSE;
END_IF

SUPER^.stPiezoStage.bBusy:=SUPER^.HomingBusy OR SUPER^.MoveBusy;

// Log errors
// Set the error message if we have one

// Hook if other code wants to inject a non-NC error
IF SUPER^.stPiezoStage.sCustomErrorMessage <> '' THEN
	bLogReady := FALSE;
	SUPER^.stPiezoStage.sErrorMessage := SUPER^.stPiezoStage.sCustomErrorMessage;

ELSE
	SUPER^.stPiezoStage.sErrorMessage := F_MotionErrorCodeLookup(nErrorId := SUPER^.stPiezoStage.nErrorId);
END_IF

fbLogError( stMotionStage:=SUPER^.stPiezoStage, bEnable:=bLogReady);

]]></ST>
      </Implementation>
    </Method>
    <Method Name="Power" Id="{634342db-4980-4103-96da-256cbacd69e1}">
      <Declaration><![CDATA[METHOD Power : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[rtEnableDrive(CLK:=SUPER^.stPiezoStage.bAllEnable);
ftDisbaleDrive(CLK:=SUPER^.stPiezoStage.bAllEnable);
// Enabled the drive: the client code must wait for state transition.
IF rtEnableDrive.Q THEN
    // Voltage on, close loop operations
    SUPER^.stPiezoStage.nPiezoDriveControl:=16#0F;
    fOverride:=100.0;
END_IF

IF ftDisbaleDrive.Q THEN
	//  inhibit motion functions! keep amplifier enable
	SUPER^.stPiezoStage.nPiezoDriveControl:=16#07;
    fOverride:=0.0;
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReadDriveErrors" Id="{b0585027-4ae7-4117-8a3d-d9e1621fba78}">
      <Declaration><![CDATA[METHOD ReadDriveErrors : BOOL
VAR_INPUT

END_VAR

VAR

END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[AmsNetIdToString();

ftErrorSdoRead(CLK:=fbErrorSdoRead.bBusy);

fbErrorSdoRead( sNetId:= sAmsNetId, 
				nSlaveAddr:=SUPER^.stPiezoStage.nSlaveAddr, 
				nIndex:=nChanErrorCodeIndex, 
				nSubIndex :=nSubIndex, 
				pDstBuf:= ADR(SUPER^.nPiezoErrorCode), 
				cbBufLen:=SIZEOF(SUPER^.nPiezoErrorCode),
				bExecute:= SUPER^.Error );
				
IF ftErrorSdoRead.Q THEN
	IF 	fbErrorSdoRead.bError THEN
		SUPER^.Error:=fbErrorSdoRead.bError;
		SUPER^.ErrorCode:=fbErrorSdoRead.nErrId;
	ELSE
		// Update Motion Error code;
		SUPER^.ErrorCode := SUPER^.PiezoErrorCode;

		// Error is general error status from the output of each motion fucntion called
		SUPER^.stPiezoStage.bError := SUPER^.Error;
		SUPER^.stPiezoStage.nErrorId := SUPER^.ErrorCode;	
		bLogReady := TRUE;
	END_IF
	bReadDone := TRUE;
ELSE
	bReadDone := FALSE;
END_IF

ReadDriveErrors := bReadDone;



]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReadDriveParams" Id="{91ee2260-ec1c-4238-9b91-9438ac703127}">
      <Declaration><![CDATA[(*Read Piezo drive Motion parameters*)
METHOD ReadDriveParams : BOOL
VAR_INPUT

END_VAR

VAR
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[tonSlowParamReadTimer( IN:=bSlowParamReadTimer, PT:=tRefreshDelay );
// Get the Master Ams Net Into into correct format
AmsNetIdToString();
// Get the following Error
fbFollowWinSdoRead(	sNetId:= sAmsNetId, 
				nSlaveAddr:=SUPER^.stPiezoStage.nSlaveAddr, 
				nIndex:=nChanFollowErrorWinIndex, 
				nSubIndex:=0, 
				pDstBuf:= ADR(SUPER^.stPiezoStage.nfollowErrorWin), 
				cbBufLen:=SIZEOF(SUPER^.stPiezoStage.nfollowErrorWin),
				bExecute:=tonSlowParamReadTimer.Q
			  );
// Read the Upper software limit
fbSoftLimMaxSdoRead( sNetId:= sAmsNetId, 
				nSlaveAddr:=SUPER^.stPiezoStage.nSlaveAddr, 
				nIndex:=nChanSoftwareLimIndex, 
				nSubIndex:=1, 
				pDstBuf:= ADR(SUPER^.stPiezoStage.nSoftwareLimMax), 
				cbBufLen:=SIZEOF(SUPER^.stPiezoStage.nSoftwareLimMax),
				bExecute:=tonSlowParamReadTimer.Q
			  );
		  
// Read the Lower software limit		  
fbSoftLimMinSdoRead( sNetId:= sAmsNetId, 
				nSlaveAddr:=SUPER^.stPiezoStage.nSlaveAddr, 
				nIndex:=nChanSoftwareLimIndex, 
				nSubIndex:=2, 
				pDstBuf:= ADR(SUPER^.stPiezoStage.nSoftwareLimMin), 
				cbBufLen:=SIZEOF(SUPER^.stPiezoStage.nSoftwareLimMin),
				bExecute:=tonSlowParamReadTimer.Q
			  );




// IF ftMotorloadSdoRead.Q THEN
// 	IF 	fbMotorloadSdoRead.bError THEN
// 		// this will be logged as a warning
// 		SUPER^.PiezoErrorCode := fbMotorloadSdoRead.nErrId;
// 		//SUPER^.fbMotionErrorLogger.AddMsg(SUPER^.PiezoErrorCode, '');
// 	END_IF
// 	tonFastParamReadTimer.IN:=TRUE AND NOT THIS^.ftExec.Q;
// END_IF	  


// ftFollowWinSdoRead(CLK:=fbFollowWinSdoRead.bBusy);
// ftSoftLimMaxSdoRead(CLK:=fbSoftLimMaxSdoRead.bBusy);
// ftSoftLimMinSdoRead(CLK:=fbSoftLimMinSdoRead.bBusy);
// ftMotorloadSdoRead(CLK:=fbMotorloadSdoRead.bBusy);

IF fbSoftLimMinSdoRead.bBusy AND fbSoftLimMaxSdoRead.bBusy AND fbFollowWinSdoRead.bBusy THEN
	bSlowParamReadTimer:=FALSE;
END_IF

IF NOT fbSoftLimMinSdoRead.bBusy AND NOT fbSoftLimMaxSdoRead.bBusy AND NOT fbFollowWinSdoRead.bBusy THEN
	IF NOT bSlowParamReadTimer THEN
		bSlowParamReadTimer:=TRUE;
	END_IF
	IF 	fbFollowWinSdoRead.bError THEN
		// this will be logged as a warning
		SUPER^.Error := FALSE;
		SUPER^.PiezoErrorCode := fbFollowWinSdoRead.nErrId;
		//SUPER^.fbMotionErrorLogger.AddMsg(SUPER^.PiezoErrorCode, '');
	ELSIF 	fbSoftLimMaxSdoRead.bError THEN
		// this will be logged as a warning
		SUPER^.Error := FALSE;
		SUPER^.PiezoErrorCode := fbSoftLimMaxSdoRead.nErrId;
		//SUPER^.fbMotionErrorLogger.AddMsg(SUPER^.PiezoErrorCode, '');
	ELSIF 	fbSoftLimMinSdoRead.bError THEN
		// this will be logged as a warning
		SUPER^.Error := FALSE;
		SUPER^.PiezoErrorCode := fbSoftLimMinSdoRead.nErrId;
		//SUPER^.fbMotionErrorLogger.AddMsg(SUPER^.PiezoErrorCode, '');
	END_IF
	SUPER^.stPiezoStage.bError := SUPER^.Error;
	SUPER^.stPiezoStage.nErrorId := SUPER^.PiezoErrorCode;
END_IF

// done reading params?	
// IF ftFollowWinSdoRead.Q 
// 
// 	AND ftSoftLimMinSdoRead.Q 
// 	AND ftSoftLimMaxSdoRead.Q  THEN
// 
// 	IF 	fbFollowWinSdoRead.bError THEN
// 		// this will be logged as a warning
// 		SUPER^.PiezoErrorCode := fbFollowWinSdoRead.nErrId;
// 		//SUPER^.fbMotionErrorLogger.AddMsg(SUPER^.PiezoErrorCode, '');
// 	ELSIF 	fbSoftLimMaxSdoRead.bError THEN
// 		// this will be logged as a warning
// 		SUPER^.PiezoErrorCode := fbSoftLimMaxSdoRead.nErrId;
// 		//SUPER^.fbMotionErrorLogger.AddMsg(SUPER^.PiezoErrorCode, '');
// 	ELSIF 	fbSoftLimMinSdoRead.bError THEN
// 		// this will be logged as a warning
// 		SUPER^.PiezoErrorCode := fbSoftLimMinSdoRead.nErrId;
// 		//SUPER^.fbMotionErrorLogger.AddMsg(SUPER^.PiezoErrorCode, '');
// 	END_IF 
// 	bSlowParamReadTimer:=TRUE;
// 
// END_IF

stPiezoStage.stAxisParameters.sAxisName := stPiezoStage.sName;
stPiezoStage.stAxisParameters.AxisId := stPiezoStage.nMotionAxisID;
stPiezoStage.stAxisParameters.bCtrlEnablePosDiffControl   := BOOL_TO_WORD(SUPER^.stPiezoStage.nfollowErrorWin > 0);
stPiezoStage.stAxisParameters.bEncEnableSoftEndMaxControl := BOOL_TO_WORD(SUPER^.stPiezoStage.nSoftwareLimMax > SUPER^.stPiezoStage.nSoftwareLimMin);
stPiezoStage.stAxisParameters.bEncEnableSoftEndMinControl := BOOL_TO_WORD(SUPER^.stPiezoStage.nSoftwareLimMin < SUPER^.stPiezoStage.nSoftwareLimMax);
stPiezoStage.stAxisParameters.fAccelerationMax := SUPER^.stPiezoStage.fMaxAcceleration;
stPiezoStage.stAxisParameters.fCtrlPosDiffMax := SUPER^.stPiezoStage.nfollowErrorWin;
// this info is not provided by the drive we keep it 0
stPiezoStage.stAxisParameters.fCtrlPosDiffMaxTime := 0.0;
stPiezoStage.stAxisParameters.fDecelerationMax := SUPER^.stPiezoStage.fMaxAcceleration;
stPiezoStage.stAxisParameters.fEncSoftEndMax := LINT_TO_LREAL(stPiezoStage.nSoftwareLimMax);
stPiezoStage.stAxisParameters.fEncSoftEndMin := LINT_TO_LREAL(stPiezoStage.nSoftwareLimMin);
stPiezoStage.stAxisParameters.fVeloMaximum := SUPER^.stPiezoStage.fMaxVelocity;
stPiezoStage.stAxisParameters.fEncOffset := 0.0;
// this info is not provided by the driver we keep it 0
stPiezoStage.stAxisParameters.fEncScaleFactorInternal := 0.0;
SUPER^.stPiezoStage.bAxisParamsInit S= TRUE;

]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReadStatus" Id="{222b82c3-b7d6-4787-9577-5abf84745d3e}">
      <Declaration><![CDATA[METHOD ReadStatus
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{ca77c887-2b90-4375-866f-a9f6ff5b335c}">
      <Declaration><![CDATA[METHOD Reset : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Try to clear any faults if they are present by setting bit 7 of the Control Word.
rtReset(CLK:=SUPER^.stPiezoStage.bReset);
IF rtReset.Q THEN
    SUPER^.stPiezoStage.nPiezoDriveControl:=16#80;
    // Reset everything when bReset is flagged
    SUPER^.stPiezoStage.bEnable:=FALSE;
    SUPER^.stPiezoStage.bReset:=FALSE;
    SUPER^.stPiezoStage.bExecute:=FALSE;
	SUPER^.Error := FALSE;
	SUPER^.ErrorCode := 0;
	SUPER^.PiezoErrorCode := 0;
	SUPER^.stPiezoStage.bError := 0;
	SUPER^.stPiezoStage.nErrorId := 0;	
    SUPER^.stPiezoStage.sErrorMessage:='';
    SUPER^.stPiezoStage.sCustomErrorMessage:='';
    bExecute:=FALSE;
	bLogReady := FALSE;
	SUPER^.HomeDone := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="StateMachine" Id="{d963b9d7-d9e1-4a33-bb79-0f8a7e20b1de}">
      <Declaration><![CDATA[METHOD StateMachine
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*switch on disable*)
IF NOT SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND  SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eDriveState :=E_DS402DriveState.SWITCH_ON_DISABLED;
END_IF

(*Ready to switch*)
IF  SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN
	bFault := FALSE;
    eDriveState :=E_DS402DriveState.SWITCH_ON_READY;
END_IF

(*Switch on*)
IF  SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eDriveState :=E_DS402DriveState.SWITCH_ON;
END_IF

(*Operation enbaled*)
IF    SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eDriveState :=E_DS402DriveState.OPERATION_ENABLED;
END_IF

(*Fault*)
IF  NOT  SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN
	bFault := TRUE;
    eDriveState :=E_DS402DriveState.FAULT;
END_IF

(*Fault reaction active*)
IF    SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN
    eDriveState :=E_DS402DriveState.FAULT_ACTIVE;
END_IF

(*Quick Stop*)
IF    SUPER^.stPiezoStage.stPiezoDriveStatus.ReadyToSwitchOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchedOn
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.OperationEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.Fault
    AND SUPER^.stPiezoStage.stPiezoDriveStatus.VoltageEnabled
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.QuickStopActive
    AND NOT SUPER^.stPiezoStage.stPiezoDriveStatus.SwitchOnDisabled THEN

    eDriveState :=E_DS402DriveState.QUICK_STOP_ACTIVE;
END_IF


rtFault(CLK:=bFault	);
rtMotionErrorEvent(CLK:=SUPER^.Error);

CASE eDriveState  OF

    E_DS402DriveState.SWITCH_ON_DISABLED:;

    E_DS402DriveState.SWITCH_ON_READY:;

    E_DS402DriveState.SWITCH_ON:;

    E_DS402DriveState.OPERATION_ENABLED:;
		IF NOT bOperational THEN
			bOperational := TRUE;
			SUPER^.McAxisState:=MC_AxisStates.MC_AXISSTATE_STANDSTILL;
		END_IF
    E_DS402DriveState.FAULT:;
        (* This is not a motion fault but rather a hardware, lost of enabled, wc or loss of calibration issue
			The condition will set bit 3 'fault' but not bit 13 'error' so waiting in the error state would won't  clear this condition *)
		IF rtFault.Q THEN
			SUPER^.Error := TRUE;
		END_IF
		// Catch the drive errors code
		ReadDriveErrors();
		SUPER^.McAxisState:=MC_AxisStates.MC_AXISSTATE_UNDEFINED;
		
    E_DS402DriveState.QUICK_STOP_ACTIVE:;


END_CASE

rtNotOperational(CLK:= eDriveState <> E_DS402DriveState.OPERATION_ENABLED);
IF rtNotOperational.Q THEN
	bOperational := FALSE;
	SUPER^.McAxisState:=MC_AxisStates.MC_AXISSTATE_DISABLED;
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="SyncEPICSStatus" Id="{0ec1ab11-3e34-4193-8590-6aaa07110b4c}">
      <Declaration><![CDATA[METHOD SyncEPICSStatus
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Status struct for EPICS communication
SUPER^.stPiezoStage.stAxisStatus.bEnable:=SUPER^.stPiezoStage.bAllEnable;
SUPER^.stPiezoStage.stAxisStatus.bEnabled:=SUPER^.stPiezoStage.bEnableDone; // account for PowerEnable from power block
SUPER^.stPiezoStage.stAxisStatus.bError:=SUPER^.stPiezoStage.bError;
SUPER^.stPiezoStage.stAxisStatus.bHomeSensor:=SUPER^.stPiezoStage.bHome;
SUPER^.stPiezoStage.stAxisStatus.bLimitBwd:=SUPER^.stPiezoStage.bAllBackwardEnable;
SUPER^.stPiezoStage.stAxisStatus.bLimitFwd:=SUPER^.stPiezoStage.bAllForwardEnable;
SUPER^.stPiezoStage.stAxisStatus.bReset:=SUPER^.stPiezoStage.bReset;
SUPER^.stPiezoStage.stAxisStatus.fAcceleration:=SUPER^.stPiezoStage.fAcceleration;
SUPER^.stPiezoStage.stAxisStatus.fActDiff:=SUPER^.stPiezoStage.fPosDiff;
SUPER^.stPiezoStage.stAxisStatus.fActPosition:=THIS^.CalibratedActPos;
SUPER^.stPiezoStage.stAxisStatus.fActVelocity:=SUPER^.stPiezoStage.fVelocity;
SUPER^.stPiezoStage.stAxisStatus.fDeceleration:=SUPER^.stPiezoStage.fAcceleration;
SUPER^.stPiezoStage.stAxisStatus.fOverride:=THIS^.fOverride;
SUPER^.stPiezoStage.stAxisStatus.fPosition:=SUPER^.stPiezoStage.fPosition;
SUPER^.stPiezoStage.stAxisStatus.fVelocity:=SUPER^.stPiezoStage.fVelocity;
SUPER^.stPiezoStage.stAxisStatus.nCmdData:=SUPER^.stPiezoStage.nCmdData;  //Or nCmdDataLocal
SUPER^.stPiezoStage.stAxisStatus.nCommand:=SUPER^.stPiezoStage.nCommand;  //Or nCommandLocal
SUPER^.stPiezoStage.stAxisStatus.nErrorId:=SUPER^.stPiezoStage.nErrorId;
SUPER^.stPiezoStage.stAxisStatus.bBusy:=SUPER^.stPiezoStage.bBusy;
SUPER^.stPiezoStage.stAxisStatus.bHomed:=SUPER^.stPiezoStage.bHomed;
SUPER^.stPiezoStage.stAxisStatus.bExecute:=bExecute;
SUPER^.stPiezoStage.stAxisStatus.nCommand:=3; // If this is not 3, the IOC stops updating positions during homing]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>