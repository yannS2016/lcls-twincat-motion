    <Method Name="Home" Id="{2fdfc142-a2a6-49f0-950a-d0e52b5408ca}">
      <Declaration><![CDATA[METHOD PUBLIC Home : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* IMPORTANT: Homing options and parameters must be configured either via the COE online tab or via the service tool*)
CASE eHomingState OF
	E_HOMING_STATE.INIT_HOMING :;
		// set Piezo drive in Homing Mode : call this line once: better use a state machine here
		stPiezoStage.nModeOfOperation := E_DS402_OPERATION_MODE.HOMING;	
		IF stPiezoStage.nModeOfOperationDisplay = E_DS402_OPERATION_MODE.HOMING THEN
			// Homing paramters are configure as PDOs for ease of operations
			// make sure homing speed are before proceeding
			stPiezoStage.nPiezoDriveControl.4 := TRUE;
			eHomingState := E_HOMING_STATE.HOMING_IN_PROGRESS;			
		END_IF
	E_HOMING_STATE.HOMING_IN_PROGRESS:;	
		IF NOT stPiezoStage.stPiezoDriveStatus.TargetReached
		   AND NOT stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
				HomingBusy := TRUE;
				HomeDone := FALSE;

		END_IF
		
		// homing error
		IF stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
			eHomingState := E_HOMING_STATE.HOMING_ERROR;	
		END_IF
		// Interrupted
		IF stPiezoStage.stPiezoDriveStatus.TargetReached THEN
			eHomingState := E_HOMING_STATE.HOMING_INTERRUPTED;	
		END_IF
		
		// Reached
		IF stPiezoStage.stPiezoDriveStatus.TargetReached
			AND stPiezoStage.stPiezoDriveStatus.Bit12_OpModeSpecific
			AND NOT stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
			eHomingState := E_HOMING_STATE.HOMING_ATTAINED;	
		END_IF
		
	E_HOMING_STATE.HOMING_ATTAINED:;
		HomingBusy := FALSE;
		HomeDone := TRUE;
		Error := FALSE;
		ErrorCode := 0;
		
	E_HOMING_STATE.HOMING_INTERRUPTED :;
		HomingBusy := FALSE;
		HomeDone := FALSE;
		stPiezoStage.bHomed := FALSE;
		IF stPiezoStage.nPiezoDriveControl.8 THEN
			ErrorMessage := 'Warning: Halt interrupted homing sequence';
			Error := FALSE;
			ErrorCode := 99; // keep this code for homing
		END_IF

	E_HOMING_STATE.HOMING_ERROR:;
		HomingBusy := FALSE;
		HomeDone := FALSE;
		Error := TRUE;
		ErrorCode := stPiezoStage.nPiezoErrorCode;
		ErrorMessage := 'Error: Homing error occured';
END_CASE

THIS^.stPiezoStage.stAxisStatus.nCommand := 3; // If this is not 3, the IOC stops updating positions during homing
//SUPER^.stPiezoStage.bHomed := SUPER^.HomeDone;]]></ST>
      </Implementation>
    </Method>
