  <POU Name="FB_PiezoDrive" Id="{062edea9-cfc5-43cf-98da-5ad9b4d99528}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK PUBLIC ABSTRACT FB_PiezoDrive IMPLEMENTS I_PiezoDrive
VAR_INPUT

END_VAR
VAR_OUTPUT

END_VAR
VAR
	{attribute 'no_copy'}
    stPiezoStage		: REFERENCE TO ST_PiezoStage;
    eModeOFOperation	: E_DS402OperationMode:=E_DS402OperationMode.NONE;
    eHomingState		: E_DS402Homing;
	// reuse to absolute/relative moves for DS402
    eAxisState			:  MC_AxisStates;
    //fbMotionErrorLogger : FB_MotionErrorLogger;
    // create a property for some of these
    bExecMove			: BOOL;
    bExecHome			: BOOL;
    bPosGoal			: BOOL;
    bNegGoal			: BOOL;
    bNewMoveReq			: BOOL;
    bMoveCmd			: BOOL;
    bHomingBusy			: BOOL;
    bHomingDone			: BOOL;
    bPrepareDisable		: BOOL;
    bMoveDone			: BOOL;
    bMoveBusy			: BOOL;
    // use this for motion time axis states
    bExecute			: BOOL;
	// This prevent unexpected logical 1 on stMotionStage.bExecute 
	// outside rising edges from bMoveCmd or bHomeCmd 
	bOverrideExternalExec	: BOOL;
	
//    rtHomed				: R_TRIG;
    rtMoveCmdShortcut	: R_TRIG;
    rtHomeCmdShortcut	: R_TRIG;
    rtEnableMode		: R_TRIG;
    rtUserExec			: R_TRIG;
    rtExec			: R_TRIG;
	rtNewMoveReq	: R_TRIG;
	ftForwardEnabled: F_TRIG;
	ftBackwardEnabled: F_TRIG;
	

    bError				: BOOL:=FALSE;
    nErrorId			: UDINT:=0;
    sLocalErrorMessage	: STRING;
    tonSyncHoming 			: TON;
	ntest				: UINT;
	nPiezoErrorCode			        : UDINT;
	// Save abd restore encoder value
    bInit: BOOL;
    bLoad: BOOL;
    nLatchError: UDINT;
    bEncError: BOOL;
    cpuCounter : GETCPUCOUNTER;
END_VAR

VAR PERSISTENT
    bSaved: BOOL;
    fPosition: LREAL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
