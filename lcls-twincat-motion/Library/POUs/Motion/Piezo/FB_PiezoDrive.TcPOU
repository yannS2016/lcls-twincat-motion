    <Method Name="CalibratedMotionParams" Id="{67fcb905-3933-48da-aebe-2bf2e7a7195e}">
      <Declaration><![CDATA[METHOD CalibratedMotionParams
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// All drive paramters must be express in mm, mm/s, mm/s2
nCalibratedMaxVelocity :=  REAL_TO_DINT((stPiezoStage.fMaxVelocity / MAX(stPiezoStage.fscalingFactor, DefaultScalingFactor)));
nCalibratedMaxAcceleration :=  LREAL_TO_DINT(stPiezoStage.fMaxAcceleration /  MAX(stPiezoStage.fscalingFactor, DefaultScalingFactor));
// Homing params
 nCalibratedHomeVelocity  := LIMIT(0, LREAL_TO_DINT (stPiezoStage.fVelocity / MAX(stPiezoStage.fscalingFactor, DefaultScalingFactor)), nCalibratedMaxVelocity);
 nCalibratedHomeAcceleration := LIMIT(0, LREAL_TO_DINT (stPiezoStage.fAcceleration / MAX(stPiezoStage.fscalingFactor, DefaultScalingFactor)), nCalibratedMaxAcceleration) ;
]]></ST>
      </Implementation>
    </Method>
