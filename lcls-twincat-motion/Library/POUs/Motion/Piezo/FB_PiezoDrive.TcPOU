    <Method Name="Home" Id="{2fdfc142-a2a6-49f0-950a-d0e52b5408ca}">
      <Declaration><![CDATA[METHOD PUBLIC Home : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[tonSyncHoming(PT:=T#1000MS);
(* IMPORTANT: Homing options and parameters must be configured either via the COE online tab or via the service tool *)
CASE eHomingState OF
    E_DS402Homing.INIT_HOMING :;
        stPiezoStage.nModeOfOperation:=E_DS402OperationMode.HOMING;
        IF stPiezoStage.nModeOfOperationDisplay = E_DS402OperationMode.HOMING THEN
			HomeDone := FALSE;
			tonSyncHoming.IN := TRUE;
            stPiezoStage.nPiezoDriveControl.4:=TRUE;
			IF tonSyncHoming.Q THEN
				eHomingState:=E_DS402Homing.HOMING_IN_PROGRESS;
			END_IF
        END_IF

    E_DS402Homing.HOMING_IN_PROGRESS:
        IF NOT stPiezoStage.stPiezoDriveStatus.TargetReached
           AND NOT stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
                HomingBusy:=TRUE;
                HomeDone:=FALSE;
        END_IF
		
        // Interrupted
        IF stPiezoStage.stPiezoDriveStatus.TargetReached 
			AND NOT stPiezoStage.stPiezoDriveStatus.Bit12_OpModeSpecific THEN
            eHomingState:=E_DS402Homing.HOMING_INTERRUPTED;
        END_IF

        // Reached
        IF stPiezoStage.stPiezoDriveStatus.TargetReached
            AND stPiezoStage.stPiezoDriveStatus.Bit12_OpModeSpecific
            AND NOT stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
            eHomingState:=E_DS402Homing.HOMING_ATTAINED;
        END_IF

    E_DS402Homing.HOMING_ATTAINED:;
        HomingBusy:=FALSE;
        HomeDone:=TRUE;
        Error:=FALSE;
		tonSyncHoming.IN := FALSE;
		stPiezoStage.fPosition := 0.0;
		//prepare next move
		stPiezoStage.nPiezoDriveControl.4:=FALSE;
		stPiezoStage.nModeOfOperation:=E_DS402OperationMode.PROFILE_POSITION;
		
    E_DS402Homing.HOMING_INTERRUPTED :;
        HomingBusy:=FALSE;
        HomeDone:=FALSE;
        ErrorMessage:='Warning: Halt interrupted homing sequence';
        Error:=FALSE;
        ErrorCode:=99; 

END_CASE

// update main homing status
//stPiezoStage.bHomed:=HomeDone;]]></ST>
      </Implementation>
    </Method>
    <Property Name="HomeDone" Id="{ef80f79d-a7a5-4a2f-a11f-e37d59b9ba61}">
      <Declaration><![CDATA[{attribute 'monitoring':= 'variable'}
PROPERTY HomeDone : BOOL]]></Declaration>
