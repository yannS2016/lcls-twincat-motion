    <Method Name="Interlock" Id="{72f66b07-eac8-4f48-a977-69dc5fa659a2}">
      <Declaration><![CDATA[METHOD PUBLIC Interlock : BOOL

VAR
	uStates	: UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Check for the plc shortcut commands
// Used for testing or to circumvent motor record issues
rtMoveCmdShortcut(CLK:=stPiezoStage.bMoveCmd);
rtHomeCmdShortcut(CLK:=stPiezoStage.bHomeCmd);

// Execute on rising edge
IF rtMoveCmdShortcut.Q AND NOT stPiezoStage.bExecute THEN
    stPiezoStage.bExecute := TRUE;
    stPiezoStage.nCommand := E_EpicsMotorCmd.MOVE_ABSOLUTE;

    // attempting to move an axis without homing first?
    IF stPiezoStage.nHomingMode <> E_EpicsHomeCmd.NONE AND NOT stPiezoStage.bHomed THEN
        // one can just set bHome here even though no homing was done?
        stPiezoStage.sErrorMessage := 'Warning: Axis homing mode set, but homing routine pending';
    END_IF

ELSIF rtHomeCmdShortcut.Q AND NOT stPiezoStage.bExecute THEN
    stPiezoStage.bExecute := TRUE;
    stPiezoStage.nCommand := E_EpicsMotorCmd.HOME;
END_IF

// Always reset, even if not rising edge, so command can be issued again
IF stPiezoStage.bMoveCmd OR stPiezoStage.bHomeCmd THEN
    stPiezoStage.bMoveCmd := FALSE;
    stPiezoStage.bHomeCmd := FALSE;
END_IF
// Automatically fill the correct nCmdData for homing
IF stPiezoStage.nCommand = E_EpicsMotorCmd.HOME THEN
    stPiezoStage.nCmdData := stPiezoStage.nHomingMode;
END_IF

// Check if the command wants to cause a move
bMoveCmd R= stPiezoStage.nCmdData = E_EpicsHomeCmd.ABSOLUTE_SET;
bMoveCmd R= stPiezoStage.nCmdData = E_EpicsHomeCmd.NONE;
bMoveCmd S= stPiezoStage.nCommand <> E_EpicsMotorCmd.HOME;

// Handle main execs
rtUserExec(CLK := stPiezoStage.bExecute);
bNewMoveReq S= rtUserExec.Q AND bMoveCmd;
bNewMoveReq R= NOT stPiezoStage.bExecute;
bPrepareDisable R= bNewMoveReq;

bPosGoal := stPiezoStage.stAxisStatus.fActPosition < stPiezoStage.fPosition;
bNegGoal := stPiezoStage.stAxisStatus.fActPosition > stPiezoStage.fPosition;

// Moves are automatically allowed if no safety hooks. Otherwise, some other code will set this.
stPiezoStage.bSafetyReady S= stPiezoStage.bPowerSelf;
// check all enabling interlocks
SetEnables();
// Transition to 'DURING_MOTION' drive mode
rtEnableMode(CLK:=(stPiezoStage.nEnableMode = E_StageEnableMode.DURING_MOTION));
// Handle auto-enable timing
CASE stPiezoStage.nEnableMode OF
    E_StageEnableMode.ALWAYS:
        stPiezoStage.bEnable := TRUE;
		
    E_StageEnableMode.DURING_MOTION:
        IF rtEnableMode.Q THEN
            stPiezoStage.bEnable := FALSE;
        END_IF
		
        IF bNewMoveReq THEN
            IF stPiezoStage.nCommand = E_EpicsMotorCmd.HOME THEN
                stPiezoStage.bEnable := stPiezoStage.bSafetyReady;

            ELSIF bPosGoal THEN
                IF stPiezoStage.bAllForwardEnable THEN
                    stPiezoStage.bEnable S= stPiezoStage.bSafetyReady;
				// we're trying not to overwrite the error condition from move and homing FB
				// error logger needs to able this better
                ELSIF NOT stPiezoStage.bError THEN
                    // Not an error, just a warning
                    stPiezoStage.sErrorMessage := 'Cannot move past positive limit.';
                    stPiezoStage.bExecute := FALSE;
					
                END_IF
				
            ELSIF bNegGoal THEN
                IF stPiezoStage.bAllBackwardEnable THEN
                    stPiezoStage.bEnable S= stPiezoStage.bSafetyReady;
				// we're trying not to overwrite the error condition from move and homing FB
				// error logger needs to able this better
                ELSIF NOT stPiezoStage.bError THEN
                    // Not an error, just a warning
                    stPiezoStage.sErrorMessage := 'Cannot move past negative limit.';
                    stPiezoStage.bExecute := FALSE;
					
                END_IF
            ELSE
                // Super rare condition where we asked for a move to exactly the same floating point we're already at
                stPiezoStage.bEnable S= stPiezoStage.bSafetyReady;
            END_IF
			// power is till enable? motion in progress or error occured
            IF stPiezoStage.bEnable OR stPiezoStage.bError THEN
                bNewMoveReq := FALSE;
            END_IF
        END_IF
END_CASE
]]></ST>
      </Implementation>
    </Method>
