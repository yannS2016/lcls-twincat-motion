<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_PiezoDrive" Id="{062edea9-cfc5-43cf-98da-5ad9b4d99528}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK PUBLIC ABSTRACT FB_PiezoDrive IMPLEMENTS I_PiezoDrive
VAR_INPUT

END_VAR
VAR_OUTPUT

END_VAR
VAR
    stPiezoStage 			:	REFERENCE TO ST_PiezoStage;
    eModeOFOperation		: 	E_DS402_OPERATION_MODE := E_DS402_OPERATION_MODE.NONE;
	eHomingState			:	E_HOMING_STATE;
	// use this for motion time axis states
	mcAxisStates			:   MC_AxisStates;
	bHomingBusy				: 	BOOL;
	bHomingDone				: 	BOOL;

	bMoveInProgess			:	BOOL;
    bError  				: 	BOOL := FALSE;
    nErrorId  				: 	UDINT := 0;
    sLocalErrorMessage		:	STRING;

	nCalibratedMaxVelocity 	: DINT;
	nCalibratedMaxAcceleration	: DINT;
	nCalibratedHomeVelocity 	: DINT;
	nCalibratedHomeAcceleration	: DINT;
	bInternalLimitActive		: BOOL;
	// Calibrated motion params : nanometer operation by default.
	fdefaultScalingFactor		: REAL := 0.000001; //nm

    bExecute: BOOL;
	// create a property for some of these
    bExecMove: BOOL;
    bExecHome: BOOL;
    bFwdHit: BOOL;
    bBwdHit: BOOL;
    ftExec: F_TRIG;
    rtExec: R_TRIG;
    rtUserExec: R_TRIG;
    rtTarget: R_TRIG;
    rtHomed: R_TRIG;
    bPosGoal: BOOL;
    bNegGoal: BOOL;
    bNewMoveReq: BOOL;
    bPrepareDisable: BOOL;
    bMoveCmd: BOOL;
    rtMoveCmdShortcut: R_TRIG;
    rtHomeCmdShortcut: R_TRIG;
    rtEnableMode: R_TRIG;	

END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
