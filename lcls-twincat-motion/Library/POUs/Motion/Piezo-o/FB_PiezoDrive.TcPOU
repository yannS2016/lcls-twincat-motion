    <Method Name="Home" Id="{2fdfc142-a2a6-49f0-950a-d0e52b5408ca}">
      <Declaration><![CDATA[METHOD PUBLIC Home : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// set Piezo drive in Homing Mode
stPiezoStage.nModeOfOperation := E_MODE_OF_OPERATION.HOMING;

IF stPiezoStage.nModeOfOperationDisplay = E_MODE_OF_OPERATION.HOMING THEN
    // Homing paramters are configure as PDOs for ease of operations
    // make sure homing speed are before proceeding
    stPiezoStage.stPiezoStageControl.Bit4_OpModeSpecific := TRUE;

    // successful ?
    IF  stPiezoStage.stPiezoStageStatus.TargetReached
        AND NOT stPiezoStage.stPiezoStageStatus.Bit12_OpModeSpecific
        AND NOT stPiezoStage.stPiezoStageStatus.Bit13_OpModeSpecific THEN
        Error := FALSE;
        ErrorID := 0; // find an appropriate code
        ErrorMessage := 'Warning: Drive Homing Precedure interrupted or not started';
        stPiezoStage.bDone := TRUE;
        stPiezoStage.bHomed := FALSE;
    END_IF

    IF  NOT stPiezoStage.stPiezoStageStatus.TargetReached
        AND stPiezoStage.stPiezoStageStatus.Bit12_OpModeSpecific
        AND NOT stPiezoStage.stPiezoStageStatus.Bit13_OpModeSpecific THEN
        Error := FALSE;
        ErrorID := 0; // find an appropriate code
        ErrorMessage := 'Warning: Home attained but target not reached';
        stPiezoStage.bDone := TRUE;
        stPiezoStage.bHomed := FALSE;
    END_IF

    IF stPiezoStage.stPiezoStageStatus.TargetReached
        AND stPiezoStage.stPiezoStageStatus.Bit12_OpModeSpecific
        AND NOT stPiezoStage.stPiezoStageStatus.Bit13_OpModeSpecific THEN
        Error := FALSE;
        ErrorID := 0; // find an appropriate code
        ErrorMessage := 'Homing procedure is completed successfully';
        stPiezoStage.stPiezoStageControl.Bit4_OpModeSpecific := FALSE;
        stPiezoStage.bDone := TRUE;
        stPiezoStage.bHomed := TRUE;
        // set home position based on stMotionStage.fHomePosition offset
        // this need to be written before homing start using sdo write if we dont use PDO for
        // homing options.
    END_IF

    IF  NOT stPiezoStage.stPiezoStageStatus.TargetReached
        AND NOT stPiezoStage.stPiezoStageStatus.Bit12_OpModeSpecific
        AND stPiezoStage.stPiezoStageStatus.Bit13_OpModeSpecific THEN
        Error := TRUE;
        ErrorID := stPiezoStage.nPiezoErrorCode; // find an appropriate code
        ErrorMessage := 'Error: Homing error occured, velocity is not 0';
        stPiezoStage.bDone := TRUE;
        stPiezoStage.bHomed := FALSE;
    END_IF

    IF  stPiezoStage.stPiezoStageStatus.TargetReached
        AND NOT stPiezoStage.stPiezoStageStatus.Bit12_OpModeSpecific
        AND stPiezoStage.stPiezoStageStatus.Bit13_OpModeSpecific THEN
        Error := FALSE;
        ErrorID := stPiezoStage.nPiezoErrorCode; // find an appropriate code
        ErrorMessage := 'Error: Homing error occured, velocity 0';
        stPiezoStage.bDone := TRUE;
        stPiezoStage.bHomed := FALSE;
    END_IF

END_IF

// Override homing status, dmov as appropriate
stPiezoStage.stAxisStatus.bHomed := stPiezoStage.bHomed;
// this need to be handle in the power method
stPiezoStage.stAxisStatus.bExecute := stPiezoStage.bExecute;
stPiezoStage.stAxisStatus.nCommand := 3; // If this is not 3, the IOC stops updating positions during homing

]]></ST>
      </Implementation>
    </Method>
