    <Method Name="SetHomingParams" Id="{a28d7e11-f485-4a60-bdef-9b0d673cfb42}">
      <Declaration><![CDATA[METHOD SetHomingParams : BOOL
VAR_INPUT
    bExecute	:	BOOL := FALSE;
    nIndex     	: 	WORD ; 		   (* CoE Object Index *)
    nSubIndex  	: 	BYTE ; 			   (* Subindex of CoE Object *)
    nValue		: 	DINT;
    fbSdoWrite	: 	FB_EcCoESdoWrite;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT fbSdoWrite.bBusy THEN
    bExecute := FALSE;
    IF NOT fbSdoWrite.bError THEN
        (* write successful *)
        Error := FALSE;
        ErrorId := 0;
    ELSE
        (* write failed *)
        Error := fbSdoWrite.bError;
        ErrorId := fbSdoWrite.nErrId;

    END_IF

    fbSdoWrite(bExecute := FALSE);
END_IF]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>