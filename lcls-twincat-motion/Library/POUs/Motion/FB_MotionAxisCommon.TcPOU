        </Implementation>
      </Get>
      <Set Name="Set" Id="{6b74fee6-0826-4088-8509-987679c32e97}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[stAxisParameterSetExposed := AxisParameterSetExposed;]]></ST>
        </Implementation>
      </Set>
    </Property>
