<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MotionInterlocks" Id="{875748a6-e3b4-4780-a711-0e1eb4182bc0}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MotionInterlocks IMPLEMENTS I_MotionInterlocks
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    {attribute 'hide'}
    iMotionLogger 		: I_MotionLogger;
    {attribute 'hide'}
    MotionSyncPrivateRef : REFERENCE TO FB_MotionSyncPrivate;
    (* Hardware *)
   // NC Forward Limit Switch: TRUE if ok to move
    bLimitForwardEnable AT %I*: BOOL;
    // NC Backward Limit Switch: TRUE if ok to move
    bLimitBackwardEnable AT %I*: BOOL;
    // NO Home Switch: TRUE if at home
    bHome AT %I*: BOOL;
   (* Psuedo-hardware *)
    // Forward enable EPS summary
    {attribute 'hide'}
    bAllForwardEnabled: BOOL:=FALSE;
    // Backward enable EPS summary
    {attribute 'hide'}
    bAllBackwardEnabled: BOOL:=FALSE;
    {attribute 'hide'}
    // Enable EPS summary encapsulating emergency stop button and any additional motion preventive hardware
    {attribute 'hide'}
    bAllEnabled: BOOL:=FALSE;
    // Forward virtual gantry limit switch
    bGantryForwardEnable: BOOL:=FALSE;
    // Backward virtual gantry limit switch
    bGantryBackwardEnable: BOOL:=FALSE;
    // Set true to activate gantry EPS
    bGantryAxis: BOOL:=FALSE;
   // If TRUE, we want to enable the motor independently of PMPS or other safety systems.
    bPowerSelf: BOOL:=FALSE;
    // Determines our encoder homing strategy
    nHomingMode: E_EpicsHomeCmd:=E_EpicsHomeCmd.NONE;
    // TRUE if we have safety permission to move
    bSafetyReady: BOOL;
    // TRUE if done enabling
    bEnableDone: BOOL;
    bLocalEnable : BOOL;
   // NC STO Input: TRUE if ok to move
    {attribute 'pytmc' := '
        pv: PLC:bHardwareEnable
        io: i
        field: ZNAM FALSE
        field: ONAM TRUE
        field: DESC TRUE if STO not hit
    '}
    bHardwareEnable AT %I*: BOOL ;

    // Forward Enable EPS struct
    {attribute 'pytmc' := '
        pv: PLC:stEPSF
        io: i
        field: DESC Forward Enable Interlocks
    '}
    stEPSForwardEnable: DUT_EPS;
    // Backward Enable EPS struct
    {attribute 'pytmc' := '
        pv: PLC:stEPSB
        io: i
        field: DESC Backward Enable Interlocks
    '}
    stEPSBackwardEnable: DUT_EPS;
    // Power Enable EPS struct
    {attribute 'pytmc' := '
        pv: PLC:stEPSP
        io: i
        field: DESC Power Interlocks
    '}
    stEPSPowerEnable: DUT_EPS;

    // Used by the IOC to disable an axis
    {attribute 'pytmc' := '
        pv: PLC:bUserEnable
        io: io
        field: ZNAM DISABLE
        field: ONAM ENABLE
        field: DESC Used to disable power entirely for an axis
    '}
    bUserEnable: BOOL := TRUE;
    {attribute 'hide'}
    bLimOverride : BOOL;
    {attribute 'hide'}
    bSoftInterlock : BOOL;
    {attribute 'hide'}
    bHomeBusy : BOOL;
    {attribute 'hide'}
    bMoveBusy	: BOOL;
    {attribute 'hide'}
    bNewMoveReq	: BOOL;
    {attribute 'hide'}
    bEnable: BOOL;
    {attribute 'hide'}
    bExecute : BOOL;
    {attribute 'hide'}
    bEPSOk : BOOL;
    {attribute 'hide'}
    sMessage : STRING;
    {attribute 'hide'}
    bWarning : BOOL;
    {attribute 'hide'}
    nErpicsWarnId : UINT;
    {attribute 'hide'}
    bError : BOOL;
    {attribute 'hide'}
    bReset : BOOL;
    {attribute 'hide'}
    bLimHit : BOOL;
    {attribute 'hide'}
    bMoveDone : BOOL;
    {attribute 'hide'}
    eAxisState	: MC_AxisStates;
    {attribute 'hide'}
    ftForwardEnabled : F_TRIG;
    {attribute 'hide'}
    ftBackwardEnabled : F_TRIG;
    rtUserExec : R_TRIG;
     nErrorID: UDINT;
     bMoveOk : BOOL;
     rtDone : R_TRIG;
    rtError : R_TRIG;
    ftError : F_TRIG;
    bLimHitIdling : BOOL;
    bLimHitMoving : BOOL;
    bStandStill	  : BOOL;
    rtStandStill : R_TRIG;
    bPositiveDirection : BOOL;
    bNegativeDirection : BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Read external private data
IF NOT __ISVALIDREF(MotionSyncPrivateRef) THEN
    RETURN;
END_IF
// some of these vars can be used for addtional interlocks checks in
// in this class or in derived implementation
THIS^.bReset := THIS^.MotionSyncPrivateRef.SyncPrvAbortDone;
THIS^.bHomeBusy :=  THIS^.MotionSyncPrivateRef.SyncPrvHomeBusy;
THIS^.bMoveBusy :=  THIS^.MotionSyncPrivateRef.SyncPrvMoveBusy;
THIS^.bMoveDone :=  THIS^.MotionSyncPrivateRef.SyncPrvMoveDone;
THIS^.bNewMoveReq :=  THIS^.MotionSyncPrivateRef.SyncPrvNewMoveReq;
THIS^.bEnable :=  THIS^.MotionSyncPrivateRef.bSyncPrvEnable;
THIS^.bPositiveDirection :=THIS^.MotionSyncPrivateRef.SyncPrvPositiveDirection;
THIS^.bNegativeDirection :=THIS^.MotionSyncPrivateRef.SyncPrvNegativeDirection;

bAllBackwardEnabled := bLimitBackwardEnable AND (bGantryBackwardEnable OR NOT bGantryAxis) AND stEPSForwardEnable.bEPS_OK;
bAllForwardEnabled := bLimitForwardEnable AND (bGantryForwardEnable OR NOT bGantryAxis) AND stEPSBackwardEnable.bEPS_OK;
/////////////////////////////////////////////////////////////////////////////
// SoftInterlock is a user defined interloc logic active high
/////////////////////////////////////////////////////////////////////////////
bAllEnabled := bEnable AND bHardwareEnable AND stEPSPowerEnable.bEPS_OK AND NOT bSoftInterlock;
bAllEnabled R= NOT bUserEnable OR bSoftInterlock;
// Moves are automatically allowed if no safety hooks. Otherwise, some other code will set this.
bSafetyReady S= bPowerSelf;
// This tell the other block in seq processing to wait on interlock to do an intial check
// before they can proceed. checking error only is not enough.
rtUserExec (CLK:=bNewMoveReq);
ftForwardEnabled(CLK:=bAllForwardEnabled);
ftBackwardEnabled (CLK:=bAllBackwardEnabled);
// compound all interlocks elements to identify the cyclic error condition
bMoveOk := bUserEnable AND bHardwareEnable AND bAllBackwardEnabled AND bAllForwardEnabled;

IF NOT bMoveOk THEN
    IF NOT bUserEnable THEN
        bError := TRUE;
        nErrorID:= 1;
        sMessage := 'User enable interlock is Triggered!';
    ELSIF NOT bHardwareEnable THEN
        bError := TRUE;
        nErrorID:= 1;
        sMessage := 'Hardware enbale Interlocks is Triggered!';
    // Axis Moving:
    // Pos Direction Move interruption: ftForwardEnabled.Q AND bPositiveDirection
    // Neg Direction Move interruption: ftBackwardEnabled.Q AND bNegativeDirection
    ELSIF (ftForwardEnabled.Q AND bPositiveDirection) OR (ftBackwardEnabled.Q AND bNegativeDirection) AND NOT bHomeBusy  THEN
        // Not an error, just a warning
        IF NOT bAllForwardEnabled THEN
            sMessage:='Cannot move past positive limit.';
        ELSIF NOT bAllBackwardEnabled THEN
            sMessage:='Cannot move past Negative limit.';
        END_IF
        bError:=FALSE;
        nErrorID:=0;
        bWarning:=TRUE;
        bLimHit := TRUE;
        bLimHitMoving:=TRUE;
        bLimOverride:=TRUE;
    // axis idling : critical limit enabled faillure
     ELSIF NOT bMoveBusy AND NOT bWarning AND NOT (bAllForwardEnabled AND bAllBackwardEnabled) THEN
        bError := TRUE;
        nErrorID:= 1;
         bLimHit := TRUE;
         bLimHitIdling := TRUE;
         sMessage:='Forward or Bakward limit enable faillure!';
    END_IF
ELSE
    bLimHit := FALSE;
    bLimHitMoving := bLimHit;
    bLimHitIdling := bLimHit;
    sMessage := '';
    bError := FALSE;
    bWarning := FALSE;
    nErrorID:= 0;
END_IF

IF bReset THEN
    bReset := FALSE;
    bError := FALSE;
    //bWarning := FALSE;
    nErrorID:= 0;
    bLimOverride := FALSE;
    bMoveOk := FALSE;
    bLimHit := FALSE;
    bLimHitMoving := bLimHit;
    bLimHitIdling := bLimHit;
    sMessage:='';
END_IF

rtError(CLK:=bError OR bWarning);
ftError(CLK:=bError);

// write external private data
// control MC_Power based on interlocks
THIS^.MotionSyncPrivateRef.SyncPrvAllEn := THIS^.bAllEnabled;
THIS^.MotionSyncPrivateRef.SyncPrvAllBwdEn := THIS^.bAllBackwardEnabled;
THIS^.MotionSyncPrivateRef.SyncPrvAllFwdEn := THIS^.bAllForwardEnabled;
// Needed by NC homing Methods
THIS^.MotionSyncPrivateRef.SyncPrvLimBwd := THIS^.bLimitBackwardEnable;
THIS^.MotionSyncPrivateRef.SyncPrvLimFwd := THIS^.bLimitForwardEnable;
THIS^.MotionSyncPrivateRef.SyncPrvHome := THIS^.bHome;
]]></ST>
    </Implementation>
