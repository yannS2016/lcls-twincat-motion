    <Method Name="ErrorHandling" Id="{e3e9f4c3-bd6f-4479-80bb-9cc735eca053}">
      <Declaration><![CDATA[METHOD ErrorHandling
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*
    Error from functions and Nc
    The error will send to EPICS interface based on predifined
    priority: axis, power, backlash, absoluteMove, etc...
*)
IF AxisRef.Status.Error  THEN
    bError:=TRUE;
    nErrorId:=AxisRef.Status.ErrorID;
ELSIF fbMcPower.Error AND fbMcPower.Active THEN
    bError:=fbMcPower.Enable;
    nErrorId:=fbMcPower.ErrorID;
ELSIF fbMcBacklashCompensation.Error (*fbMcMoveAbsolute.Active*) THEN
    bError:=fbMcBacklashCompensation.Enable;
    nErrorId:=fbMcBacklashCompensation.ErrorID;
ELSIF fbMcMoveAbsolute.Error (*fbMcMoveAbsolute.Active*) THEN
    bError:=fbMcMoveAbsolute.Error;
    nErrorId:=fbMcMoveAbsolute.ErrorID;
ELSIF THIS^.bHomeError (*Homing error*) THEN
    bError:=bHomeError;
    nErrorId:=THIS^.nHomeErrorID;
ELSIF fbMcHalt.Error AND fbMcHalt.Active THEN
    bError:=fbMcHalt.Execute;
    nErrorId:=fbMcHalt.ErrorID;
ELSIF fbMcReset.Error  THEN
    bError:=fbMcPower.Enable;
    nErrorId:=fbMcPower.ErrorID;
ELSIF mcReadParams.Error THEN
    bError := mcReadParams.Error;
    nErrorId := mcReadParams.ErrorID;
ELSIF bRestoreError THEN
    bError := bRestoreError ;
    nErrorId := nRestoreErrorID;
ELSE
    bError:=FALSE;
    nErrorId:=0;
    sErrorMessage := '';
END_IF;


]]></ST>
      </Implementation>
    </Method>
    <Property Name="ErrorID" Id="{b7569608-1ea8-4914-a3b4-543b15f7c860}">
      <Declaration><![CDATA[{attribute 'monitoring':= 'variable'}
