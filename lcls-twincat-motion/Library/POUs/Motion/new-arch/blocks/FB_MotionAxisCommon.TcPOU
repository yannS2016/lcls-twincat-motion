    <Method Name="Power" Id="{07e66653-5e23-4ae4-b867-e4c021789c12}">
      <Declaration><![CDATA[METHOD Power
VAR_INPUT
    Enable	: BOOL;
    Enable_Positive	: BOOL;
    Enable_Negative	: BOOL;
    (* in percent from 0 to 100 *)
    Override	: LREAL := 100.0;
    BufferMode	: MC_BufferMode := MC_BufferMode.MC_Aborting;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.bPowerEnable := Enable;
THIS^.bPowerEnablePositive := Enable_Positive;
THIS^.bPowerEnableNegative := Enable_Negative;
THIS^.fOverride := Override;
THIS^.eBufferMode := BufferMode ;
]]></ST>
      </Implementation>
    </Method>
