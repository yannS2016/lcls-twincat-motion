<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MotionAxisCommon" Id="{b2f4c148-bcde-4ca5-a7a9-abd4413ce8ab}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'call_after_init'}
FUNCTION_BLOCK FB_MotionAxisCommon IMPLEMENTS I_MotionAxisCommon
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    {attribute 'no_copy'}
    AxisRef : REFERENCE TO AXIS_REF;
    bDummy : BOOL;
    fHaltDeceleration : LREAL;
    fHaltJerk : LREAL;
    eHaltBufferMode : MC_BufferMode;
    eDisableMode : E_DISABLEMODE := E_DISABLEMODE.DisableModeHold;
    // Raw encoder IO for ULINT (Biss-C)
    nCycleCounter : UDINT;
    nCycleCounterPrev :  UDINT;
    nRawEncoderULINT AT %I*: ULINT;
    // Raw encoder IO for UINT (Relative Encoders)

    nRawEncoderUINT AT %I*: UINT;
    // Raw encoder IO for INT (LVDT)

    nRawEncoderINT AT %I*: INT;
    // Raw encoder IO for INT (EL5072 LVDT)

    nRawEncoderDINT AT %I*: DINT;
    // Encoder count summary, if linked above
    {attribute 'pytmc' := '
        pv: PLC:nEncoderCount
        io: i
        field: DESC Count from encoder hardware
    '}
    nEncoderCount: UDINT;
    (* Other status information for users of the IOC *)
    (* Backlash compensation*)
    // Enabled axis backlash compensation
    {attribute 'pytmc' := '
        pv: PLC:bBacklashEn
        io: io
        field: ZNAM FALSE
        field: ONAM TRUE
        field: DESC Enable Backlash compensation
    '}
    bUserBacklashEn: BOOL;

    // backlash compensation status
    {attribute 'pytmc' := '
        pv: PLC:bBacklasStatus
        io: i
        field: ZNAM DISABLED
        field: ONAM ENABLED
        field: DESC Backlash compensation status
    '}
    bBacklashStatus: BOOL;

    // Backlash compensation value
    {attribute 'pytmc' := '
        pv: PLC:fBacklash
        io: io
        field: DESC Backlash compensation
    '}
    fBacklash: LREAL;

    // Current Backlash compensation value ?
    {attribute 'pytmc' := '
        pv: PLC:fCurrentBacklash
        io: i
        field: DESC Currently applied compensation
    '}
    fCurrentBacklash: LREAL;

    // Position lag difference
    {attribute 'pytmc' := '
        pv: PLC:fPosDiff
        io: i
        field: DESC Position lag difference
    '}
    fPosDiff: LREAL;

    // NC parameters that are exposed with pytmc pragmas
    {attribute 'pytmc' := '
        pv: PLC:AxisPar
        io: i
        field: DESC Axis configuration parameters in the numerical controller.
    '}
    stAxisParameterSetExposed : ST_AxisParameterSetExposed;

    // MC_ReadParameterSet Output

    mcReadParams: MC_ReadParameterSet;
    //{attribute 'hide'}

    stAxisParameters: ST_AxisParameterSet;


    bNcParamsReadInit   : BOOL;

    (* NC Blocks *)
    // MoveABsolute

    fbMcMoveAbsolute : MC_MoveAbsolute;

    bCommandedMoveAbsolute : BOOL;

    bMoveAbsoluteBusy : BOOL;

    bMoveAbsoluteDone : BOOL;

    bMoveAbsoluteError : BOOL;

    bCommandedAborted : BOOL;

    nMoveAbsoluteErrorID : UDINT;
    // Reset

    fbMcReset 	: MC_Reset;

    bResetDone 	: BOOL;

    bResetBusy	: BOOL;

    bResetError	: BOOL;

    bResetErrorID	: UDINT;

    bReset		: BOOL;

    bCommandedReset : BOOL;
    // Power

    fbMcPower 		: MC_Power;

    bPowerEnable	: BOOL;

    bPowerEnablePositive : BOOL;

    bPowerEnableNegative : BOOL;

    bPowerIsEnabled : BOOL;

    bPowerBusy 		: BOOL;

    bPowerError 	: BOOL;

    nPowerErrorID 	: UDINT;

    fOverride 		: LREAL := 100.0;
    //////////////////

    fbMcHalt 		: MC_Halt;

    bCommandedHalt 	: BOOL;

    bHaltDone 		: BOOL;

    bHaltError 		: BOOL;

    nHaltErrorID 	: UDINT;

    bHaltBusy 		: BOOL;

    bExecHome : BOOL;

    bExecMove : BOOL;
    // Move parameters

    fMoveAbsoluteTargetPosition	: LREAL;

    fMoveAbsoluteTargetVelocity	: LREAL;

    fMoveAbsoluteTargetAcceleration	: LREAL := 0.0;

    fMoveAbsoluteTargetDeceleration	: LREAL := 0.0;

    fMoveAbsoluteTargetJerk	: LREAL := 0.0;

    eMoveMode : E_EpicsMotorCmd := E_EpicsMotorCmd.MOVE_ABSOLUTE;

    eBufferMode	: MC_BufferMode := .MC_BufferMode.MC_Aborting;
    // Axis Status

    nAxisId : UDINT;

    fMeasuredVelocity : LREAL;

    fMeasuredPosition : LREAL;

    fMeasuredPositionDiff : LREAL;

    fMeasuredAcceleration : LREAL;
    // Needed for interlocks checks. please keep this as declared

    eAxisState : MC_AxisStates;
    // save and restore

    fbSetPos: MC_SetPosition;

    bClearPositionLag : BOOL := TRUE;

    bAxisError 		: BOOL;

    bPowerStatus 	: BOOL;

    bRestoreDone 	: BOOL;

    bRestoreError 	: BOOL;

    nRestoreErrorID : UDINT;

    // save and Restore

    RestoreTimer: TON;

    bRestoreInit: BOOL;

    bRestoreLoad: BOOL;

    nLatchError: UDINT;

    bEncError: BOOL;

    tRetryDelay: TIME := T#1S;

    nMaxRetries: UINT := 10;

    nCurrTries: UINT := 0;

    bRestoreWaitRetry: BOOL;

    tonRestoreRetry: TON;

    tRefreshTime : TIME := T#1S;

    // create a property for some of these

    bMoveDone		: BOOL;

    bMoveBusy		: BOOL;

    bInTargetPosition	: BOOL;

    bInterrupted : BOOL;
    // Error handling

    bError				: BOOL;

    nErrorId			: UDINT:=0;

    sErrorMessage		: STRING;

    rtMoveAbsoluteBusy 			: R_TRIG;

    ftMoveAbsoluteBusy 			: F_TRIG;

    ftError		: F_TRIG;

    rtAbsoluteMoveDone	: R_TRIG;

    fbMcBacklashCompensation: MC_BacklashCompensation;

    fPrevCompensation : LREAL := 0.0;

    bBacklashCompEnable: BOOL;

    fBakclashRampRatio : LREAL := 10.0;

    iPersistentDataStorage : I_PersistentDataStorage;

    iMotionLogger : I_MotionLogger;
    fSetPosition	: LREAL;
    fSetVelocity	: LREAL;
    fSetAcceleration	: LREAL := 0.0;
    fSetDeceleration	: LREAL := 0.0;
    fSetJerk	: LREAL := 0.0;
    sName : STRING;
    // Piezo Motion Control

    tholtime		: TIME := T#10S;

    fPowerOverride : LREAL := 100.0;

    nCommand 		: UINT;

    nCommandData	: UINT;

    bAbortDone : BOOL;

    rtError				: R_TRIG;

    rtReset				: R_TRIG;

    ftServo				: F_TRIG;

    rtDone : R_TRIG;

    rtHomeAborted : R_TRIG;

    bCommandedMoveHome  : BOOL;

    bHomeBusy			: BOOL;

    bHomeDone			: BOOL;
    eHomingMethod : E_DS402HomingMethod;
    fHomePosition 		: LREAL :=0.0;
    fHomingSpeedsFast : LREAL;
    fHomingSpeedsSlow : LREAL;
    fHomingAcceleration : LREAL;
    fHomeOffset : LREAL;
   // fHomePosition : LREAL :=0.0;
    rtHomeDone				: R_TRIG;
    bHomeInterrupted	: BOOL;

    bHomeError 			: BOOL;

    nHomeErrorID 		: UDINT;


    // cathc this from interlock block or send it to interlock block in fb_init or call_after_init
    // catch limit status from motioninterlock block cyclic or just after execHome has pos edge.
    fbHomeMcSetPos: MC_SetPosition;
    fbHomeMcJog: MC_Jog;
    rtHomeExec: R_TRIG;
    ftHomeExec: F_TRIG;
    nHomeStateMachine: E_HomeStates;
    nHomeStateAfterStop: E_HomeStates;
    nHomeMoves: INT;
    bHomeFirstDir: BOOL;
    bAtHome: BOOL;
    bHomeMove: BOOL;
    nHomeErrCount: INT;
    nHomeMode:ENUM_EpicsHomeCmd :=ENUM_EpicsHomeCmd.NONE;

    bLimitBackwardEnable : BOOL;

    bLimitForwardEnable : BOOL;

	bPositiveMotionIsEnabled : BOOL;
	bNegativeMotionIsEnabled : BOOL;
    bHome : BOOL;

    ftEnabled :F_TRIG;
    bStandStill : BOOL;
END_VAR


VAR PERSISTENT
    {attribute 'conditionalshow'}
    bSaved: BOOL;
    {attribute 'conditionalshow'}
    fSavedPosition: LREAL;
END_VAR

VAR CONSTANT
    (*
        This is a simpler way of disabling the soft limits that ends up being really obvious if something has gone wrong.
        If you turn the limits off/on, not only do you need to keep track of if you had soft limits set,
        but you need to always restore this properly or risk some issue.
        Instead, I set position to a ridiculous value that can always move forward or backward.
        If this gets stuck for any reason it's very clear that something has gone wrong,
        rather than a silent failure of the soft limit marks.
    *)
    FWD_START: LREAL := -99999999;
    BWD_START: LREAL :=  99999999;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF( THIS^.AxisRef ) OR (THIS^.AxisRef.NcToPlc.AxisId = 0)THEN
    RETURN;
END_IF

// NC Functions
THIS^.AxisStatus();

THIS^.fbMcReset(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedReset (* AND Axis.Status.Error*),
    Done => THIS^.bResetDone,
    Busy => THIS^.bResetBusy,
    Error => THIS^.bResetError,
    ErrorID => THIS^.bResetErrorID,
);

//////////////////////////////////////////////////////////////////
// Power block depends on interlocks check in  iMotionInterlocks
/////////////////////////////////////////////////////////////////
THIS^.fbMcPower(
    Axis := THIS^.AxisRef,
    Enable := THIS^.bPowerEnable,
    Enable_Positive := THIS^.bPowerEnablePositive,
    Enable_Negative := THIS^.bPowerEnableNegative,
    Override := THIS^.fOverride,
    BufferMode := THIS^.eBufferMode,
    (*Enabled*)
    Status => THIS^.bPowerIsEnabled,
    Busy => THIS^.bPowerBusy,
    Error => THIS^.bPowerError,
    ErrorID => THIS^.nPowerErrorID
);


THIS^.fbMcHalt(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedHalt,
    Deceleration := THIS^.fHaltDeceleration,
    Jerk := THIS^.fHaltJerk,
    BufferMode := THIS^.eHaltBufferMode,
    Done =>THIS^.bHaltDone,
    Busy => THIS^.bHaltBusy,
    CommandAborted => ,
    Error => THIS^.bHaltError,
    ErrorID => THIS^.nHaltErrorID
);

//THIS^.bHaltDone S= THIS^.fbMcHalt.Done;
//THIS^.bHaltDone R= THIS^.fbMcHalt.Busy;

(*Note: Configure within the axis parameters set "position correction" to true
    Directional change FOR compensation
      FALSE: positive backlash:
      TRUE -> Negative backlash compensation
    Reset Compensation to register a new value change
*)
// use bUserBacklashEn for addtional control in user code, i.e fb_motionDrive
bBacklashCompEnable R= THIS^.bCommandedMoveHome OR (THIS^.fBacklash<>THIS^.fPrevCompensation);
bBacklashCompEnable S= THIS^.bUserBacklashEn AND NOT THIS^.AxisRef.Status.HomingBusy;

fbMcBacklashCompensation(Axis:=AxisRef,
    Enable:= THIS^.bBacklashCompEnable,
    Backlash:= THIS^.fBacklash,
    CompensationInPositiveDirection:=(THIS^.fBacklash<0.0),
    Ramp:=( THIS^.fMoveAbsoluteTargetVelocity / THIS^.fBakclashRampRatio ),
    DisableMode:=THIS^.eDisableMode,
    Enabled=> THIS^.bBacklashStatus,
    Error=>,
    ErrorID=>,
    CurrentBacklash=>THIS^.fCurrentBacklash
);
fPrevCompensation:=THIS^.fBacklash;
////////////////////////////////////////////////////////////////////////////////////
// Handling Absolute move request using signaling events
// on CommandedMoveAbsolute
// clear the done bit after previous move is completed by an error condition
///////////////////////////////////////////////////////////////////////////////////
THIS^.fbMcMoveAbsolute(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedMoveAbsolute,
    Position := THIS^.fMoveAbsoluteTargetPosition,
    Velocity := THIS^.fMoveAbsoluteTargetVelocity,
    Acceleration := THIS^.fMoveAbsoluteTargetAcceleration,
    Deceleration := THIS^.fMoveAbsoluteTargetDeceleration,
    Jerk := THIS^.fMoveAbsoluteTargetJerk,
    BufferMode := THIS^.eBufferMode,
    Done => ,
    Busy => THIS^.bMoveAbsoluteBusy,
    Active => ,
    CommandAborted => THIS^.bCommandedAborted,
    Error => THIS^.bMoveAbsoluteError,
    ErrorID => THIS^.nMoveAbsoluteErrorID
);

rtMoveAbsoluteBusy (CLK:=bMoveAbsoluteBusy);
ftMoveAbsoluteBusy(CLK:=bMoveAbsoluteBusy);

bMoveAbsoluteDone S= ftMoveAbsoluteBusy.Q AND NOT THIS^.bMoveAbsoluteError AND NOT THIS^.bResetBusy AND NOT THIS^.bHaltBusy;
bMoveAbsoluteDone R= rtMoveAbsoluteBusy.Q;

// Get axis status after calling NC blocks
THIS^.AxisStatus();

THIS^.CalibrateRawEncValue();

THIS^.ExposeNCParams();
//////////////////////////////////////
// Handle save
//////////////////////////////////////
THIS^.EncSave(bEnable:=TRUE);

/// error handling not completed yet
THIS^.ErrorHandling();

THIS^.bAbortDone := THIS^.bHaltDone OR THIS^.bResetDone;
// will be used in derive class or elsewhere.
// may be call this in derive class??
THIS^.bInterrupted := THIS^.bCommandedHalt OR THIS^.bCommandedReset;
// readbacks and status update from common worker
// When E_EpicsHomeCmd.ABSOLUTE_SET or E_EpicsHomeCmd.NONE
// bHomeDone is latched true, this will latched bDone.
rtHomeDone(CLK:=bHomeDone);
THIS^.bMoveBusy := THIS^.bMoveAbsoluteBusy OR THIS^.bHomeBusy;
THIS^.bMoveDone R= THIS^.bMoveBusy;
THIS^.bMoveDone S= THIS^.bMoveAbsoluteDone OR rtHomeDone.Q;

// reset execute when done or aborted.
IF  THIS^.bMoveDone OR THIS^.bAbortDone THEN
    THIS^.bCommandedReset := FALSE;
    THIS^.bCommandedHalt := FALSE;
    THIS^.bCommandedMoveHome := FALSE;
    THIS^.bCommandedMoveAbsolute := FALSE;
END_IF]]></ST>
    </Implementation>
    <Property Name="AbortDone" Id="{c838cdf3-d6f0-4b4f-8804-126c0b0381f5}">
      <Declaration><![CDATA[{warning 'Add property implementation'}
PROPERTY AbortDone : BOOL
]]></Declaration>
      <Get Name="Get" Id="{4e255b41-15b8-486b-969e-e24d5c13118d}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[AbortDone := bAbortDone;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="AxisState" Id="{8543a64f-cfc1-4464-880f-fb8b0081b8e8}">
      <Declaration><![CDATA[PROPERTY AxisState : MC_AxisStates]]></Declaration>
      <Get Name="Get" Id="{2010c811-c440-4e2c-80c8-2541abf98579}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[AxisState := THIS^.eAxisState;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="AxisStatus" Id="{a2f51608-f018-4206-8683-35f8a139b286}">
      <Declaration><![CDATA[METHOD INTERNAL AxisStatus
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.AxisRef.ReadStatus();
// (*Axis id in motion "motor"*)
THIS^.nAxisId:=AxisRef.NcToPlc.AxisId;
// (*Actual Velocity*)
THIS^.fMeasuredVelocity:=AxisRef.NcToPlc.ActVelo;
// (*Actual Position*)
THIS^.fMeasuredPosition:=AxisRef.NcToPlc.ActPos;
// (*Actual Position Diff*)
THIS^.fMeasuredPositionDiff:=THIS^.AxisRef.NcToPlc.PosDiff;
// (*Current Axis state*)
THIS^.eAxisState := THIS^.AxisRef.Status.MotionState;
// (* Target Reached *)
THIS^.bInTargetPosition := THIS^.AxisRef.Status.InTargetPosition;
THIS^.bPositiveMotionIsEnabled := THIS^.AxisRef.Status.PositiveDirection;
THIS^.bNegativeMotionIsEnabled := THIS^.AxisRef.Status.NegativeDirection;]]></ST>
      </Implementation>
    </Method>
    <Method Name="BacklashCompensation" Id="{927638b2-37f4-4736-8328-c9d3bbdf5863}">
      <Declaration><![CDATA[(*
    Handle positive/negative backlash compensation
    User needs to set the direction of backlash from the sign of the compensation value
    Backlash compensation is disabled during referencing (homing).
    When direction is positive/negative, further movement in the negative/positive direction not compensated
    further movement in the negative/positive direction will be compensated
*)
METHOD BacklashCompensation
VAR_INPUT
    User_Enable     : BOOL;
    Backlash	: LREAL;
       BakclashRampRatio	: LREAL := 10.0;
    DisableMode	: E_DISABLEMODE := E_DISABLEMODE.DisableModeHold;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.bUserBacklashEn := User_Enable;
THIS^.fBacklash := Backlash;
THIS^.fBakclashRampRatio := BakclashRampRatio;
THIS^.eDisableMode:=DisableMode;]]></ST>
      </Implementation>
    </Method>
    <Property Name="BufferMode" Id="{bbbbad1c-a25b-4e16-b8e7-df89fde7223f}">
      <Declaration><![CDATA[PROPERTY BufferMode : MC_BufferMode
]]></Declaration>
      <Set Name="Set" Id="{09436c45-d463-45eb-84c8-25add90ecfb1}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[eBufferMode := BufferMode;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="CalibrateRawEncValue" Id="{1731f1b4-fc8d-48cd-81d7-d75b2a571773}">
      <Declaration><![CDATA[METHOD INTERNAL CalibrateRawEncValue
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF nRawEncoderULINT <> 0 THEN
    IF nRawEncoderULINT < 4294967296 THEN
        nEncoderCount := ULINT_TO_UDINT(nRawEncoderULINT);
    ELSE
        nEncoderCount := ULINT_TO_UDINT(18446744073709551615 - nRawEncoderULINT);
    END_IF
ELSIF nRawEncoderUINT <> 0 THEN
    nEncoderCount := UINT_TO_UDINT(nRawEncoderUINT);
ELSIF nRawEncoderINT <> 0 THEN
    nEncoderCount := INT_TO_UDINT(nRawEncoderINT);
ELSIF nRawEncoderDINT <> 0 THEN
    nEncoderCount := DINT_TO_UDINT(nRawEncoderDINT);
ELSE
    nEncoderCount := 0;
END_IF]]></ST>
      </Implementation>
    </Method>
