    <Method Name="AxisStatus" Id="{a2f51608-f018-4206-8683-35f8a139b286}">
      <Declaration><![CDATA[METHOD AxisStatus
]]></Declaration>
      <Implementation>
        <ST><![CDATA[AxisRef.ReadStatus();
//
// (*Axis id in motion "motor"*)
nAxisId:=AxisRef.NcToPlc.AxisId;
//
// (*Actual Velocity*)
// SUPER^.fMeasuredVelocity:=AxisRef.NcToPlc.ActVelo;
//
// (*Actual Position*)
// IF SUPER^.AxisRef.Status.OpMode.Modulo THEN
//     SUPER^.fMeasuredPosition:=AxisRef.NcToPlc.ModuloActPos;
// ELSE
//     SUPER^.fMeasuredPosition:=AxisRef.NcToPlc.ActPos;
// END_IF
//
// (*Actual Position Diff*)
// SUPER^.fMeasuredPositionDiff:=SUPER^.AxisRef.NcToPlc.PosDiff;
// (*Current Axis state*)
eAxisState := AxisRef.Status.MotionState;
// (*Target Reached*)
// SUPER^.bInTargetPosition := SUPER^.AxisRef.Status.InTargetPosition;]]></ST>
      </Implementation>
    </Method>
    <Method Name="BacklashCompensation" Id="{927638b2-37f4-4736-8328-c9d3bbdf5863}">
      <Declaration><![CDATA[(*
    Handle positive/negative backlash compensation
    User needs to set the direction of backlash from the sign of the compensation value
    Backlash compensation is disabled during referencing (homing).
    When direction is positive/negative, further movement in the negative/positive direction not compensated
    further movement in the negative/positive direction will be compensated
*)
METHOD BacklashCompensation

]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*Note: Configure within the axis parameters set "position correction" to true
    Directional change FOR compensation
      FALSE: positive backlash:
      TRUE -> Negative backlash compensation
    Reset Compensation to register a new value change
*)
bBacklashCompEnable R= bExecHome OR (THIS^.fBacklash<>fPrevCompensation);
bBacklashCompEnable S= bExecMove;

fbMcBacklashCompensation(Axis:=AxisRef,
    Enable:= ( THIS^.bUserBacklashEn AND bBacklashCompEnable),
    Backlash:= THIS^.fBacklash,
    CompensationInPositiveDirection:=(THIS^.fBacklash<0.0),
    Ramp:=( fMoveAbsoluteTargetVelocity / fBakclashRampRatio ),
    DisableMode:=DisableModeHold,
    Enabled=> THIS^.bBacklashStatus,
    Error=>,
    ErrorID=>,
    CurrentBacklash=>THIS^.fCurrentBacklash
);
fPrevCompensation:=THIS^.fBacklash;]]></ST>
      </Implementation>
    </Method>
