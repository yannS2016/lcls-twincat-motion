    <Method Name="EmergencyReset" Id="{19357ae2-2734-4e5e-b7fa-6a933d786328}">
      <Declaration><![CDATA[(* Force clearing of all MC_Block execute inputs
  this can be used to override MC_Blocks stuck in previous status from erros or logic faillure to clear the cmds when job done
*)
METHOD EmergencyReset
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.bCommandedReset := FALSE;
THIS^.bCommandedHalt := FALSE;
THIS^.bCommandedMoveHome := FALSE;
THIS^.bCommandedMoveAbsolute := FALSE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="EncErrorCheck" Id="{7c7bd705-a252-45ea-8394-e497101ce9be}">
      <Declaration><![CDATA[METHOD EncErrorCheck : BOOL
VAR_INPUT
    EncError : BOOL;
    EncErrorCode : UDINT;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Maybe different for some DS402 NC based drives. if so adjust or derive.
EncErrorCheck := EncError AND EncErrorCode >= 16#4400 AND EncErrorCode <= 16#44FF;]]></ST>
      </Implementation>
    </Method>
