<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MotionAxisCommon" Id="{b2f4c148-bcde-4ca5-a7a9-abd4413ce8ab}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'call_after_init'}
FUNCTION_BLOCK FB_MotionAxisCommon IMPLEMENTS I_MotionAxisCommon
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    {attribute 'no_copy'}
    AxisRef : REFERENCE TO AXIS_REF;
    //{attribute 'hide'}
    MotionSyncPrivateRef : REFERENCE TO FB_MotionSyncPrivate;
    // Raw encoder IO for ULINT (Biss-C)
    nRawEncoderULINT AT %I*: ULINT;
    // Raw encoder IO for UINT (Relative Encoders)
    nRawEncoderUINT AT %I*: UINT;
    // Raw encoder IO for INT (LVDT)
    nRawEncoderINT AT %I*: INT;
    // Raw encoder IO for INT (EL5072 LVDT)
    nRawEncoderDINT AT %I*: DINT;
    // Encoder count summary, if linked above
    {attribute 'pytmc' := '
        pv: PLC:nEncoderCount
        io: i
        field: DESC Count from encoder hardware
    '}
    nEncoderCount: UDINT;
    (* Other status information for users of the IOC *)
    (* Backlash compensation*)
    // Enabled axis backlash compensation
    {attribute 'pytmc' := '
        pv: PLC:bBacklashEn
        io: io
        field: ZNAM FALSE
        field: ONAM TRUE
        field: DESC Enable Backlash compensation
    '}
    bUserBacklashEn: BOOL;

    // backlash compensation status
    {attribute 'pytmc' := '
        pv: PLC:bBacklasStatus
        io: i
        field: ZNAM DISABLED
        field: ONAM ENABLED
        field: DESC Backlash compensation status
    '}
    bBacklashStatus: BOOL;

    // Backlash compensation value
    {attribute 'pytmc' := '
        pv: PLC:fBacklash
        io: io
        field: DESC Backlash compensation
    '}
    fBacklash: LREAL;

    // Current Backlash compensation value ?
    {attribute 'pytmc' := '
        pv: PLC:fCurrentBacklash
        io: i
        field: DESC Currently applied compensation
    '}
    fCurrentBacklash: LREAL;

    // Position lag difference
    {attribute 'pytmc' := '
        pv: PLC:fPosDiff
        io: i
        field: DESC Position lag difference
    '}
    fPosDiff: LREAL;

    // NC parameters that are exposed with pytmc pragmas
    {attribute 'pytmc' := '
        pv: PLC:AxisPar
        io: i
        field: DESC Axis configuration parameters in the numerical controller.
    '}
    stAxisParameterSetExposed : ST_AxisParameterSetExposed;

    // MC_ReadParameterSet Output
    {attribute 'hide'}
    mcReadParams: MC_ReadParameterSet;
    //{attribute 'hide'}
    stAxisParameters: ST_AxisParameterSet;

    {attribute 'hide'}
    bNcParamsReadInit   : BOOL;

    (* NC Blocks *)
    // MoveABsolute
    fbMcMoveAbsolute : MC_MoveAbsolute;
    bCommandedMoveAbsolute : BOOL;
    {attribute 'hide'}
    bMoveAbsoluteBusy : BOOL;
    {attribute 'hide'}
    bMoveAbsoluteDone : BOOL;
    {attribute 'hide'}
    bMoveAbsoluteError : BOOL;
    {attribute 'hide'}
    bCommandAborted : BOOL;
    {attribute 'hide'}
    nMoveAbsoluteErrorID : UDINT;
    // Reset
    fbMcReset 	: MC_Reset;
    {attribute 'hide'}
    bResetDone 	: BOOL;
    {attribute 'hide'}
    bResetBusy	: BOOL;
    {attribute 'hide'}
    bResetError	: BOOL;
    {attribute 'hide'}
    bResetErrorID	: UDINT;
    {attribute 'hide'}
    bReset		: BOOL;
    bCommandedReset : BOOL;
    // Power
    fbMcPower 		: MC_Power;
    bPowerEnable	: BOOL;
    bPowerEnablePositive : BOOL;
    bPowerEnableNegative : BOOL;
    {attribute 'hide'}
    bPowerIsEnabled : BOOL;
    {attribute 'hide'}
    bPowerBusy 		: BOOL;
    {attribute 'hide'}
    bPowerError 	: BOOL;
    {attribute 'hide'}
    nPowerErrorID 	: UDINT;
    {attribute 'hide'}
    fOverride 		: LREAL := 100.0;
    //////////////////
    fbMcHalt 		: MC_Halt;
    bCommandedHalt 	: BOOL;
    {attribute 'hide'}
    bHaltDone 		: BOOL;
    {attribute 'hide'}
    bHaltError 		: BOOL;
    {attribute 'hide'}
    nHaltErrorID 	: UDINT;
    {attribute 'hide'}
    bHaltBusy 		: BOOL;
    bExecHome : BOOL;
    bExecMove : BOOL;
    // Move parameters
    fMoveAbsoluteTargetPosition	: LREAL;
    fMoveAbsoluteTargetVelocity	: LREAL;
    fMoveAbsoluteTargetAcceleration	: LREAL := 0.0;
    fMoveAbsoluteTargetDeceleration	: LREAL := 0.0;
    fMoveAbsoluteTargetJerk	: LREAL := 0.0;

    eBufferMode	: MC_BufferMode := .MC_BufferMode.MC_Aborting;
    // Axis Status
    {attribute 'hide'}
    nAxisId : UDINT;
    {attribute 'hide'}
    fMeasuredVelocity : LREAL;
    {attribute 'hide'}
    fMeasuredPosition : LREAL;
    {attribute 'hide'}
    fMeasuredPositionDiff : LREAL;
    {attribute 'hide'}
    fMeasuredAcceleration : LREAL;
    // Needed for interlocks checks. please keep this as declared
    {attribute 'hide'}
    eAxisState : MC_AxisStates;
    // save and restore
    {attribute 'hide'}
    fbSetPos: MC_SetPosition;
    {attribute 'hide'}
    bClearPositionLag : BOOL := TRUE;
    {attribute 'hide'}
    bAxisError 		: BOOL;
    {attribute 'hide'}
    bPowerStatus 	: BOOL;
    {attribute 'hide'}
    bRestoreDone 	: BOOL;
    {attribute 'hide'}
    bRestoreError 	: BOOL;
    {attribute 'hide'}
    nRestoreErrorID : UDINT;

    // save and Restore
    {attribute 'hide'}
    RestoreTimer: TON;
    {attribute 'hide'}
    bRestoreInit: BOOL;
    {attribute 'hide'}
    bRestoreLoad: BOOL;
    {attribute 'hide'}
    nLatchError: UDINT;
    {attribute 'hide'}
    bEncError: BOOL;
    {attribute 'hide'}
    tRetryDelay: TIME := T#1S;
    {attribute 'hide'}
    nMaxRetries: UINT := 10;
    {attribute 'hide'}
    nCurrTries: UINT := 0;
    {attribute 'hide'}
    bRestoreWaitRetry: BOOL;
    {attribute 'hide'}
    tonRestoreRetry: TON;
    {attribute 'hide'}
    tRefreshTime : TIME := T#1S;

    // create a property for some of these
    {attribute 'hide'}
    bDone		: BOOL;
    {attribute 'hide'}
    bBusy		: BOOL;
    {attribute 'hide'}
    bInTargetPosition	: BOOL;
    {attribute 'hide'}
    bInterrupted : BOOL;
    // Error handling
    {attribute 'hide'}
    bError				: BOOL;
    {attribute 'hide'}
    nErrorId			: UDINT:=0;
    {attribute 'hide'}
    sErrorMessage		: STRING;
    {attribute 'hide'}
    rtMoveAbsoluteBusy 			: R_TRIG;
    {attribute 'hide'}
    ftMoveAbsoluteBusy 			: F_TRIG;
    {attribute 'hide'}
    //ftStopExec 		: F_TRIG;
    {attribute 'hide'}
    ftError		: F_TRIG;
    {attribute 'hide'}
    //rtHaltedDone	: R_TRIG;
    {attribute 'hide'}
    //rtTargetReached	: R_TRIG;
    {attribute 'hide'}
    rtAbsoluteMoveDone	: R_TRIG;
    fbMcBacklashCompensation: MC_BacklashCompensation;
    fPrevCompensation : LREAL := 0.0;
    bBacklashCompEnable: BOOL;
    fBakclashRampRatio : LREAL := 10.0;

    fRefVeloSearch : LREAL;
    fRefVeloSync : LREAL;
    {attribute 'no_copy'}
   // AxisRef : REFERENCE TO AXIS_REF;
    //iMotionAxisCommon : I_MotionAxisCommon;
    iPersistentDataStorage : I_PersistentDataStorage;
    iMotionLogger : I_MotionLogger;
     iMotionInterlocks: I_MotionInterlocks;
    fSetPosition	: LREAL;
    fSetVelocity	: LREAL;
    fSetAcceleration	: LREAL := 0.0;
    fSetDeceleration	: LREAL := 0.0;
    fSetJerk	: LREAL := 0.0;
    sName : STRING;
    // Piezo Motion Control
    tholtime		: TIME := T#10S;
    fPowerOverride : LREAL := 100.0;
    {attribute 'hide'}
    nCommand 		: UINT;
    nCommandData		: UINT;

    //rtDone 				: R_TRIG;
    rtError				: R_TRIG;
    rtReset				: R_TRIG;
    ftServo				: F_TRIG;
    rtDone : R_TRIG;
    // This prevent unexpected logical 1 on stMotionStage.bExecute
    bCommandedMoveHome  : BOOL;
    bHomeBusy			: BOOL;
    bHomeDone			: BOOL;
    // get this value from fb_MotionDrive epics interface
    fHomePosition 		: LREAL :=0.0;
    rtHomeDone				: R_TRIG;
    bHomeInterrupted	: BOOL;
    bHomeError 			: BOOL;
    nHomeErrorID 		: UDINT;
    nHomeMode:ENUM_EpicsHomeCmd :=ENUM_EpicsHomeCmd.NONE;

END_VAR


VAR PERSISTENT
    {attribute 'conditionalshow'}
    bSaved: BOOL;
    {attribute 'conditionalshow'}
    fSavedPosition: LREAL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[





]]></ST>
    </Implementation>
