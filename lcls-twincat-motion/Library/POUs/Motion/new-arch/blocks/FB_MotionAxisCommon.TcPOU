    <Method Name="MoveAbsolute" Id="{bedd8396-b1f3-452f-bba8-1daae2474961}">
      <Declaration><![CDATA[METHOD MoveAbsolute
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[////////////////////////////////////////////////////////////////////////////////////
// Handling Absolute move request using signaling events
// on CommandedMoveAbsolute
// clear the done bit after previous move is completed by an error condition
///////////////////////////////////////////////////////////////////////////////////

THIS^.fbMcMoveAbsolute(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedMoveAbsolute,
    Position := THIS^.fMoveAbsoluteTargetPosition,
    Velocity := THIS^.fMoveAbsoluteTargetVelocity,
    Acceleration := THIS^.fMoveAbsoluteTargetAcceleration,
    Deceleration := THIS^.fMoveAbsoluteTargetDeceleration,
    Jerk := THIS^.fMoveAbsoluteTargetJerk,
    BufferMode := THIS^.eBufferMode,
    Done => ,
    Busy => THIS^.bMoveAbsoluteBusy,
    Active => ,
    CommandAborted => THIS^.bCommandAborted,
    Error => THIS^.bMoveAbsoluteError,
    ErrorID => THIS^.nMoveAbsoluteErrorID
);
(*a Neg edge on busy does not mean that the cause of that event has completed
    its execution, thus setting done base on it alone is not correct
    Engaging the limit, halting or resetting will cause a neg edge on busy
    For haltingand resetting we use each block done bit for terminating the move
    For limit switch we use the set abs move done flag to true after testing that
    The interuption is not from hatling or resetting.
*)
IF THIS^.bMoveAbsoluteError THEN
    //THIS^.bCommandedMoveAbsolute := FALSE;
END_IF
rtMoveAbsoluteBusy (CLK:=bMoveAbsoluteBusy);
ftMoveAbsoluteBusy(CLK:=bMoveAbsoluteBusy);

bMoveAbsoluteDone S= ftMoveAbsoluteBusy.Q AND NOT THIS^.bMoveAbsoluteError AND NOT THIS^.bResetBusy AND NOT THIS^.bHaltBusy;
bMoveAbsoluteDone R= rtMoveAbsoluteBusy.Q;]]></ST>
      </Implementation>
    </Method>
