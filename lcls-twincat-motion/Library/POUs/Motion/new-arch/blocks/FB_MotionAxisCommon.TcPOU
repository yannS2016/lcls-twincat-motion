    <Method Name="MoveAbsolute" Id="{bedd8396-b1f3-452f-bba8-1daae2474961}">
      <Declaration><![CDATA[METHOD MoveAbsolute
VAR_INPUT
    Execute     : BOOL;
    Position	: LREAL;
    Velocity	: LREAL;
    Acceleration	: LREAL := 0.0;
    Deceleration	: LREAL := 0.0;
    Jerk	: LREAL := 0.0;
    BufferMode	: MC_BufferMode := MC_BufferMode.MC_Aborting;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.bCommandedMoveAbsolute := Execute;
THIS^.fMoveAbsoluteTargetPosition := Position;
THIS^.fMoveAbsoluteTargetVelocity := Velocity;
THIS^.fMoveAbsoluteTargetAcceleration := Acceleration;
THIS^.fMoveAbsoluteTargetDeceleration := Deceleration;
THIS^.fMoveAbsoluteTargetJerk := Jerk;
THIS^.eBufferMode := BufferMode;]]></ST>
      </Implementation>
    </Method>
    <Property Name="MoveAbsoluteBusy" Id="{8bba339d-272b-4575-bd5a-b3466a6e1c1c}">
      <Declaration><![CDATA[PROPERTY MoveAbsoluteBusy : BOOL
