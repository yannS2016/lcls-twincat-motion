<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MotionAxisDS402NC" Id="{c65bcaa5-32c2-4ba1-a44e-f37d90d611d0}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MotionAxisDS402NC IMPLEMENTS I_MotionAxis
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    {attribute 'no_copy'}
    AxisRef : REFERENCE TO AXIS_REF;
    iMotionAxisCommon : I_MotionAxisCommon;
    // NC Blocks
    fbSetPos		:	MC_SetPosition;
    fbReset: MC_Reset;
    fbPower: MC_Power;
    fbHalt: MC_Halt;
    fbJog: MC_Jog;
    fbMoveVelocity: MC_MoveVelocity;
    fbMoveRelative: MC_MoveRelative;
    fbMcMoveAbsolute: MC_MoveAbsolute;
    fbMoveModulo: MC_MoveModulo;
    //fbHomeVirtual:FB_MotionHoming;
    fbGearInDyn: MC_GearInDyn;
    fbGearOut: MC_GearOut;

     bClearPositionLag : BOOL := TRUE;
    fPowerOverride: LREAL := 100;
    nCommandLocal: UINT;
    nCmdDataLocal: UINT;
    // create a property for some of these
    bExecMove			: BOOL;
    bExecHome			: BOOL;
    bPosGoal			: BOOL;
    bNegGoal			: BOOL;
    bNewMoveReq			: BOOL;
    bHomingBusy			: BOOL;
    bHomingDone			: BOOL;
    bPrepareDisable		: BOOL;
    bMoveDone			: BOOL;
    bMoveBusy			: BOOL;
    bHalted				: BOOL;
    bAborted			: BOOL;
    bStopped			: BOOL;
    bOperational		: BOOL;
    bServoOffTrans		: BOOL;
    bServoOnTrans 		: BOOL;
    bServoOffMode		: BOOL ;
    bServoOnMode		: BOOL;
    bDiscreteInit		: BOOL;
    bDiscreteMotionAct  : BOOL;
    bServoOffparamsSet  : BOOL;
    bServoOffparamsSetDone : BOOL;
    bLimOverride				: BOOL;
    bPositionHolding		: BOOL;
    bError				: BOOL:=FALSE;
    bErrorStop			: BOOL;
    // use this for motion time axis states
    bExecute			: BOOL;
    // This prevent unexpected logical 1 on stMotionStage.bExecute
    nErrorId			: UDINT:=0;
    sLocalErrorMessage	: STRING;
    nPiezoErrorCode		: UDINT;
    // Save abd restore encoder value
    bInit				: BOOL;
    bLoad				: BOOL;
    bEncError			: BOOL;
    bSaveDone			: BOOL;
    bAbortDone			: BOOL;
    // axis status -- emulating some NC axis
    bClosedLoopMode		:	BOOL;
    bPositiveDirection	:  	BOOL;
    bNegativeDirection 	:  	BOOL;
    bInTargetPosition 	:  	BOOL;
    bReadErrDone			: 	BOOL;
    bLogReady			: 	BOOL;
    bFault				: 	BOOL;
    bDiscreteMotion 	:  	BOOL;
    bContinuousMotion 	:  	BOOL;
    bSlowParamReadTimer	: 	BOOL := TRUE;
	ftDone : F_TRIG;
    rtHaltedDone	: R_TRIG;
    rtTargetReached	: R_TRIG;
    ftAbortDone: F_TRIG;
    rtFault			: R_TRIG;
    rtHomed			: R_TRIG;
    rtMoveCmdShortcut	: R_TRIG;
    rtHomeCmdShortcut	: R_TRIG;
	rtAbsoluteModeDone		: R_TRIG;
	rtNewMoveReq			: R_TRIG;
    rtEnableMode		: R_TRIG;
    rtUserExec			: R_TRIG;
    rtModeChange			: R_TRIG;
    rtTarget		: R_TRIG;
    rtServoOnMode	: R_TRIG;
    rtEnableDrive	: R_TRIG;
    rtServoOnTrans	: R_TRIG;
    rtNotClState 	: R_TRIG;
    rtNotOlState 	: R_TRIG;
    //rtNewMoveReq	: R_TRIG;
    rtNewHoldTime	: R_TRIG;
    ftServoOffTrans	: F_TRIG;
    rtServoOffMode	: R_TRIG;
    ftAmsNetId 		: F_TRIG;
    ftExec			: F_TRIG;
    ftErrorSdoRead	: F_TRIG;
    ftEnableDrive	: F_TRIG;
    ftForwardEnabled	: F_TRIG;
    ftBackwardEnabled	: F_TRIG;
    ftServo				: F_TRIG;
	
    ftSdoStep		: 	F_TRIG;
    ftSdoStepFreq	: 	F_TRIG;
    ftSdoStepAmp	: 	F_TRIG;
	sErrorMessage : STRING;
    tonSyncHoming 		: TON;
    tonHoldTime			: TON;
    tonServoOffSync		: TON;
    tonSlowParamReadTimer: TON;
    // fast changing paramter timer -- wwe could have used PDO for this params
    // but the Piezo ESC have fixed PDO list.
    tonFastParamReadTimer: TON;
    //bInitiated	: BOOL;
    // Diagnotics data from the drive, mainly Error codes
 
    tholtime		: TIME := T#10S;
    bBusy : BOOL;
	ftStopExec : F_TRIG;
// NC Exposed Parameters

    fHomePosition : LREAL :=0.0;
    nHomingMode:ENUM_EpicsHomeCmd :=ENUM_EpicsHomeCmd.NONE;


    bCommandedMoveAbsolute : BOOL;
    bMostRecentMoveAbsoluteDone : BOOL;

    bCommandedReset : BOOL;
    fbMcReset : MC_Reset;

    fbMcPower : MC_Power;

    bCommandedHalt : BOOL;
    fbMcHalt : MC_Halt;
    bMostRecentHaltDone : BOOL;

    bCommandedStop : BOOL;
    fbMcStop : MC_Stop;
    bMostRecentStopDone : BOOL;
	
	bMoveAbsoluteBusy : BOOL;
	bMoveAbsoluteDone : BOOL;
	bMoveAbsoluteError : BOOL;
	bCommandAborted : BOOL;
	bActive : BOOL;
	nMoveAbsoluteErrorID : UDINT;
    fPosition	: LREAL;
    fVelocity	: LREAL;
    fAcceleration	: LREAL := 0.0;
    fDeceleration	: LREAL := 0.0;
    fJerk	: LREAL := 0.0;
    eBufferMode	: MC_BufferMode := .MC_BufferMode.MC_Aborting;
	// Reset
    bResetDone : BOOL;
    bResetBusy: BOOL;
    bResetError: BOOL;
    bResetErrorID: UDINT;
	// Power
    bPowerEnable : BOOL;
	bPowerEnablePositive : BOOL;
    bPowerEnableNegative : BOOL;
	bPowerIsEnabled : BOOL;
	bPowerBusy : BOOL;
	bPowerError : BOOL;
	nPowerErrorID : UDINT;
	// Halt
	bHaltDone : BOOL;
	bHaltError : BOOL;
	nHaltErrorID : UDINT;
	bHaltBusy : BOOL;
	bReset : BOOL;
END_VAR


VAR CONSTANT

END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF( AxisRef ) OR (THIS^.AxisRef.NcToPlc.AxisId = 0)THEN
    RETURN;
END_IF

///////////////////////////////////////////////////////////////
// Reset the Axis based on signaling event on CommandedReset
//////////////////////////////////////////////////////////////
THIS^.fbMcReset(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedReset,
    Done => bResetDone,
    Busy => bResetBusy,
    Error => bResetError,
    ErrorID => bResetErrorID,
);

IF bResetDone THEN
	THIS^.bCommandedReset := FALSE;	
END_IF

//////////////////////////////////////////////////////////////////
// Power block depends on interlocks check in  iMotionInterlocks
/////////////////////////////////////////////////////////////////
THIS^.fbMcPower(
    Axis := THIS^.AxisRef,
    Enable := bPowerEnable,
    Enable_Positive := bPowerEnablePositive,
    Enable_Negative := bPowerEnableNegative,
    Override := fPowerOverride,
    BufferMode := eBufferMode,
	(*Enabled*)
    Status => bPowerIsEnabled,
    Busy => bPowerBusy,
    Error => bPowerError,
    ErrorID => nPowerErrorID
);
////////////////////////////////////////////////////////////////////////////////////
// Handling Absolute move request using signaling events
// on CommandedMoveAbsolute and bPowerIsEnabled ( interlock dependent)
// clear the done bit after previous move is completed by an error condition
///////////////////////////////////////////////////////////////////////////////////

IF AxisRef.Status.Error THEN
	bMoveAbsoluteDone := FALSE;
END_IF

THIS^.fbMcMoveAbsolute(
    Axis := THIS^.AxisRef,
	// for DURING_MOTION mode, we need to wait for bPowerIsEnabled to be set
    Execute := THIS^.bCommandedMoveAbsolute AND bPowerIsEnabled,
    Position := fPosition,
    Velocity := fVelocity,
    Acceleration := fAcceleration,
    Deceleration := fDeceleration,
    Jerk := fJerk,
    BufferMode := eBufferMode,
    Done => ,
    Busy => bMoveAbsoluteBusy,
    Active => bActive,
    CommandAborted => bCommandAborted,
    Error => bMoveAbsoluteError,
    ErrorID => nMoveAbsoluteErrorID
);
// A neg edge on bMoveAbsoluteBusy comfirm that the previous move is done
// either because of an error, an abort or a target reached.
// bMoveAbsoluteDone will reset next cycle if done condition was an error
ftDone (CLK:=bMoveAbsoluteBusy);
IF ftDone.Q THEN
	bMoveAbsoluteDone := TRUE;
END_IF
/////////////////////////////////////////////////////////////////////////////
// Execute DS402 Homing routine using signaling event on CommandedMoveHome
////////////////////////////////////////////////////////////////////////////
THIS^.Home();

]]></ST>
    </Implementation>
