    <Method Name="MoveAbsolute" Id="{6b50c75c-030a-4b3c-9a0b-c342bc66e047}">
      <Declaration><![CDATA[METHOD MoveAbsolute
VAR_INPUT
// Set the corresponding properties for motion paramters
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.fbMcMoveAbsolute(
    Axis := THIS^.AxisRef,
	// for DURING_MOTION mode, we need to wait for bPowerIsEnabled to be set
    Execute := THIS^.bCommandedMoveAbsolute AND bPowerIsEnabled,
    Position := fPosition,
    Velocity := fVelocity,
    Acceleration := fAcceleration,
    Deceleration := fDeceleration,
    Jerk := fJerk,
    BufferMode := eBufferMode,
    Done => ,
    Busy => bMoveAbsoluteBusy,
    Active => bActive,
    CommandAborted => bCommandAborted,
    Error => bMoveAbsoluteError,
    ErrorID => nMoveAbsoluteErrorID
);
// We dont allow  any new request unless the current one is:
// 1- Done
// 2- Aborted / Stopped
// 3- Halted ( loosely, has halted does not complete the current move instead its pauses it)
// THIS^.bCommandedMoveAbsolute : maintains previous state till any of the condition above occurs



]]></ST>
      </Implementation>
    </Method>
