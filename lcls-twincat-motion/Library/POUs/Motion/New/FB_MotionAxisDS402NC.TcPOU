    <Method Name="Power" Id="{dd25e964-0517-40f5-924c-4964ca24fa0f}">
      <Declaration><![CDATA[METHOD Power
VAR_INPUT
    Enable	: BOOL;
    Enable_Positive	: BOOL;
    Enable_Negative	: BOOL;
    (* in percent from 0 to 100 *)
    Override	: LREAL := 100.0;
    BufferMode	: MC_BufferMode := .MC_BufferMode.MC_Aborting;
END_VAR
VAR_OUTPUT
    Status	: BOOL;
    Busy	: BOOL;
    Active	: BOOL;
    Error	: BOOL;
    ErrorID	: UDINT;
    ErrorStr	: T_MaxString;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.fbMcPower(
    Axis := THIS^.AxisRef,
    Enable := PowerEnable,
    Enable_Positive := bPowerEnablePositive,
    Enable_Negative := bPowerEnableNegative,
    Override := fPowerOverride,
    BufferMode := eBufferMode,
	(*Enabled*)
    Status => bPowerIsEnabled,
    Busy => bPowerBusy,
    Error => bPowerError,
    ErrorID => nPowerErrorID
);

]]></ST>
      </Implementation>
    </Method>
