    <Method Name="FB_Init" Id="{3c6b89cf-6335-421f-bc49-43ad02ddd5d0}">
      <Declaration><![CDATA[//FB_Init is always available implicitly and it is used primarily for initialization.
//The return value is not evaluated. For a specific influence, you can also declare the
//methods explicitly and provide additional code there with the standard initialization
//code. You can evaluate the return value.
METHOD FB_Init: BOOL
VAR_INPUT
    bInitRetains: BOOL; // TRUE: the retain variables are initialized (reset warm / reset cold)
    bInCopyCode: BOOL;  // TRUE: the instance will be copied to the copy code afterward (online change)
    AxisReference : REFERENCE TO AXIS_REF;
    //iMotionAxisCommon : I_MotionAxisCommon;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[AxisRef REF= AxisReference;
//iMotionAxisCommon := iMotionAxisCommon;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Halt" Id="{b6a8e12d-141b-4b04-b9a3-63a5a6a53059}">
      <Declaration><![CDATA[METHOD Halt


]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.fbMcHalt(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedHalt,
    Deceleration := fDeceleration,
    Jerk := fJerk,
    BufferMode := eBufferMode,
    Done => bHaltDone,
    Busy => bHaltBusy,
    CommandAborted => bCommandAborted,
    Error => bHaltError,
    ErrorID => nHaltErrorID
);

THIS^.bCommandedHalt := FALSE;
]]></ST>
      </Implementation>
    </Method>
