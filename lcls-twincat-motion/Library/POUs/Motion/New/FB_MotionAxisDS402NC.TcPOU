    <Method Name="Reset" Id="{a6bfedcd-09ad-4e2e-b0fb-fb5b66d37a7f}">
      <Declaration><![CDATA[METHOD Reset
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.fbMcReset(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedReset,
    Done => bResetDone,
    Busy => bResetBusy,
    Error => bResetError,
    ErrorID => bResetErrorID,
);

IF bResetDone THEN
	THIS^.bCommandedReset := FALSE;	
END_IF
]]></ST>
