    <Method Name="Home" Id="{70bd90c9-eebc-4f8a-a8ba-43919335ed26}">
      <Declaration><![CDATA[METHOD Home
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//
// tonSyncHoming(PT:=T#500MS);
// (* IMPORTANT: Homing options and parameters must be configured either via the COE online tab or via the service tool *)
// CASE eHomingState OF
//     E_DS402Homing.INIT_HOMING :;
// 		rtModeChange (CLK:=(THIS^.ModeOfOperationDisplay = E_DS402OpMode.HOMING));
//         IF rtModeChange.Q THEN
// 			tonSyncHoming.IN := TRUE;
//             stPiezoStage.nPiezoDriveControl.4:=TRUE;
//         END_IF
// 		IF tonSyncHoming.Q THEN
// 			eHomingState:=E_DS402Homing.HOMING_IN_PROGRESS;
// 		END_IF
//     E_DS402Homing.HOMING_IN_PROGRESS:
//         IF NOT stPiezoStage.stPiezoDriveStatus.TargetReached
//            AND NOT stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
//                 HomingBusy:=TRUE;
//                 HomeDone:=FALSE;
//
//         // Interrupted
//         ELSIF Stopped AND stPiezoStage.bHalt THEN
//             eHomingState:=E_DS402Homing.HOMING_INTERRUPTED;
//
// 		// Genral Motion error i.e Following error ?
// 		ELSIF stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
// 			eHomingState:=E_DS402Homing.HOMING_ERROR;
//
//         // Reached
//         ELSIF stPiezoStage.stPiezoDriveStatus.TargetReached
//             AND stPiezoStage.stPiezoDriveStatus.Bit12_OpModeSpecific
//             AND NOT stPiezoStage.stPiezoDriveStatus.Bit13_OpModeSpecific THEN
//             eHomingState:=E_DS402Homing.HOMING_ATTAINED;
//         END_IF
//
//
//     E_DS402Homing.HOMING_INTERRUPTED :;
//         HomingBusy:=FALSE;
//         HomeDone:=FALSE;
// 		Halted := TRUE;
// 		McAxisState:= MC_AxisStates.MC_AXISSTATE_STOPPING;
//
//     E_DS402Homing.HOMING_ATTAINED:;
//         HomingBusy:=FALSE;
// 		tonSyncHoming.IN := FALSE;
// 		tonHoldTime.IN := TRUE;
// 		eHomingState:=E_DS402Homing.HOMING_DONE;
//
//     E_DS402Homing.HOMING_DONE:;
// 		//prepare next move
// 		IF NOT THIS^.PositionHolding THEN
// 			HomeDone:=TRUE;
