    <Method Name="PostMoveHandling" Id="{4fda8021-4799-4333-8c6f-645440426869}">
      <Declaration><![CDATA[METHOD PostMoveHandling
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="ProcessMoveReq" Id="{1da2dc9d-4406-4cb4-be2e-a29a35f201c7}">
      <Declaration><![CDATA[METHOD ProcessMoveReq
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*
   Check for the plc shortcut commands
   Used for testing or to circumvent motor record issues
   A request is process and qualified as a legitimate move after it clears interlocks checks
*)
rtMoveCmdShortcut(CLK:=bMoveCmd);
rtHomeCmdShortcut(CLK:=stMotionEpicsItf.bHomeCmd);

// Execute on rising edge
IF rtMoveCmdShortcut.Q AND NOT stMotionEpicsItf.bExecute THEN
    stMotionEpicsItf.bExecute:=TRUE;
    stMotionEpicsItf.nCommand:=E_EpicsMotorCmd.MOVE_ABSOLUTE;
    // attempting to move an axis without homing first?
    IF iMotionAxis.HomeMode <> E_EpicsHomeCmd.NONE AND NOT iMotionAxis.HomeDone THEN
        stMotionEpicsItf.sErrorMessage:='Axis homing mode set, but homing routine pending';
    END_IF

ELSIF rtHomeCmdShortcut.Q AND NOT stMotionEpicsItf.bExecute THEN
    stMotionEpicsItf.bExecute:= NOT ( stMotionEpicsItf.nCmdData = E_EpicsHomeCmd.ABSOLUTE_SET ) OR NOT ( stMotionEpicsItf.nCmdData = E_EpicsHomeCmd.NONE);

    stMotionEpicsItf.nCommand:=E_EpicsMotorCmd.HOME;
    // Automatically fill the correct nCmdData for homing
    stMotionEpicsItf.nCmdData:=iMotionAxis.HomeMode;
END_IF

// Handle main execs .  Rising on bMoved should be the ntry point
// bu this is not the case in production its a rising on bExecute.
rtUserExec(CLK:=stMotionEpicsItf.bExecute);
// if a Move/Home Goal is comfirmed and there is no persistant
// error conditions, then we have a valid move request.
bNewMoveReq S= NOT stMotionEpicsItf.stAxisStatus.bBusy AND rtUserExec.Q AND NOT stMotionEpicsItf.bError;
// this Move request is valid till an error occurs or the currently move is done
bNewMoveReq R= NOT stMotionEpicsItf.bExecute OR stMotionEpicsItf.bError;
// define this R_TRIG to comfirm a new move request.
rtNewMoveReq(CLK:=bNewMoveReq);

(*These are additional status for special uses*)
bPosGoal  S= rtNewMoveReq.Q AND (iMotionAxisCommon.ActPosition < stMotionEpicsItf.fPosition) ;
bNegGoal  S= rtNewMoveReq.Q AND (iMotionAxisCommon.ActPosition > stMotionEpicsItf.fPosition) ;
bPosGoal  R= iMotionAxis.HomeBusy OR bNegGoal;
bNegGoal  R= iMotionAxis.HomeBusy OR bPosGoal;

// Transfer nCommand and nCmdData to local copies at rising edge of bExecute
// (avoid issues if nCommand or nCmdData are changed during a command)
fbExecuteRiseEdge(CLK:=iMotionInterlocks.Execute);
IF fbExecuteRiseEdge.Q THEN
  iMotionAxis.CmdData:=INT_TO_UINT(stMotionEpicsItf.nCmdData);
  iMotionAxis.Cmd:=INT_TO_UINT(stMotionEpicsItf.nCommand);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{953319a7-2879-4371-9527-9f5359dadf51}">
      <Declaration><![CDATA[{warning 'Add method implementation '}
METHOD Reset
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Reset everything when bReset is flagged
IF stMotionEpicsItf.bReset THEN
            stMotionEpicsItf.bExecute := FALSE;
            stMotionEpicsItf.bError := FALSE;
            stMotionEpicsItf.nErrorId := 0;
            stMotionEpicsItf.sErrorMessage := '';
            // Propagate Reset event
            iMotionInterlocks.Reset := stMotionEpicsItf.bReset;
            iMotionAxis.Reset := stMotionEpicsItf.bReset;
            iMotionAxisCommon.Reset := stMotionEpicsItf.bReset;
            stMotionEpicsItf.bReset := FALSE;

END_IF]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>