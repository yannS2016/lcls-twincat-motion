    <Method Name="AllEnable" Id="{d8a3a70f-6b1a-419d-a2d4-e80c80ec0881}">
      <Declaration><![CDATA[METHOD AllEnable
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
bAllEnable := bEnable AND bHardwareEnable AND bEpicsEPSOk;
bAllEnable R= NOT bEpicsUserEn;]]></ST>
      </Implementation>
    </Method>
