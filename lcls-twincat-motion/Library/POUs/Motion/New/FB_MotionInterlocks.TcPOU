    <Method Name="PostMoveInterlocks" Id="{b5d413e1-a0f2-4ef7-886c-b72d777e4bc0}">
      <Declaration><![CDATA[METHOD PostMoveInterlocks

VAR
    rtTarget: R_TRIG;
    rtHomed: R_TRIG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Check done moving via user stop, axis Target Position reached, or from homing.

ftStopExec(CLK:=bEpicsExec);
rtTarget(CLK:=(bMoveDone));
rtHomed(CLK:=bHomeDone);
IF ftStopExec.Q OR rtTarget.Q OR rtHomed.Q THEN
    IF NOT bEpicsDone THEN
        bEpicsBusy := FALSE;
        bEpicsDone := bMoveDone OR bHomeDone;
        IF NOT bAxisError THEN
            bEpicsExec := FALSE;
            bExecute := FALSE;
        END_IF
    END_IF
END_IF

// Handle auto-disable timing
bPrepareDisable S= (EnableMode = E_StageEnableMode.DURING_MOTION AND ftStopExec.Q );
// Delay the disable until we reach standstill, else brake issues or other race conditions
IF bPrepareDisable AND MotionState = MC_AXISSTATE_STANDSTILL THEN
    bPrepareDisable := FALSE;
    bEnable := FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="PowerInterlocks" Id="{7e05d54d-8f72-4bf3-a74d-f567b6a489ab}">
      <Declaration><![CDATA[METHOD PowerInterlocks
]]></Declaration>
      <Implementation>
        <ST><![CDATA[rtNewMoveReq(CLK:=bNewMoveReq);
rtEnableMode(CLK:=(EnableMode = E_StageEnableMode.DURING_MOTION));
// Handle auto-enable timing
CASE EnableMode OF
    E_StageEnableMode.ALWAYS:
        bEnable:=TRUE;
    E_StageEnableMode.DURING_MOTION:
        IF rtEnableMode.Q THEN
            bEnable := FALSE;
        END_IF
        // Power interlock only enabled with a new move request
        IF rtNewMoveReq.Q THEN
            bEnable S= SafetyReady;
        END_IF
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Property Name="PowerSelf" Id="{fb36e9c1-0ee1-4f1a-b06f-22d945195377}">
      <Declaration><![CDATA[{warning 'Add property implementation'}
PROPERTY PowerSelf : BOOL
]]></Declaration>
      <Get Name="Get" Id="{c06ff4fd-ee59-4911-94a2-c723bdd82017}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[ PowerSelf := bPowerSelf;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{b9461afa-a4ea-4cd5-ab04-03c92360ffde}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[ bPowerSelf := PowerSelf;]]></ST>
