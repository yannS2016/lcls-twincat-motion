    <Method Name="LimHit" Id="{7c1d3d89-4cb6-42f8-8e46-9fb90fc36cd7}">
      <Declaration><![CDATA[METHOD LimHit
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// use falling trigger to avoid spaming  sErrorMessage
ftForwardEnabled(CLK:=bAllForwardEnable);
ftBackwardEnabled(CLK:=bAllBackwardEnable);

IF  NOT bHomeBusy AND ftForwardEnabled.Q THEN
    // Not an error, just a warning
    sEpicsWarnMsg:='Cannot move past positive limit.';
    bLimOverride := TRUE;
    bEpicsExec:=FALSE;

ELSIF NOT bHomeBusy AND ftBackwardEnabled.Q THEN
    // Not an error, just a warning
    sEpicsWarnMsg:='Cannot move past Negative limit.';
    bLimOverride := TRUE;
    bEpicsExec:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
