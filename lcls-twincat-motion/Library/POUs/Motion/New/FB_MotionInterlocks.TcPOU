      </Set>
    </Property>
    <Method Name="PreMoveInterlocks" Id="{0acfe365-427d-447d-bdaa-7f2cc05bea76}">
      <Declaration><![CDATA[METHOD PreMoveInterlocks
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT bEpicsError AND bEpicsExec AND NOT bEpicsUserEn THEN
    bEpicsError := TRUE;
    nErpicsWarnId := 1;
    sEpicsWarnMsg := 'Move requested, but user enable is disabled!';
END_IF

// Get a definitive bEnabled reading
CASE MotionState OF
    // We are not enabled if there is an issue
    MC_AXISSTATE_UNDEFINED, MC_AXISSTATE_DISABLED, MC_AXISSTATE_ERRORSTOP:
        bEnableDone := FALSE;
    ELSE
        bEnableDone := TRUE;
END_CASE

// This is the output interlock check used to allow the requested move
bExecute:= NOT bEpicsError AND bEpicsExec AND bAllEnable AND bEnableDone AND bSafetyReady;
//
// When we start, set the busy/done appropriately
rtExec(CLK:=bExecute);
IF rtExec.Q THEN
    // move end status
    bEpicsDone R= FALSE;
    bEpicsBusy R= FALSE;
    bHomeDone R= FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
