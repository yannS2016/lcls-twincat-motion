    <Property Name="MoveAbsoluteTargetVelocity" Id="{e615d560-a621-4c43-b5ac-5ce3d0036d44}">
      <Declaration><![CDATA[PROPERTY MoveAbsoluteTargetVelocity : LREAL
]]></Declaration>
