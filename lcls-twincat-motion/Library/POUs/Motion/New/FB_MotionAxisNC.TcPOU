<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MotionAxisNC" Id="{abd0b982-5130-4244-8207-eba0b3246906}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MotionAxisNC IMPLEMENTS I_MotionAxis
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    {attribute 'no_copy'}
    AxisRef : REFERENCE TO AXIS_REF;
    iMotionAxisCommon : I_MotionAxisCommon;
    iPersistentDataStorage : I_PersistentDataStorage;
    iMotionLogger : I_MotionLogger;

    stAxisParameterSetExposed : ST_AxisParameterSetExposed;

    // This prevent unexpected logical 1 on stMotionStage.bExecute
    nErrorId			: UDINT:=0;
    bHomingBusy			: BOOL;
    bHomingDone			: BOOL;
    fHomePosition : LREAL :=0.0;
    bError				: BOOL;
    sErrorMessage		: STRING;

    fSetPosition	: LREAL;
    fSetVelocity	: LREAL;
    fSetAcceleration	: LREAL := 0.0;
    fSetDeceleration	: LREAL := 0.0;
    fSetJerk	: LREAL := 0.0;
    nHomingMode:ENUM_EpicsHomeCmd :=ENUM_EpicsHomeCmd.NONE;
    eBufferMode	: MC_BufferMode := .MC_BufferMode.MC_Aborting;
    eMoveMode : E_MoveMode;
    sName : STRING;
    // Piezo Motion Control
    tholtime		: TIME := T#10S;
    bBusy : BOOL;
    bDone: BOOL;
    bPowerEnable : BOOL;
    bPowerEnableNegative : BOOL;
    bPowerEnablePositive : BOOL;
    bPowerIsEnabled : BOOL;
    fPowerOverride : LREAL := 100.0;
    bResetDone : BOOL;
    bHaltDone : BOOL;
    bHomeDone  : BOOL;

    {attribute 'hide'}
    eAxisState : MC_AxisStates;
    // intermediary motion signal: from EPICS interface
    bCmdMoveAbsolute	: BOOL;
    bCmdReset 			: BOOL;
    bCmdHalt 			: BOOL;
    bCmdMoveHome			: BOOL;
    nCommand 		: UINT;
    nCommandData		: UINT;
    nEncoderCount	: UDINT;
    fMoveAbsoluteTargetPosition : LREAL;
    fMoveAbsoluteTargetVelocity : LREAL;
    fMoveAbsoluteTargetAcceleration : LREAL;
    fMoveAbsoluteTargetDeceleration : LREAL;
    fMoveAbsoluteTargetJerk : LREAL;
    fMeasuredAcceleration : LREAL;
    fMeasuredVelocity : LREAL;
    fMeasuredPosition : LREAL;
    fMeasuredPositionDiff : LREAL;

    rtDone 				: R_TRIG;
    rtError				: R_TRIG;
    rtReset				: R_TRIG;
    rtHomed				: R_TRIG;
    ftServo				: F_TRIG;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Propagate user command to common worker
// 1- Power status
iMotionAxisCOmmon.BufferMode := THIS^.eBufferMode;
iMotionAxisCommon.PowerEnable := THIS^.bPowerEnable;
iMotionAxisCommon.PowerEnableNegative := THIS^.bPowerEnableNegative;
iMotionAxisCommon.PowerEnablePositive := THIS^.bPowerEnablePositive;
iMotionAxisCommon.PowerOverride := THIS^.fPowerOverride;
// 2- Motion commands
iMotionAxisCommon.CommandedHalt := THIS^.bCmdHalt;
iMotionAxisCommon.CommandedReset := THIS^.bCmdReset;
iMotionAxisCommon.CommandedMoveAbsolute := THIS^.bCmdMoveAbsolute;
iMotionAxisCommon.MoveAbsoluteTargetPosition := THIS^.fMoveAbsoluteTargetPosition;
iMotionAxisCommon.MoveAbsoluteTargetVelocity := THIS^.fMoveAbsoluteTargetVelocity;
iMotionAxisCommon.MoveAbsoluteTargetAcceleration := THIS^.fMoveAbsoluteTargetAcceleration;
iMotionAxisCommon.MoveAbsoluteTargetDeceleration := THIS^.fMoveAbsoluteTargetDeceleration;
iMotionAxisCommon.MoveAbsoluteTargetJerk := THIS^.fMoveAbsoluteTargetJerk;

// readbacks and status update from common worker
THIS^.fMeasuredAcceleration := iMotionAxisCommon.MeasuredAcceleration;
THIS^.fMeasuredVelocity := iMotionAxisCommon.MeasuredVelocity;
THIS^.fMeasuredPosition := iMotionAxisCommon.MeasuredPosition;
THIS^.fMeasuredPositionDiff := iMotionAxisCommon.MeasuredPositionDiff;
THIS^.nEncoderCount := iMotionAxisCommon.EncoderCount;
THIS^.bHaltDone := iMotionAxisCommon.HaltDone;
THIS^.bResetDone := iMotionAxisCommon.ResetDone;
THIS^.bDone := iMotionAxisCommon.MoveAbsoluteDone OR THIS^.HomeDone;
THIS^.bBusy := iMotionAxisCommon.MoveAbsoluteBusy OR THIS^.HomingBusy;
THIS^.bError := iMotionAxisCommon.Error;
THIS^.nErrorId := iMotionAxisCommon.ErrorID;
THIS^.sErrorMessage := iMotionAxisCommon.ErrorMessage;
THIS^.eAxisState := iMotionAxisCommon.AxisState;

// reset cmds if done, error or reset
rtDone(CLK:=bDone);
rtError(CLK:=bError);
rtReset(CLK:=bResetDone);
IF rtDone.Q OR rtError.Q OR rtReset.Q THEN
    bCmdMoveAbsolute	:= FALSE;
    bCmdReset	:= FALSE;
    bCmdHalt 	:= FALSE;
    bCmdMoveHome	:= FALSE;
END_IF]]></ST>
    </Implementation>
