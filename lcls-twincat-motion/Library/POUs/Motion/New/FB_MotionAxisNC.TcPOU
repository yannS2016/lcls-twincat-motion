    <Method Name="EncErrorCheck" Id="{029213d6-00be-442b-b832-8ab7e7fd1f46}">
      <Declaration><![CDATA[METHOD EncErrorCheck : BOOL
VAR_INPUT
    EncError : BOOL;
    EncErrorCode : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[EncErrorCheck := EncError AND EncErrorCode >= 16#4400 AND EncErrorCode <= 16#44FF;]]></ST>
      </Implementation>
    </Method>
