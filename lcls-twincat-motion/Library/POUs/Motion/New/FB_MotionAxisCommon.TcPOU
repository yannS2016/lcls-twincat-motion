      </Set>
    </Property>
    <Method Name="ErrorHandling" Id="{e3e9f4c3-bd6f-4479-80bb-9cc735eca053}">
      <Declaration><![CDATA[METHOD ErrorHandling
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*Error from functions and Nc*)
IF fbMcPower.Error AND fbMcPower.Active THEN
    bError:=fbMcPower.Enable;
    nErrorId:=fbMcPower.ErrorID;
ELSIF fbMcHalt.Error AND fbMcHalt.Active THEN
    bError:=fbMcHalt.Execute;
    nErrorId:=fbMcHalt.ErrorID;
ELSIF fbMcMoveAbsolute.Error AND nCommandLocal=3 (*fbMcMoveAbsolute.Active*) THEN
    bError:=fbMcMoveAbsolute.Execute;
    nErrorId:=fbMcMoveAbsolute.ErrorID;
ELSIF HomeError AND nCommandLocal=10 (*fbMcHome.Active*) THEN
    bError:=HomeError;
    nErrorId:=HomeErrorID;

ELSIF AxisRef.Status.Error  THEN
    bError:=TRUE;
    nErrorId:=AxisRef.Status.ErrorID;
ELSIF HomeError THEN
    bError:=TRUE;
    nErrorId:=HomeErrorID;
ELSE
    bError:=FALSE;
    nErrorId:=0;
END_IF;
]]></ST>
      </Implementation>
    </Method>
