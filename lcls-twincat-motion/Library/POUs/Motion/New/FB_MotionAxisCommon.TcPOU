    <Method Name="EncRestore" Id="{f9f7cdfc-d8df-423b-8c50-6f118d29a052}">
      <Declaration><![CDATA[METHOD EncRestore
VAR
    tRetryDelay: TIME := T#1S;
    nMaxRetries: UINT := 10;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT bRestoreDone THEN
// Trigger a load if anything was saved at all
    IF NOT bInitRestore THEN
       bInitRestore := TRUE;
       bRestoreLoad S= bSaved;
        // this belongs to iMotionAxis.SetRestorePosition()
        // fbSetPos.Options.ClearPositionLag := TRUE;
    END_IF

    // Set our position if bLoad is true
    SetRestorePosition( bRestoreLoad, fSavedPosition );

    // Only load once, at startup
    bRestoreLoad R= bRestoreDone OR bRestoreError;

    IF bRestoreError THEN
        // Keep the error latched, it can disappear if Execute is set to FALSE
        nRestoreLatchErrorID :=  nRestoreLatchErrorID;
        nRestoreCurrTries := nRestoreCurrTries + 1;
        IF nRestoreCurrTries >= nMaxRetries THEN
            // Alert the user that something has gone wrong
            Error := TRUE;
            ErrorID := nRestoreLatchErrorID;
            sErrorMessage := 'Error loading previously saved position.';
        ELSE
            // Reset the FB for the next retry
             SetRestorePosition( bRestoreLoad, fSavedPosition );
            // Try again
            bRestoreWaitRetry := TRUE;
        END_IF
    END_IF

END_IF

tonSaveRestoreTimer( IN := bRestoreWaitRetry, PT := tRetryDelay );
bRestoreLoad S= tonSaveRestoreTimer.Q;
bRestoreWaitRetry R= tonSaveRestoreTimer.Q;]]></ST>
      </Implementation>
    </Method>
    <Method Name="EncSave" Id="{3648ae53-29b9-44bf-a321-1effe30ac004}">
      <Declaration><![CDATA[METHOD EncSave
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Check ST_MotionStage for an encoder error (range 0x44nn)
bEncError:= AxisRef.Status.Error AND  ( AxisRef.Status.ErrorID  >= 16#4400  AND AxisRef.Status.ErrorID <= 16#44FF );

// Do not save if we're currently loading or if there is an encoder error
IF NOT bRestoreLoad AND NOT bEncError AND NOT bRestoreWaitRetry THEN
    fSavedPosition := fActPosition;
    // This persistent variable lets us check if anything was saved
    // It will be TRUE at startup if we have saved values
    bSaved := TRUE;
    (*
        use this with a timer of a change threshold on the fActPosition
        to trigger a save from this PLC program. otherwise this will be a spamming
        persistence, filling up the disk.
    *)
    // iPersistantDataStorage.TriggerWriteOfPersistentData := TRUE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Property Name="Error" Id="{2819c2f0-b6fd-42b1-b42d-175038209c48}">
