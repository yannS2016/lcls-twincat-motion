    </Property>
    <Property Name="Busy" Id="{dbe7370a-96f9-4293-8d7a-aa83479a93ec}">
      <Declaration><![CDATA[{attribute 'monitoring':= 'variable'}
PROPERTY Busy : BOOL
]]></Declaration>
      <Get Name="Get" Id="{cf057b51-ea7a-4a6d-80b9-c1ff9ed546dd}">
