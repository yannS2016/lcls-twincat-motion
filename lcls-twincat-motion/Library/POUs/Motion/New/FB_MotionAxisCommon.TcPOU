      <Declaration><![CDATA[{attribute 'monitoring':= 'variable'}
PROPERTY AxisState : MC_AxisStates
]]></Declaration>
      <Get Name="Get" Id="{5079f451-585f-45fc-ac12-d15b6be4da3e}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[AxisState := eAxisState;]]></ST>
