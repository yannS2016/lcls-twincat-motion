<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MotionAxisCommon" Id="{b2f4c148-bcde-4ca5-a7a9-abd4413ce8ab}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MotionAxisCommon IMPLEMENTS I_MotionAxisCommon
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
    {attribute 'no_copy'}
    AxisRef : REFERENCE TO AXIS_REF;
    // MC_ReadParameterSet Output
    {attribute 'hide'}
    mcReadParams: MC_ReadParameterSet;
    {attribute 'hide'}
    stAxisParameters: ST_AxisParameterSet;
    // NC Exposed Parameters
    {attribute 'hide'}
    stAxisParameterSetExposed : ST_AxisParameterSetExposed;
    {attribute 'hide'}
    bNcParamsReadInit   : BOOL;

    // NC er IO for ULINT (Biss-C)
    nRawEncoderULINT AT %I*: ULINT;
    // Raw encoder IO for UINT (Relative Encoders)
    nRawEncoderUINT AT %I*: UINT;
    // Raw encoder IO for INT (LVDT)
    nRawEncoderINT AT %I*: INT;
    // Raw encoder IO for INT (EL5072 LVDT)
    nRawEncoderDINT AT %I*: DINT;
    nEncoderCount	: UDINT;

    (* NC Blocks *)
    // MoveABsolute
    fbMcMoveAbsolute : MC_MoveAbsolute;
    bCommandedMoveAbsolute : BOOL;
    {attribute 'hide'}
    bMoveAbsoluteBusy : BOOL;
    {attribute 'hide'}
    bMoveAbsoluteDone : BOOL;
    {attribute 'hide'}
    bMoveAbsoluteError : BOOL;
    {attribute 'hide'}
    bCommandAborted : BOOL;
    {attribute 'hide'}
    nMoveAbsoluteErrorID : UDINT;
    // Reset
    fbMcReset 	: MC_Reset;
    {attribute 'hide'}
    bResetDone 	: BOOL;
    {attribute 'hide'}
    bResetBusy	: BOOL;
    {attribute 'hide'}
    bResetError	: BOOL;
    {attribute 'hide'}
    bResetErrorID	: UDINT;
    {attribute 'hide'}
    bReset		: BOOL;
    bCommandedReset : BOOL;
    // Power
    fbMcPower 		: MC_Power;
    bPowerEnable	: BOOL;
    bPowerEnablePositive : BOOL;
    bPowerEnableNegative : BOOL;
    {attribute 'hide'}
    bPowerIsEnabled : BOOL;
    {attribute 'hide'}
    bPowerBusy 		: BOOL;
    {attribute 'hide'}
    bPowerError 	: BOOL;
    {attribute 'hide'}
    nPowerErrorID 	: UDINT;
    {attribute 'hide'}
    fOverride 		: LREAL := 100.0;
    //////////////////
    fbMcHalt 		: MC_Halt;
    bCommandedHalt 	: BOOL;
    {attribute 'hide'}
    bHaltDone 		: BOOL;
    {attribute 'hide'}
    bHaltError 		: BOOL;
    {attribute 'hide'}
    nHaltErrorID 	: UDINT;
    {attribute 'hide'}
    bHaltBusy 		: BOOL;

    // Move parameters
    fMoveAbsoluteTargetPosition	: LREAL;
    fMoveAbsoluteTargetVelocity	: LREAL;
    fMoveAbsoluteTargetAcceleration	: LREAL := 0.0;
    fMoveAbsoluteTargetDeceleration	: LREAL := 0.0;
    fMoveAbsoluteTargetJerk	: LREAL := 0.0;
    nCommandLocal: UINT;
    nCmdDataLocal: UINT;
    eBufferMode	: MC_BufferMode := .MC_BufferMode.MC_Aborting;
    // Axis Status
    {attribute 'hide'}
    nAxisId : UDINT;
    {attribute 'hide'}
    fMeasuredVelocity : LREAL;
    {attribute 'hide'}
    fMeasuredPosition : LREAL;
    {attribute 'hide'}
    fMeasuredPositionDiff : LREAL;
    {attribute 'hide'}
    fMeasuredAcceleration : LREAL;
    // Needed for interlocks checks. please keep this as declared
    {attribute 'hide'}
    eAxisState : MC_AxisStates;
    // save and restore
    {attribute 'hide'}
    fbSetPos: MC_SetPosition;
    {attribute 'hide'}
    bClearPositionLag : BOOL := TRUE;
    {attribute 'hide'}
    bAxisError 		: BOOL;
    {attribute 'hide'}
    bPowerStatus 	: BOOL;
    {attribute 'hide'}
    bRestoreDone 	: BOOL;
    {attribute 'hide'}
    bRestoreError 	: BOOL;
    {attribute 'hide'}
    nRestoreErrorID : UDINT;

    // save and Restore
    {attribute 'hide'}
    RestoreTimer: TON;
    {attribute 'hide'}
    bRestoreInit: BOOL;
    {attribute 'hide'}
    bRestoreLoad: BOOL;
    {attribute 'hide'}
    nLatchError: UDINT;
    {attribute 'hide'}
    bEncError: BOOL;
    {attribute 'hide'}
    tRetryDelay: TIME := T#1S;
    {attribute 'hide'}
    nMaxRetries: UINT := 10;
    {attribute 'hide'}
    nCurrTries: UINT := 0;
    {attribute 'hide'}
    bRestoreWaitRetry: BOOL;
    {attribute 'hide'}
    tonRestoreRetry: TON;
    {attribute 'hide'}
    tRefreshTime : TIME := T#1S;

    // create a property for some of these
    {attribute 'hide'}
    bDone		: BOOL;
    {attribute 'hide'}
    bBusy		: BOOL;
    {attribute 'hide'}
    bInTargetPosition	: BOOL;

    // Error handling
    {attribute 'hide'}
    bError				: BOOL;
    {attribute 'hide'}
    nErrorId			: UDINT:=0;
    {attribute 'hide'}
    sErrorMessage		: STRING;
    {attribute 'hide'}
    ftMoveAbsoluteBusy 			: F_TRIG;
    {attribute 'hide'}
    ftStopExec 		: F_TRIG;
    {attribute 'hide'}
    rtTarget		: R_TRIG;
    {attribute 'hide'}
    rtHaltedDone	: R_TRIG;
    {attribute 'hide'}
    rtTargetReached	: R_TRIG;
    {attribute 'hide'}
    ftAbsoluteMoveDone	: F_TRIG;

END_VAR

VAR PERSISTENT
    {attribute 'conditionalshow'}
    bSaved: BOOL;
    {attribute 'conditionalshow'}
    fSavedPosition: LREAL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF( AxisRef ) OR (THIS^.AxisRef.NcToPlc.AxisId = 0)THEN
    RETURN;
END_IF

////////////////////////////////////////////////////////////////////////
THIS^.AxisStatus();

THIS^.fbMcHalt(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedHalt,
    Deceleration := THIS^.fMoveAbsoluteTargetDeceleration,
    Jerk := THIS^.fMoveAbsoluteTargetJerk,
    BufferMode := THIS^.eBufferMode,
    Done => THIS^.bHaltDone,
    Busy => THIS^.bHaltBusy,
    CommandAborted => THIS^.bCommandAborted,
    Error => THIS^.bHaltError,
    ErrorID => THIS^.nHaltErrorID
);

THIS^.bCommandedHalt := FALSE;

///////////////////////////////////////////////////////////////
// Reset the Axis based on signaling event on CommandedReset
//////////////////////////////////////////////////////////////
THIS^.fbMcReset(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedReset,
    Done => THIS^.bResetDone,
    Busy => THIS^.bResetBusy,
    Error => THIS^.bResetError,
    ErrorID => THIS^.bResetErrorID,
);

IF bResetDone THEN
    THIS^.bCommandedReset := FALSE;
END_IF

//////////////////////////////////////////////////////////////////
// Power block depends on interlocks check in  iMotionInterlocks
/////////////////////////////////////////////////////////////////
THIS^.fbMcPower(
    Axis := THIS^.AxisRef,
    Enable := THIS^.bPowerEnable,
    Enable_Positive := THIS^.bPowerEnablePositive,
    Enable_Negative := THIS^.bPowerEnableNegative,
    Override := THIS^.fOverride,
    BufferMode := THIS^.eBufferMode,
    (*Enabled*)
    Status => THIS^.bPowerIsEnabled,
    Busy => THIS^.bPowerBusy,
    Error => THIS^.bPowerError,
    ErrorID => THIS^.nPowerErrorID
);
////////////////////////////////////////////////////////////////////////////////////
// Handling Absolute move request using signaling events
// on CommandedMoveAbsolute
// clear the done bit after previous move is completed by an error condition
///////////////////////////////////////////////////////////////////////////////////
THIS^.fbMcMoveAbsolute(
    Axis := THIS^.AxisRef,
    Execute := THIS^.bCommandedMoveAbsolute,
    Position := THIS^.fMoveAbsoluteTargetPosition,
    Velocity := THIS^.fMoveAbsoluteTargetVelocity,
    Acceleration := THIS^.fMoveAbsoluteTargetAcceleration,
    Deceleration := THIS^.fMoveAbsoluteTargetDeceleration,
    Jerk := THIS^.fMoveAbsoluteTargetJerk,
    BufferMode := THIS^.eBufferMode,
    Done => ,
    Busy => THIS^.bMoveAbsoluteBusy,
    Active => ,
    CommandAborted => THIS^.bCommandAborted,
    Error => THIS^.bMoveAbsoluteError,
    ErrorID => THIS^.nMoveAbsoluteErrorID
);
////////////////////////////////////////////////////////////////////////////
// A neg edge on bMoveAbsoluteBusy comfirm that the previous move is done
//   either because of an error, an abort or a target reached.
//   bMoveAbsoluteDone will reset next cycle if done condition was an error
////////////////////////////////////////////////////////////////////////////
ftMoveAbsoluteBusy (CLK:=bMoveAbsoluteBusy);
ftAbsoluteMoveDone(CLK:=fbMcMoveAbsolute.Done);
IF ftMoveAbsoluteBusy.Q AND NOT bMoveAbsoluteError THEN
    bMoveAbsoluteDone := TRUE;
    bCommandedMoveAbsolute := FALSE;
// Done bit cleared Next cycle
ELSIF ftAbsoluteMoveDone.Q OR AxisRef.Status.Error THEN
   bMoveAbsoluteDone := FALSE;

END_IF

THIS^.CalibrateRawEncValue();

THIS^.ErrorHandling();

THIS^.ExposeNCParams();
//////////////////////////////////////
// Handle save and restor
//////////////////////////////////////
THIS^.EncSaveRestore(bEnable:=TRUE);
]]></ST>
    </Implementation>
