    <Method Name="AxisStatus" Id="{a2f51608-f018-4206-8683-35f8a139b286}">
      <Declaration><![CDATA[METHOD AxisStatus
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.AxisRef.ReadStatus();

(*Axis id in motion "motor"*)
nAxisId:=AxisRef.NcToPlc.AxisId;

(*Actual Velocity*)
fActVelocity:=AxisRef.NcToPlc.ActVelo;

(*Actual Position*)
IF AxisRef.Status.OpMode.Modulo THEN
    fActPosition:=AxisRef.NcToPlc.ModuloActPos;
ELSE
    fActPosition:=AxisRef.NcToPlc.ActPos;
END_IF

(*Actual Position Diff*)
fActDiff:=AxisRef.NcToPlc.PosDiff;
(*Current Axis state*)
AxisState := AxisRef.Status.MotionState;
(*Target Reached*)
bInTargetPosition := AxisRef.Status.InTargetPosition;
 (*Axis Error*)
bAxisError := AxisRef.Status.Error;]]></ST>
      </Implementation>
    </Method>
